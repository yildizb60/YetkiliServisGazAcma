@model List<YetkiliServisGazAcma.Entities.Ys_DevreyeAlma>
@{
    ViewData["Title"] = "İşlem Geçmişim";
    Layout = "_PanelLayout";
    ViewData["ActiveMenu"] = "DevreyeGecmis";
    ViewData["PanelArea"] = "YetkiliServis";
    var firma = ViewBag.Firma as YetkiliServisGazAcma.Entities.Ys_Firma;
    var markaList = ViewBag.MarkaList as List<string> ?? new List<string>();
    string seciliMarka = ViewBag.SeciliMarka as string ?? "";
    string seciliBas = ViewBag.SeciliBas as string ?? "";
    string seciliBit = ViewBag.SeciliBit as string ?? "";
    string seciliMusteri = ViewBag.SeciliMusteri as string ?? "";
    string seciliDurum = ViewBag.SeciliDurum as string ?? "";
    string adSoyad = firma?.YetkiliKisi ?? "Yetkili Servis";
    string basHarf = !string.IsNullOrEmpty(adSoyad) ? adSoyad.Substring(0, 1).ToUpper() : "Y";
}
@section Styles {
    <style>
.btn-yeni { padding: 9px 20px; background: #4CAF7D; color: #fff; border: none; border-radius: 7px; font-size: 14px; font-weight: bold; text-decoration: none; }
        .btn-yeni:hover { background: #3d9e6e; }
.mesaj-basarili { background: #E1F5EE; color: #085041; padding: 14px 18px; border-radius: 8px; margin-bottom: 18px; font-size: 14px; border-left: 4px solid #4CAF7D; }

        /* istatistik kartlari */
        .istat-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-bottom: 20px; }
        .istat-kart { background: #fff; border-radius: 10px; border: 1px solid #eee; padding: 16px 20px; display: flex; align-items: center; gap: 14px; }
        .istat-icon { width: 44px; height: 44px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 20px; }
        .istat-icon.yesil { background: #E1F5EE; }
        .istat-icon.mavi { background: #E6F1FB; }
        .istat-icon.sari { background: #FAEEDA; }
        .istat-sayi { font-size: 22px; font-weight: bold; color: #1a1a1a; }
        .istat-label { font-size: 12px; color: #888; margin-top: 2px; }

        /* Filtre */
        .filtre-kart { background: #fff; border-radius: 10px; border: 1px solid #eee; padding: 18px 22px; margin-bottom: 16px; display: flex; gap: 14px; align-items: flex-end; flex-wrap: wrap; }
        .filtre-alan { display: flex; flex-direction: column; gap: 5px; min-width: 160px; }
        .filtre-alan label { font-size: 12px; color: #555; font-weight: bold; }
        .filtre-alan input, .filtre-alan select { padding: 9px 11px; border: 1.5px solid #ddd; border-radius: 7px; font-size: 14px; outline: none; color: #333; }
        .filtre-alan input:focus, .filtre-alan select:focus { border-color: #4CAF7D; }
        .btn-filtre { padding: 9px 20px; background: #1B9FD4; color: #fff; border: none; border-radius: 7px; font-size: 14px; cursor: pointer; font-weight: bold; }
        .btn-filtre:hover { background: #0d7faa; }

        /* Tablo */
        .section { background: #fff; border-radius: 10px; border: 1px solid #eee; overflow: hidden; }
        .tablo-head { display: grid; grid-template-columns: 1fr 1.2fr 1.5fr 1.2fr 0.8fr 0.8fr 0.6fr; padding: 12px 22px; background: #f4faf7; font-size: 12px; color: #4CAF7D; font-weight: bold; border-bottom: 2px solid #e0f0e8; }
        .tablo-row { display: grid; grid-template-columns: 1fr 1.2fr 1.5fr 1.2fr 0.8fr 0.8fr 0.6fr; padding: 14px 22px; border-top: 1px solid #f0f0ee; font-size: 14px; color: #333; align-items: center; transition: background .1s; }
        .tablo-row:hover { background: #f8fffe; }
        .badge { display: inline-block; padding: 4px 12px; border-radius: 10px; font-size: 12px; font-weight: bold; }
        .b-green { background: #E1F5EE; color: #085041; }
        .b-yellow { background: #FAEEDA; color: #633806; }
        .empty { padding: 50px; text-align: center; color: #bbb; font-size: 15px; }
        .model-text { max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .detay-btn { padding: 5px 12px; background: #f0f4f8; border: 1px solid #ddd; border-radius: 6px; font-size: 12px; color: #555; text-decoration: none; cursor: pointer; }
        .detay-btn:hover { background: #e0f0e8; border-color: #4CAF7D; color: #085041; }
    </style>
}

@if (TempData["Basarili"] != null)
            {
                <div class="mesaj-basarili">&#9989; @TempData["Basarili"]</div>
            }

            <!-- istatistikler -->
            <div class="istat-row">
                <div class="istat-kart">
                    <div class="istat-icon yesil">&#9989;</div>
                    <div>
                        <div class="istat-sayi">@Model.Count(x => x.Durum == 1)</div>
                        <div class="istat-label">Tamamlanan İşlem</div>
                    </div>
                </div>
                <div class="istat-kart">
                    <div class="istat-icon sari">&#9203;</div>
                    <div>
                        <div class="istat-sayi">@Model.Count(x => x.Durum == 0)</div>
                        <div class="istat-label">Bekleyen İşlem</div>
                    </div>
                </div>
                <div class="istat-kart">
                    <div class="istat-icon mavi">&#128202;</div>
                    <div>
                        <div class="istat-sayi">@Model.Count</div>
                        <div class="istat-label">Toplam İşlem</div>
                    </div>
                </div>
            </div>

            <!-- Filtreler -->
            <form class="filtre-kart" method="get" action="/ys-devreyeal/gecmis">
                <div class="filtre-alan">
                    <label>Marka</label>
                    <select name="marka">
                        <option value="">Tüm</option>
                        @foreach (var m in markaList)
                        {
                            if (string.Equals(seciliMarka, m, StringComparison.OrdinalIgnoreCase))
                            {
                                <option selected="selected">@m</option>
                            }
                            else
                            {
                                <option>@m</option>
                            }
                        }
                    </select>
                </div>
                <div class="filtre-alan">
                    <label>Başlangıç Tarihi</label>
                    <input type="date" name="bas" value="@seciliBas" />
                </div>
                <div class="filtre-alan">
                    <label>Bit Tarihi</label>
                    <input type="date" name="bit" value="@seciliBit" />
                </div>
                <div class="filtre-alan">
                    <label>Müşteri Adı</label>
                    <input type="text" name="musteri" placeholder="Müşteri ara..." value="@seciliMusteri" />
                </div>
                <div class="filtre-alan">
                    <label>Durum</label>
                    <select name="durum">
                        @if (string.IsNullOrWhiteSpace(seciliDurum))
                        {
                            <option value="" selected="selected">Tüm</option>
                        }
                        else
                        {
                            <option value="">Tüm</option>
                        }
                        @if (string.Equals(seciliDurum, "tamamlandi", StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="tamamlandi" selected="selected">Tamamlandı</option>
                        }
                        else
                        {
                            <option value="tamamlandi">Tamamlandı</option>
                        }
                        @if (string.Equals(seciliDurum, "bekliyor", StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="bekliyor" selected="selected">Bekliyor</option>
                        }
                        else
                        {
                            <option value="bekliyor">Bekliyor</option>
                        }
                    </select>
                </div>
                <button class="btn-filtre" type="submit">Filtrele</button>
            </form>

            <div style="display:flex; justify-content:flex-end; margin-bottom:10px;">
                <a class="btn-yeni" href="/ys-devreyeal">+ Yeni İşlem</a>
            </div>

            <div class="section">
                <div class="tablo-head">
                    <div>Tesisat No</div>
                    <div>Müşteri</div>
                    <div>Marka / Model</div>
                    <div>Teknisyen</div>
                    <div>Tarih</div>
                    <div>Durum</div>
                    <div></div>
                </div>
                @if (!Model.Any())
                {
                    <div class="empty">Henüz işlem bulunmuyor</div>
                }
                else
                {
                    @foreach (var i in Model)
                    {
                        <div class="tablo-row">
                            <div><strong>@i.TesistatNo</strong></div>
                            <div>@i.MusteriAdi</div>
                            <div class="model-text" title="@i.CihazMarka / @i.CihazModeli">
                                @i.CihazMarka / @i.CihazModeli
                            </div>
                            <div>@i.TeknisyenAdi</div>
                            <div>@i.DevreyeAlmaTarihi.ToString("dd.MM.yyyy")</div>
                            <div>
                                <span class="badge @(i.Durum == 1 ? "b-green" : "b-yellow")">
                                    @(i.Durum == 1 ? "Tamamlandı" : "Bekliyor")
                                </span>
                            </div>
                            <div>
                                <a class="detay-btn" href="/ys-devreyeal/detay/@i.Id">Detay</a>
                            </div>
                        </div>
                    }
                }
            </div>
