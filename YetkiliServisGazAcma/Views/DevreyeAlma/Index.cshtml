@{
    ViewData["Title"] = "Cihaz Devreye Al";
    Layout = "_PanelLayout";
    ViewData["ActiveMenu"] = "DevreyeAl";
    ViewData["PanelArea"] = "YetkiliServis";
    var markalar = ViewBag.Markalar as List<YetkiliServisGazAcma.Entities.Ys_Marka>;
    var firma = ViewBag.Firma as YetkiliServisGazAcma.Entities.Ys_Firma;
    string adSoyad = firma?.YetkiliKisi ?? "Yetkili Servis";
    string basHarf = !string.IsNullOrEmpty(adSoyad) ? adSoyad.Substring(0, 1).ToUpper() : "Y";
}
@section Styles {
    <style>
/* Adım göstergesi */
        .adimlar { display: flex; align-items: center; margin-bottom: 24px; }
        .adim { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #bbb; }
        .adim.aktif { color: #1B9FD4; font-weight: bold; }
        .adim.tamamlandi { color: #4CAF7D; }
        .adim-no { width: 28px; height: 28px; border-radius: 50%; background: #eee; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: bold; color: #bbb; }
        .adim.aktif .adim-no { background: #1B9FD4; color: #fff; }
        .adim.tamamlandi .adim-no { background: #4CAF7D; color: #fff; }
        .adim-cizgi { flex: 1; height: 2px; background: #eee; margin: 0 12px; }
        .adim-cizgi.tamamlandi { background: #4CAF7D; }

        /* Kartlar */
        .kart { background: #fff; border-radius: 10px; border: 1px solid #eee; padding: 24px; margin-bottom: 16px; }
        .kart-baslik { font-size: 14px; font-weight: bold; color: #333; margin-bottom: 16px; padding-bottom: 10px; border-bottom: 1px solid #f0f0ee; display: flex; align-items: center; gap: 8px; }

        /* Tesisat sorgulama */
        .sorgula-row { display: flex; gap: 12px; align-items: flex-end; }
        .sorgula-input { flex: 1; }
        label { font-size: 12px; color: #444; font-weight: bold; display: block; margin-bottom: 6px; }
        input, select { padding: 10px 12px; border: 1.5px solid #e0e0e0; border-radius: 8px; font-size: 14px; color: #333; outline: none; width: 100%; }
        input:focus, select:focus { border-color: #1B9FD4; }
        .btn-sorgula { padding: 10px 24px; background: #1B9FD4; color: #fff; border: none; border-radius: 8px; font-size: 13px; font-weight: bold; cursor: pointer; white-space: nowrap; }
        .btn-sorgula:hover { background: #0d7faa; }

        /* Müşteri bilgileri */
        .musteri-bilgi { display: none; }
        .musteri-bilgi.goster { display: block; }
        .bilgi-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 16px; }
        .bilgi-alan { background: #f8f8f6; border-radius: 8px; padding: 12px; }
        .bilgi-label { font-size: 11px; color: #888; margin-bottom: 3px; }
        .bilgi-deger { font-size: 13px; font-weight: bold; color: #333; }
        .uygunluk-badge { display: inline-block; padding: 4px 12px; border-radius: 10px; font-size: 12px; font-weight: bold; background: #E1F5EE; color: #085041; }
        .cihaz-listesi { display: grid; gap: 8px; }
        .cihaz-listesi .cihaz-satir { padding: 8px 10px; border: 1px solid #edf3f8; border-radius: 8px; background: #fff; }
        .cihaz-secim { cursor: pointer; transition: border-color .15s, background .15s, box-shadow .15s; display: flex; align-items: center; justify-content: space-between; gap: 12px; }
        .cihaz-secim::after { content: "Sec"; flex: 0 0 auto; border-radius: 999px; background: #E6F1FB; color: #0d7faa; font-size: 11px; font-weight: 800; padding: 4px 10px; }
        .cihaz-secim:hover { border-color: #1B9FD4; background: #f4fbff; }
        .cihaz-secim.secili { border-color: #1B9FD4; background: #E6F1FB; box-shadow: 0 0 0 2px rgba(27,159,212,.10); }
        .cihaz-secim.secili::after { content: "Secildi"; background: #4CAF7D; color: #fff; }

        /* Marka seçimi */
        .marka-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
        .marka-kart { border: 2px solid #eee; border-radius: 8px; padding: 14px; text-align: center; cursor: pointer; transition: all .15s; }
        .marka-kart:hover { border-color: #1B9FD4; }
        .marka-kart.secili { border-color: #1B9FD4; background: #E6F1FB; }
        .marka-kart.yetkisiz { border-color: #F09595; background: #FCEBEB; cursor: not-allowed; opacity: .6; }
        .marka-adi { font-size: 13px; font-weight: bold; color: #333; margin-top: 4px; }

        /* Form alanlari */
        .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
        .alan { display: flex; flex-direction: column; gap: 5px; }
        .alan.tam { grid-column: span 2; }

        /* Bildirim */
        .mesaj-hata { background: #FCEBEB; color: #501313; padding: 12px 16px; border-radius: 8px; margin-bottom: 16px; font-size: 13px; border: 1px solid #F09595; }
        .mesaj-basarili { background: #E1F5EE; color: #085041; padding: 12px 16px; border-radius: 8px; margin-bottom: 16px; font-size: 13px; }
        .marka-uyari { background: #FCEBEB; color: #501313; padding: 10px 14px; border-radius: 8px; font-size: 13px; display: none; margin-top: 10px; }
        .marka-uyari.goster { display: block; }

        /* Butonlar */
        .butonlar { display: flex; justify-content: flex-end; gap: 10px; margin-top: 16px; }
        .btn-kKaydet { padding: 11px 28px; background: #4CAF7D; color: #fff; border: none; border-radius: 8px; font-size: 14px; font-weight: bold; cursor: pointer; }
        .btn-kKaydet:hover { background: #3d9e6e; }
        .btn-kKaydet:disabled { background: #ccc; cursor: not-allowed; }
        .btn-iiptal { padding: 11px 20px; background: #fff; color: #e24b4a; border: 1px solid #e24b4a; border-radius: 8px; font-size: 13px; text-decoration: none; }

        /* Loading */
        .loading { display: none; text-align: center; padding: 20px; color: #888; font-size: 13px; }
        .loading.goster { display: block; }
    </style>
}

@if (TempData["Hata"] != null)
            {
                <div class="mesaj-hata">&#10060; @TempData["Hata"]</div>
            }

            <!-- Adım Göstergesi -->
            <div class="adimlar">
                <div class="adim aktif" id="adim1">
