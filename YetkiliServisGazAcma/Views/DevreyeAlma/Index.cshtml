                    </div>
                    <div class="bilgi-alan">
                        <div class="bilgi-label">Telefon</div>
                        <div class="bilgi-deger" id="b-musteriTelefon"></div>
                    </div>
                    <div class="bilgi-alan">
                        <div class="bilgi-label">Cari / Abone No</div>
                        <div class="bilgi-deger" id="b-aboneNo"></div>
                    </div>
                    <div class="bilgi-alan">
                        <div class="bilgi-label">S&#246;zle&#351;me No</div>
                        <div class="bilgi-deger" id="b-sozlesmeNo"></div>
                    </div>
                    <div class="bilgi-alan">
                        <div class="bilgi-label">Saya&#231; No</div>
                        <div class="bilgi-deger" id="b-sayacNo"></div>
                    </div>
                    <div class="bilgi-alan">
                        <div class="bilgi-label">Uygunluk Belge No</div>
                        <div class="bilgi-deger" id="b-uygunlukBelgeNo"></div>
                    </div>
                    <div class="bilgi-alan">
                        <div class="bilgi-label">Uygunluk Tarihi</div>
                        <div class="bilgi-deger" id="b-uygunlukTarihi"></div>
                    </div>
                    <div class="bilgi-alan" style="grid-column:span 2">
                        <div class="bilgi-label">Adres</div>
