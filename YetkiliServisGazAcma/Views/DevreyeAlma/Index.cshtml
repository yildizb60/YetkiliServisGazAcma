                            &#9989; Devreye Almay&#305; Tamamla
                        </button>
                    </div>
                </form>
            </div>

<script>
    let seciliMarkaId = 0;
    let seciliMarkaAdi = "";
    let servisCihazlari = [];
    let seciliServisCihazIndex = -1;

    function setAdim(aktif) {
        for (let i = 1; i <= 4; i++) {
            const adim = document.getElementById("adim" + i);
            if (!adim) continue;
            adim.classList.remove("aktif");
            adim.classList.remove("tamamlandi");
            if (i < aktif) adim.classList.add("tamamlandi");
            if (i === aktif) adim.classList.add("aktif");
        }

        for (let i = 1; i <= 3; i++) {
            const cizgi = document.getElementById("cizgi" + i);
            if (!cizgi) continue;
            if (i < aktif) cizgi.classList.add("tamamlandi");
            else cizgi.classList.remove("tamamlandi");
        }
    }

    function temizleSonrakiAdimlar() {
        document.getElementById("musteriBilgiKart")?.classList.remove("goster");
        document.getElementById("markaKart")?.classList.remove("goster");
        document.getElementById("formKart")?.classList.remove("goster");
        document.getElementById("markaUyari")?.classList.remove("goster");
        seciliMarkaId = 0;
        seciliMarkaAdi = "";
        servisCihazlari = [];
        seciliServisCihazIndex = -1;
        document.querySelectorAll(".marka-kart").forEach(x => x.classList.remove("secili"));
        document.querySelectorAll(".cihaz-secim").forEach(x => x.classList.remove("secili"));
        setAdim(1);
    }

    function normalizeMarka(value) {
        return (value || "")
            .toLocaleLowerCase("tr-TR")
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "")
            .replace(/[^a-z0-9]/g, "");
    }

    function markaKartiBul(markaAdi) {
        const aranan = normalizeMarka(markaAdi);
        if (!aranan) return null;

        return Array.from(document.querySelectorAll(".marka-kart")).find(function (kart) {
            return normalizeMarka(kart.dataset.markaAdi) === aranan;
        }) || null;
    }

    function cihazAlanlariniTemizle() {
        const tipSelect = document.querySelector('select[name="CihazTipi"]');
        const kapasiteInput = document.querySelector('input[name="CihazKapasite"]');
        const modelInput = document.querySelector('input[name="CihazModeli"]');
        if (tipSelect) tipSelect.value = "";
        if (kapasiteInput) kapasiteInput.value = "";
        if (modelInput) modelInput.value = "";
        const cihazMarka = document.getElementById("f-cihazMarka");
        if (cihazMarka) cihazMarka.value = "";
    }

    async function tesistatSorgula() {
        const tesisatNoInput = document.getElementById("tesistatNo");
        const sozlesmeNoInput = document.getElementById("sozlesmeNo");
        const loading = document.getElementById("sorgulaLoading");
        const tesisatNo = (tesisatNoInput?.value || "").trim();
        const sozlesmeNo = (sozlesmeNoInput?.value || "").trim();

        if (!tesisatNo) {
            alert("Lütfen tesisat numarası giriniz.");
            return;
        }

        if (!sozlesmeNo) {
            alert("Lütfen sözleşme numarası giriniz.");
            return;
        }

        temizleSonrakiAdimlar();
        if (loading) loading.classList.add("goster");

        try {
            const response = await fetch("/ys-devreyeal/tesisat-sorgula", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ tesistatNo: tesisatNo, sozlesmeNo: sozlesmeNo })
            });

            if (!response.ok) {
                alert("Sorgu sırasında bir hata oluştu.");
                return;
            }

            const data = await response.json();
            if (!data.basarili) {
                alert(data.mesaj || "Tesisat sorgulaması başarısız.");
                return;
            }

            document.getElementById("b-musteriAdi").textContent = data.musteriAdi || "-";
            document.getElementById("b-musteriTcNo").textContent = data.musteriTcNo || "-";
            document.getElementById("b-musteriTelefon").textContent = data.musteriTelefon || "-";
            document.getElementById("b-aboneNo").textContent = data.aboneNo || "-";
            document.getElementById("b-sozlesmeNo").textContent = data.sozlesmeNo || sozlesmeNo || "-";
            document.getElementById("b-sayacNo").textContent = data.sayacNo || "-";
            document.getElementById("b-uygunlukBelgeNo").textContent = data.uygunlukBelgeNo || "-";
            document.getElementById("b-uygunlukTarihi").textContent = data.uygunlukTarihi || "-";
            document.getElementById("b-adres").textContent = data.adres || "-";
            document.getElementById("b-durum").textContent = data.durum || "-";

            const cihazlar = Array.isArray(data.cihazlar) ? data.cihazlar : [];
            servisCihazlari = cihazlar;
            const cihazListesi = document.getElementById("b-cihazlar");
            if (cihazListesi) {
                cihazListesi.innerHTML = "";
                if (cihazlar.length === 0) {
                    cihazListesi.textContent = "Cihaz bilgisi bulunamadı.";
                } else {
                    cihazlar.forEach(function (cihaz, index) {
                        const marka = cihaz.cihazMarka || "-";
                        const tip = cihaz.cihazTipi || "-";
                        const kapasite = cihaz.cihazKapasite || "-";
                        const proje = cihaz.projeNo || "-";
                        const satir = document.createElement("div");
                        satir.className = "cihaz-satir cihaz-secim";
                        satir.setAttribute("role", "button");
                        satir.setAttribute("tabindex", "0");
                        satir.textContent = marka + " / " + tip + " / " + kapasite + " kcal - Proje: " + proje;
                        satir.addEventListener("click", function () { cihazSec(index); });
                        satir.addEventListener("keydown", function (event) {
                            if (event.key === "Enter" || event.key === " ") {
                                event.preventDefault();
                                cihazSec(index);
                            }
                        });
                        cihazListesi.appendChild(satir);
                    });
                }
            }

            document.getElementById("f-tesistatNo").value = data.tesistatNo || "";
            document.getElementById("f-aboneNo").value = data.aboneNo || data.sozlesmeNo || "";
            document.getElementById("f-uygunlukBelgeNo").value = data.uygunlukBelgeNo || "";
            document.getElementById("f-uygunlukTarihi").value = data.uygunlukTarihi || "";
            document.getElementById("f-musteriAdi").value = data.musteriAdi || "";
            document.getElementById("f-musteriTcNo").value = data.musteriTcNo || "";
            document.getElementById("f-musteriTelefon").value = data.musteriTelefon || "";
            document.getElementById("f-adres").value = data.adres || "";

            document.getElementById("musteriBilgiKart")?.classList.add("goster");
            document.getElementById("markaKart")?.classList.add("goster");
            setAdim(2);
        } catch (e) {
            alert("Bağlantı hatası oluştu. Lütfen tekrar deneyiniz.");
        } finally {
            if (loading) loading.classList.remove("goster");
        }
    }

    async function cihazSec(index) {
        const cihaz = servisCihazlari[index];
        if (!cihaz) return;

        seciliServisCihazIndex = index;
        document.querySelectorAll(".cihaz-secim").forEach(function (satir, satirIndex) {
            satir.classList.toggle("secili", satirIndex === index);
        });

        const cihazTipi = cihaz.cihazTipi || "";
        const tipSelect = document.querySelector('select[name="CihazTipi"]');
        if (tipSelect && cihazTipi) {
            const secenek = Array.from(tipSelect.options).find(function (option) {
                return option.value.toLocaleLowerCase("tr-TR") === cihazTipi.toLocaleLowerCase("tr-TR");
            });
            if (secenek) tipSelect.value = secenek.value;
        }

        const kapasiteInput = document.querySelector('input[name="CihazKapasite"]');
        if (kapasiteInput) kapasiteInput.value = cihaz.cihazKapasite || "";

        const modelInput = document.querySelector('input[name="CihazModeli"]');
        if (modelInput && cihaz.cihazModeli) modelInput.value = cihaz.cihazModeli;

        document.getElementById("f-cihazMarka").value = cihaz.cihazMarka || "";
        document.getElementById("markaUyari")?.classList.remove("goster");
        const markaKarti = markaKartiBul(cihaz.cihazMarka);
        if (markaKarti) {
            await markaSec(parseInt(markaKarti.dataset.markaId || "0", 10), markaKarti.dataset.markaAdi || cihaz.cihazMarka || "", markaKarti, true);
            return;
        }

        seciliMarkaId = 0;
        seciliMarkaAdi = "";
        document.getElementById("f-markaid").value = "";
        document.querySelectorAll(".marka-kart").forEach(x => x.classList.remove("secili"));
        document.getElementById("formKart")?.classList.remove("goster");
        setAdim(2);
    }

    async function markaSec(markaId, markaAdi, el, servisCihazindan) {
        const tesistatNo = (document.getElementById("f-tesistatNo")?.value || "").trim();
        if (!tesistatNo) {
            alert("Önce tesisat sorgulaması yapınız.");
            return;
        }

        document.getElementById("markaUyari")?.classList.remove("goster");

        try {
            const response = await fetch("/ys-devreyeal/marka-kontrol", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ markaId: markaId })
            });

            if (!response.ok) {
                alert("Marka kontrolü sırasında hata oluştu.");
                return;
            }

            const data = await response.json();
            if (!data.yetkili) {
                const uyari = document.getElementById("markaUyari");
                if (uyari) {
                    uyari.textContent = data.mesaj || "Bu marka için yetkiniz bulunmamaktadır.";
                    uyari.classList.add("goster");
                }
                return;
            }

            document.querySelectorAll(".marka-kart").forEach(x => x.classList.remove("secili"));
            if (el) el.classList.add("secili");

            seciliMarkaId = markaId;
            seciliMarkaAdi = markaAdi;
            document.getElementById("f-markaid").value = String(markaId);
            if (servisCihazindan) {
                const cihaz = servisCihazlari[seciliServisCihazIndex];
                document.getElementById("f-cihazMarka").value = cihaz?.cihazMarka || markaAdi;
            } else {
                const cihaz = servisCihazlari[seciliServisCihazIndex];
                if (!cihaz) {
                    cihazAlanlariniTemizle();
                }
                document.getElementById("f-cihazMarka").value = markaAdi;
            }

            document.getElementById("formKart")?.classList.add("goster");
            setAdim(3);
        } catch (e) {
            alert("Bağlantı hatası oluştu. Lütfen tekrar deneyiniz.");
        }
    }

    document.getElementById("devreyeAlmaForm")?.addEventListener("submit", function (e) {
        if (!document.getElementById("f-tesistatNo").value) {
            e.preventDefault();
            alert("Önce tesisat sorgulaması yapınız.");
            return;
        }
        if (!document.getElementById("f-markaid").value) {
            e.preventDefault();
            alert("Lütfen marka seçiniz.");
            return;
        }
        setAdim(4);
    });
</script>
