                    </div>
                    <div class="bilgi-alan">
                        <div class="bilgi-label">Tesisat Durumu</div>
                        <div class="bilgi-deger">
                            <span class="uygunluk-badge" id="b-durum"></span>
                        </div>
                    </div>
                    <div class="bilgi-alan" style="grid-column:span 3">
                        <div class="bilgi-label">Servisten Gelen Cihazlar</div>
                        <div class="bilgi-deger cihaz-listesi" id="b-cihazlar"></div>
                    </div>
                </div>
            </div>

            <!-- Marka Seçimi -->
            <div class="kart musteri-bilgi" id="markaKart">
                <div class="kart-baslik">Ad&#305;m 2  Marka Se&#231;imi</div>
                <div class="marka-grid">
    @if (markalar != null)
    {
        @foreach(var m in markalar)
        {
            <div class="marka-kart" data-marka-id="@m.Id" data-marka-adi="@m.MarkaAdi" onclick="markaSec(@m.Id, '@m.MarkaAdi', this)">
                <div style="font-size:28px;">*</div>
                <div class="marka-adi">@m.MarkaAdi</div>
            </div>
        }
    }
</div>
                <div class="marka-uyari" id="markaUyari">&#10060; Bu marka i&#231;in yetkiniz bulunmamaktad&#305;r!</div>
            </div>

            <!-- Devreye Alma Formu -->
            <div class="kart musteri-bilgi" id="formKart">
                <div class="kart-baslik">Ad&#305;m 3  Cihaz Bilgileri</div>
                <form method="post" action="/ys-devreyeal/kaydet" id="devreyeAlmaForm">
                    @Html.AntiForgeryToken()

                    <!-- Gizli alanlar -->
                    <input type="hidden" name="TesistatNo" id="f-tesistatNo" />
                    <input type="hidden" name="AboneNo" id="f-aboneNo" />
                    <input type="hidden" name="UygunlukBelgeNo" id="f-uygunlukBelgeNo" />
                    <input type="hidden" name="UygunlukTarihi" id="f-uygunlukTarihi" />
                    <input type="hidden" name="MusteriAdi" id="f-musteriAdi" />
                    <input type="hidden" name="MusteriTcNo" id="f-musteriTcNo" />
                    <input type="hidden" name="MusteriTelefon" id="f-musteriTelefon" />
                    <input type="hidden" name="Adres" id="f-adres" />
                    <input type="hidden" name="MarkaId" id="f-markaid" />
                    <input type="hidden" name="CihazMarka" id="f-cihazMarka" />

                    <div class="form-grid">
                        <div class="alan">
                            <label>Cihaz Tipi *</label>
                            <select name="CihazTipi" required>
                                <option value="">-- Se&#231;iniz --</option>
                                <option value="Kombi">Kombi</option>
                                <option value="&#350;ofben">&#350;ofben</option>
                                <option value="Ocak">Ocak</option>
                                <option value="Firin">Firin</option>
                                <option value="Kazan">Kazan</option>
                                <option value="Diger">Di&#287;er</option>
                            </select>
                        </div>
                        <div class="alan">
                            <label>Cihaz Modeli *</label>
                            <input type="text" name="CihazModeli" placeholder="Cihaz modeli" required />
                        </div>
