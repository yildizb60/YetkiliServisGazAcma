@model List<YetkiliServisGazAcma.Entities.Ys_Firma>
@{
    ViewData["Title"] = "Yetkili Servisler";
    ViewData["PanelTitle"] = ViewData["Title"];
    ViewData["PanelSubtitle"] = "Personel Paneli";
    ViewData["ActiveMenu"] = "YetkiliServisler";
    Layout = "~/Views/Shared/_PanelLayout.cshtml";
    var kullanici = ViewBag.Kullanici as YetkiliServisGazAcma.Entities.AppKullanici;
    var q = ViewBag.Query as string ?? "";
    var devreyeSayilari = ViewBag.DevreyeSayilari as Dictionary<int, int> ?? new Dictionary<int, int>();
    bool yYetkiBelgesi = ViewBag.YetkiBelgesi != false;
    bool yRapor = ViewBag.YetkiRapor != false;
    bool yServis = ViewBag.YetkiServis != false;
}

@section Styles {
    <style>
.content { padding: 28px 32px; }
        .filter { background: #fff; border: 1px solid #e6eef4; border-radius: 10px; padding: 16px 20px; margin-bottom: 16px; display: flex; gap: 10px; align-items: center; }
        .filter input { flex: 1; padding: 10px 12px; border: 1.5px solid #ddd; border-radius: 8px; font-size: 13px; background: #fafafa; }
        .filter button { padding: 9px 16px; border-radius: 8px; border: none; background: #1B9FD4; color: #fff; font-weight: bold; cursor: pointer; }
        .btn-ekle { display:inline-flex; align-items:center; gap:8px; background:#4CAF7D; color:#fff; font-weight:700; padding:8px 14px; border-radius:8px; text-decoration:none; margin-bottom:12px; }
        .section { background: #fff; border-radius: 12px; border: 1px solid #e6eef4; overflow: hidden; box-shadow: 0 10px 24px rgba(20,40,60,.06); }
        .alert { padding: 11px 14px; border-radius: 10px; margin-bottom: 12px; font-size: 13px; font-weight: 700; border: 1px solid transparent; }
        .alert-success { background: #E1F5EE; color: #085041; border-color: #c3e6db; }
        .alert-danger { background: #FCEBEB; color: #501313; border-color: #eccaca; }
        .tablo-head, .tablo-row { display: grid; grid-template-columns: 1.4fr 1fr 1fr .65fr .75fr 1.45fr; align-items: center; gap: 12px; }
        .tablo-head { padding: 10px 20px; background: #f8fbff; font-size: 11px; color: #718093; font-weight: bold; }
        .tablo-row { padding: 12px 20px; border-top: 1px solid #f0f0ee; font-size: 13px; color: #333; }
        .empty { padding: 30px; text-align: center; color: #bbb; font-size: 13px; }
        .badge { display: inline-block; padding: 3px 10px; border-radius: 10px; font-size: 11px; font-weight: bold; }
        .b-green { background: #E1F5EE; color: #085041; }
        .b-red { background: #FCEBEB; color: #501313; }
        .b-blue { background: #E6F1FB; color: #0C447C; }
        .action-cell { display:flex; flex-wrap:wrap; gap:6px; align-items:center; }
        .action-cell form { display:inline; }
        .action-badge { display:inline-flex; align-items:center; gap:6px; padding:5px 12px; border-radius:10px; font-size:11px; font-weight:bold; border:1px solid #d7e5f2; background:#f7fbff; color:#1B9FD4; text-decoration:none; line-height:1.2; box-shadow:0 6px 12px rgba(15,40,80,0.08); cursor:pointer; }
        .action-badge:hover { background:#eef6ff; }
        .action-badge.danger { background:#fff4f4; border-color:#f1c6c6; color:#b02020; }
        .action-badge.locked { background:#f1f5f9; border-color:#dbe3ea; color:#8391a1; cursor:not-allowed; box-shadow:none; }
        @@media (max-width: 980px) {
            .sidebar { position: static; width: 100%; height: auto; }
            .main { margin-left: 0; }
            .tablo-head { display:none; }
            .tablo-row { grid-template-columns: 1fr; gap: 8px; }
        }
    </style>
}

@if (yServis)
{
    <a class="btn-ekle" href="/personel-panel/yetkiliservisler/ekle">+ Yetkili Servis Ekle</a>
}
@if (TempData["Basarili"] != null) { <div class="alert alert-success">@TempData["Basarili"]</div> }
@if (TempData["Hata"] != null) { <div class="alert alert-danger">@TempData["Hata"]</div> }
<form class="filter" method="get" action="/personel-panel/yetkiliservisler">
    <input type="text" name="q" placeholder="Firma, vergi no veya şirket ara..." value="@q" />
    <button type="submit">Filtrele</button>
</form>
<div class="section">
    <div class="tablo-head">
        <div>Firma</div><div>Şirket</div><div>Vergi No</div><div>Devreye</div><div>Durum</div><div>İşlem</div>
    </div>
    @if (Model == null || Model.Count == 0)
    {
        <div class="empty">Kayıt bulunamadı.</div>
    }
    else
    {
        foreach (var f in Model)
        {
            var devreyeSayisi = devreyeSayilari.TryGetValue(f.Id, out var sayi) ? sayi : 0;
            <div class="tablo-row">
                <div>@f.FirmaAdi</div>
                <div>@f.Sirket?.SirketAdi</div>
                <div>@(f.VergiNo ?? "-")</div>
                <div><span class="badge b-blue">@devreyeSayisi</span></div>
                <div><span class="badge @(f.AktifMi ? "b-green" : "b-red")">@(f.AktifMi ? "Aktif" : "Pasif")</span></div>
                <div class="action-cell">
                    <a class="action-badge" href="/personel-panel/yetkiliservisler/detay/@f.Id">Detay</a>
                    @if (yServis)
                    {
                        <a class="action-badge" href="/personel-panel/yetkiliservisler/duzenle/@f.Id">Düzenle</a>
                        if (devreyeSayisi > 0)
                        {
                            <button type="button" class="action-badge locked" title="Bu servisin devreye alma işlemi olduğu için silinemez.">Silinemez</button>
                        }
                        else
                        {
                            <form method="post" action="/personel-panel/yetkiliservisler/sil/@f.Id" onsubmit="return confirm('Bu yetkili servisi silmek istiyor musunuz?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="action-badge danger">Sil</button>
                            </form>
                        }
                    }
                </div>
            </div>
        }
    }
</div>

@section Scripts {
<script>
(function () {
    var btns = document.querySelectorAll('.notif');
    btns.forEach(function(btn){
        var panel = btn.parentElement.querySelector('.notif-panel');
        if (!panel) return;
        btn.addEventListener('click', function(e){
            e.stopPropagation();
            panel.style.display = (panel.style.display === "block" ? "none" : "block");
        });
        panel.addEventListener('click', function(e){ e.stopPropagation(); });
    });
    document.addEventListener('click', function(){
        document.querySelectorAll('.notif-panel').forEach(function(p){ p.style.display = "none"; });
    });
})();
</script>
<script>
(function () {
    var yetki = {
        yetkiBelgesi: @((ViewBag.YetkiBelgesi == true).ToString().ToLower()),
        rapor: @((ViewBag.YetkiRapor == true).ToString().ToLower())
    };

    function hide(selector, allowed) {
        if (allowed) return;
        var list = document.querySelectorAll(selector);
        list.forEach(function (el) { el.style.display = 'none'; });
    }

    hide('a[href="/personel-panel/onay-bekleyenler"]', yetki.yetkiBelgesi);
    hide('a[href="/personel-panel/onay-gecmisi"]', yetki.yetkiBelgesi);
    hide('a[href="/personel-panel/raporlar"]', yetki.rapor);

    var raporSection = Array.from(document.querySelectorAll('.nav-section')).find(function (x) {
        return (x.textContent || '').toLowerCase().indexOf('rapor') >= 0;
    });
    if (!yetki.rapor && raporSection) raporSection.style.display = 'none';
})();
</script>
}
