@model List<YetkiliServisGazAcma.Entities.Dag_Sirket>
@{    ViewData["Title"] = "Sirketler";    ViewData["PanelTitle"] = ViewData["Title"];
    ViewData["PanelSubtitle"] = "Personel Paneli";
    ViewData["ActiveMenu"] = "Sirketler";
    Layout = "~/Views/Shared/_PanelLayout.cshtml";    var kullanici = ViewBag.Kullanici as YetkiliServisGazAcma.Entities.AppKullanici;    var q = ViewBag.Query as string ?? "";    bool ySertifika = ViewBag.YetkiSertifika != false;    bool yRapor = ViewBag.YetkiRapor != false;    bool ySirket = ViewBag.YetkiSirket != false;    bool yMarka = ViewBag.YetkiMarka != false;    bool ySirketYonet = ViewBag.YetkiSirketYonet != false;    bool yMarkaYonet = ViewBag.YetkiMarkaYonet != false;    bool yServis = ViewBag.YetkiServis != false;}

@section Styles {
    <style>
.content { padding: 28px 32px; }        .filter { background: #fff; border: 1px solid #eee; border-radius: 10px; padding: 16px 20px; margin-bottom: 16px; display: flex; gap: 10px; align-items: center; }        .btn-ekle { display:inline-flex; align-items:center; gap:8px; background:#4CAF7D; color:#fff; font-weight:700; padding:8px 14px; border-radius:8px; text-decoration:none; margin-bottom:12px; }        .filter input { flex: 1; padding: 10px 12px; border: 1.5px solid #ddd; border-radius: 8px; font-size: 13px; background: #fafafa; }        .filter button { padding: 9px 16px; border-radius: 8px; border: none; background: #1B9FD4; color: #fff; font-weight: bold; cursor: pointer; }        .section { background: #fff; border-radius: 12px; border: 1px solid #eee; overflow: hidden; }        .tablo-head { padding: 10px 20px; background: #f8f8f6; font-size: 11px; color: #888; font-weight: bold; display: grid; grid-template-columns: 1.6fr 1fr 1fr 0.8fr 0.9fr; }        .tablo-row { padding: 12px 20px; border-top: 1px solid #f0f0ee; font-size: 13px; color: #333; display: grid; grid-template-columns: 1.6fr 1fr 1fr 0.8fr 0.9fr; }        .empty { padding: 30px; text-align: center; color: #bbb; font-size: 13px; }            .notif-wrap { position: relative; }
        .notif { position: relative; width: 32px; height: 32px; border-radius: 50%; background: #f0f4f8; border: none; display: flex; align-items: center; justify-content: center; font-size: 16px; color: #4CAF7D; cursor: pointer; }
        .notif-badge { position: absolute; top: -4px; right: -4px; background: #e24b4a; color: #fff; font-size: 9px; font-weight: bold; padding: 2px 5px; border-radius: 10px; }
        .notif-panel { position: absolute; right: 0; top: 38px; width: 280px; background: #fff; border: 1px solid #e7e7e7; border-radius: 10px; box-shadow: 0 10px 24px rgba(0,0,0,0.08); padding: 10px; display: none; z-index: 50; }
        .notif-panel.open { display: block; }
        .notif-title { font-size: 12px; font-weight: bold; color: #555; padding: 6px 8px 8px; border-bottom: 1px solid #f0f0f0; margin-bottom: 6px; }
        .notif-item { display: flex; gap: 10px; padding: 8px; border-radius: 8px; transition: background .12s; }
        .notif-item:hover { background: #f7fafc; }
        .notif-dot { width: 8px; height: 8px; border-radius: 50%; margin-top: 6px; background: #4CAF7D; flex-shrink: 0; }
        .notif-text { font-size: 13px; color: #333; line-height: 1.35; }
        .notif-meta { font-size: 11px; color: #888; margin-top: 2px; }
        .notif-empty { padding: 10px 8px; font-size: 12px; color: #999; }            .notif-panel { display: none; position: absolute; right: 0; top: 38px; width: 280px; background: #fff; border: 1px solid #e7e7e7; border-radius: 10px; box-shadow: 0 10px 24px rgba(0,0,0,0.08); padding: 10px; z-index: 50; }
        .notif-panel.open { display: block; }            
        .notif-panel.open { display: block !important; }
    </style>
}

@if (ySirketYonet) { <a class="btn-ekle" href="/personel-panel/sirketler/ekle">+ Yeni &#350;irket</a> } <form class="filter" method="get" action="/personel-panel/sirketler">                <input type="text" name="q" placeholder="&#350;irket ad&#305; veya il ara..." value="@q" />                <button type="submit">Filtrele</button>            </form>            <div class="section">                <div class="tablo-head">                    <div>&#350;irket Ad&#305;</div><div>&#304;l</div><div>Telefon</div><div>Durum</div><div>&#304;&#351;lem</div>                </div>                @if (Model == null || Model.Count == 0)                {                    <div class="empty">Kay&#305;t bulunamad&#305;.</div>                }                else                {                    foreach (var s in Model)                    {                        <div class="tablo-row">                            <div>@s.SirketAdi</div>                            <div>@s.Il</div>                            <div>@s.Telefon</div>                            <div>@(s.AktifMi ? "Aktif" : "Pasif")</div>                            <div class="action-cell">@if (ySirketYonet) { <a class="action-badge" style="display:inline-flex;align-items:center;gap:6px;padding:4px 12px;border-radius:10px;font-size:11px;font-weight:bold;border:1px solid #d7e5f2;background:#f7fbff;color:#1B9FD4;text-decoration:none;line-height:1.2;box-shadow:0 6px 12px rgba(15,40,80,0.08);" href="/personel-panel/sirketler/duzenle/@s.Id">D&#252;zenle</a> <form method="post" action="/personel-panel/sirketler/sil/@s.Id" style="display:inline;">@Html.AntiForgeryToken()<button type="submit" class="action-badge danger" style="display:inline-flex;align-items:center;gap:6px;padding:4px 12px;border-radius:10px;font-size:11px;font-weight:bold;border:1px solid #f1c6c6;background:#fff4f4;color:#b02020;text-decoration:none;line-height:1.2;box-shadow:0 6px 12px rgba(15,40,80,0.08);">Sil</button></form> } else { <span>-</span> }</div>                        </div>                    }                }            </div>

@section Scripts {
<script>
    (function () {
        var btns = document.querySelectorAll('.notif');
        btns.forEach(function(btn){
            var panel = btn.parentElement.querySelector('.notif-panel');
            if (!panel) return;
            btn.addEventListener('click', function(e){
                e.stopPropagation();
                panel.style.display = (panel.style.display === "block" ? "none" : "block");
            });
            panel.addEventListener('click', function(e){ e.stopPropagation(); });
        });
        document.addEventListener('click', function(){
            document.querySelectorAll('.notif-panel').forEach(function(p){ p.style.display = "none"; });
        });
    })();
</script>
<script>
(function () {
    // PERSONEL_YETKI_MENU
    var yetki = {
        sertifika: @((ViewBag.YetkiSertifika == true).ToString().ToLower()),
        rapor: @((ViewBag.YetkiRapor == true).ToString().ToLower())
    };

    function hide(selector, allowed) {
        if (allowed) return;
        var list = document.querySelectorAll(selector);
        list.forEach(function (el) { el.style.display = 'none'; });
    }

    hide('a[href="/personel-panel/onay-bekleyenler"]', yetki.sertifika);
    hide('a[href="/personel-panel/onay-gecmisi"]', yetki.sertifika);
    hide('a[href="/personel-panel/raporlar"]', yetki.rapor);

    var raporSection = Array.from(document.querySelectorAll('.nav-section')).find(function (x) {
        return (x.textContent || '').toLowerCase().indexOf('rapor') >= 0;
    });
    if (!yetki.rapor && raporSection) raporSection.style.display = 'none';
})();
</script>
}
