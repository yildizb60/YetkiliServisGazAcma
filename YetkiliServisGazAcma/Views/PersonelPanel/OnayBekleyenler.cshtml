@model List<YetkiliServisGazAcma.Entities.Ys_Sertifika>
@using YetkiliServisGazAcma.Entities
@{
    ViewData["Title"] = "Yetki Belgesi Onayları";
    ViewData["PanelTitle"] = "Yetki Belgesi Onayları";
    ViewData["PanelSubtitle"] = "Personel Paneli";
    ViewData["ActiveMenu"] = "OnayBekleyenler";
    Layout = "~/Views/Shared/_PanelLayout.cshtml";

    var bekleyenler = Model ?? new List<Ys_Sertifika>();
    var onaylananlar = ViewBag.Onaylananlar as List<Ys_Sertifika> ?? new List<Ys_Sertifika>();
    var reddedilenler = ViewBag.Reddedilenler as List<Ys_Sertifika> ?? new List<Ys_Sertifika>();
}

@if (TempData["Basarili"] != null)
{
    <div class="df-alert df-alert-success">@TempData["Basarili"]</div>
}
@if (TempData["Hata"] != null)
{
    <div class="df-alert df-alert-danger">@TempData["Hata"]</div>
}

<div class="approval-reference-panel approval-panels">
    <div class="approval-reference-toolbar">
        <div class="approval-reference-tabs" data-approval-tabs>
            <button type="button" class="approval-reference-tab active" data-target="bekleyen">Onaya G&ouml;nderildi (@bekleyenler.Count)</button>
            <button type="button" class="approval-reference-tab" data-target="onaylanan">Onaylananlar (@onaylananlar.Count)</button>
            <button type="button" class="approval-reference-tab" data-target="reddedilen">Reddedilenler (@reddedilenler.Count)</button>
        </div>
        <div class="approval-reference-tools">
            <button type="button" class="approval-filter-btn">
                <i class="bi bi-funnel"></i>
                <span>Filtreler</span>
                <span class="approval-filter-count">0</span>
            </button>
            <div class="approval-search">
                <input type="text" id="approvalSearchInput" placeholder="Aray&#305;n&#305;z..." autocomplete="off" />
                <i class="bi bi-search"></i>
            </div>
        </div>
    </div>

    <div class="approval-table-shell">
        <div data-panel="bekleyen" class="active">
            @await Html.PartialAsync("~/Views/Shared/_SertifikaOnayTable.cshtml", new Tuple<List<Ys_Sertifika>, string, string>(bekleyenler, "bekleyen", "personel"))
        </div>
        <div data-panel="onaylanan">
            @await Html.PartialAsync("~/Views/Shared/_SertifikaOnayTable.cshtml", new Tuple<List<Ys_Sertifika>, string, string>(onaylananlar, "onaylanan", "personel"))
        </div>
        <div data-panel="reddedilen">
            @await Html.PartialAsync("~/Views/Shared/_SertifikaOnayTable.cshtml", new Tuple<List<Ys_Sertifika>, string, string>(reddedilenler, "reddedilen", "personel"))
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var tabs = document.querySelector('[data-approval-tabs]');
    if (!tabs) return;
    var searchInput = document.getElementById('approvalSearchInput');

    function applySearch() {
        var term = (searchInput && searchInput.value ? searchInput.value : '').toLocaleLowerCase('tr-TR').trim();
        var activePanel = document.querySelector('.approval-panels [data-panel].active');
        if (!activePanel) return;

        activePanel.querySelectorAll('tbody tr').forEach(function (row) {
            var emptyRow = row.querySelector('.df-empty');
            if (emptyRow) {
                row.style.display = '';
                return;
            }

            var text = row.innerText.toLocaleLowerCase('tr-TR');
            row.style.display = !term || text.indexOf(term) > -1 ? '' : 'none';
        });
    }

    tabs.addEventListener('click', function (event) {
        var btn = event.target.closest('[data-target]');
        if (!btn) return;
        var target = btn.getAttribute('data-target');

        tabs.querySelectorAll('[data-target]').forEach(function (item) {
            item.classList.toggle('active', item === btn);
        });

        document.querySelectorAll('.approval-panels [data-panel]').forEach(function (panel) {
            panel.classList.toggle('active', panel.getAttribute('data-panel') === target);
        });

        applySearch();
    });

    if (searchInput) {
        searchInput.addEventListener('input', applySearch);
    }
})();
</script>
}
