@model List<YetkiliServisGazAcma.Entities.Ys_DevreyeAlma>
@{
    ViewData["Title"] = "Devreye Almalar";
    ViewData["PanelTitle"] = ViewData["Title"];
    ViewData["PanelSubtitle"] = "Personel Paneli";
    ViewData["ActiveMenu"] = "DevreyeAlmalar";
    Layout = "~/Views/Shared/_PanelLayout.cshtml";

    var markalar = ViewBag.Markalar as List<YetkiliServisGazAcma.Entities.Ys_Marka> ?? new();
    var firmaIlceleri = ViewBag.FirmaIlceleri as Dictionary<int, string> ?? new();

    var secilenTesisat = Context.Request.Query["tesisat"].ToString();
    var secilenMarka = Context.Request.Query["marka"].ToString();
    var secilenServis = Context.Request.Query["servis"].ToString();
    var secilenIl = Context.Request.Query["il"].ToString();
    var secilenIlce = Context.Request.Query["ilce"].ToString();
    var secilenDurum = Context.Request.Query["durum"].ToString();
    var secilenBas = Context.Request.Query["bas"].ToString();
    var secilenBit = Context.Request.Query["bit"].ToString();
}

@section Styles {
    <style>
        .content { padding: 28px 32px; }
        .istat-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 22px; }
        .istat-kart { background: #fff; border-radius: 12px; border: 1px solid #eee; padding: 18px 20px; display: flex; align-items: center; gap: 14px; }
        .istat-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 18px; font-weight: 800; }
        .istat-icon.yesil { background: #E1F5EE; color: #085041; }
        .istat-icon.mavi { background: #E6F1FB; color: #1565C0; }
        .istat-icon.sari { background: #FAEEDA; color: #633806; }
        .istat-icon.mor { background: #F0EBFF; color: #4b3a92; }
        .istat-sayi { font-size: 24px; font-weight: 800; color: #1a1a1a; }
        .istat-label { font-size: 12px; color: #777; margin-top: 2px; }

        .filtre-kart { background: #fff; border-radius: 12px; border: 1px solid #eee; padding: 20px 24px; margin-bottom: 18px; }
        .filtre-baslik { font-size: 14px; font-weight: 800; color: #333; margin-bottom: 16px; border-bottom: 1px solid #f0f0ee; padding-bottom: 12px; }
        .filtre-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 14px; align-items: end; }
        .filtre-alan { display: flex; flex-direction: column; gap: 6px; }
        .filtre-alan label { font-size: 11px; color: #555; font-weight: 800; text-transform: uppercase; letter-spacing: .04em; }
        .filtre-alan input, .filtre-alan select { padding: 10px 12px; border: 1.5px solid #ddd; border-radius: 8px; font-size: 13px; outline: none; color: #333; background: #fafafa; }
        .filtre-alan input:focus, .filtre-alan select:focus { border-color: #4CAF7D; background: #fff; }
        .filtre-butonlar { display: flex; gap: 10px; margin-top: 16px; }
        .btn-filtre { padding: 10px 22px; background: #1B9FD4; color: #fff; border: none; border-radius: 8px; font-size: 13px; cursor: pointer; font-weight: 800; }
        .btn-temizle { padding: 10px 16px; background: #fff; color: #777; border: 1.5px solid #ddd; border-radius: 8px; font-size: 13px; text-decoration: none; }

        .section { background: #fff; border-radius: 12px; border: 1px solid #eee; overflow: hidden; }
        .section-head { padding: 16px 24px; border-bottom: 2px solid #f0f0ee; display: flex; justify-content: space-between; align-items: center; background: linear-gradient(to right, #f4faf7, #fff); }
        .section-title { font-size: 15px; font-weight: 800; color: #333; }
        .section-sayi { font-size: 12px; color: #4CAF7D; background: #E1F5EE; padding: 5px 12px; border-radius: 10px; font-weight: 800; }
        .bulk-actions { padding: 12px 24px; display: flex; gap: 10px; align-items: center; border-bottom: 1px solid #f0f0ee; flex-wrap: wrap; }
        .pdf-btn { padding: 6px 10px; background: #E6F1FB; border: 1px solid #BBDEFB; border-radius: 6px; font-size: 11px; color: #1565C0; text-decoration: none; font-weight: 800; cursor: pointer; }

        .tablo-head, .tablo-row { display: grid; grid-template-columns: .3fr .9fr 1.4fr .8fr .8fr .9fr .8fr .8fr .7fr; align-items: center; }
        .tablo-head { padding: 11px 24px; background: #f4faf7; font-size: 11px; color: #4CAF7D; font-weight: 800; border-bottom: 2px solid #e0f0e8; text-transform: uppercase; letter-spacing: .04em; }
        .tablo-row { padding: 14px 24px; border-top: 1px solid #f0f0ee; font-size: 13px; color: #333; }
        .tablo-row:hover { background: #f8fffe; }
        .tesisat-no { font-weight: 800; color: #1B9FD4; font-family: monospace; }
        .cell-overflow { max-width: 170px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .badge { display: inline-block; padding: 4px 11px; border-radius: 10px; font-size: 11px; font-weight: 800; }
        .b-green { background: #E1F5EE; color: #085041; }
        .b-yellow { background: #FAEEDA; color: #633806; }
        .b-red { background: #FCEBEB; color: #501313; }
        .detay-btn { padding: 5px 11px; background: #f0f4f8; border: 1px solid #ddd; border-radius: 6px; font-size: 11px; color: #555; text-decoration: none; font-weight: 800; }
        .empty { padding: 60px; text-align: center; color: #999; font-size: 15px; }

        @@media (max-width: 1100px) {
            .istat-row, .filtre-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
            .tablo-head, .tablo-row { grid-template-columns: .3fr .9fr 1.4fr .8fr .8fr .9fr .8fr; }
            .tablo-head div:nth-child(8), .tablo-row div:nth-child(8),
            .tablo-head div:nth-child(9), .tablo-row div:nth-child(9) { display: none; }
        }
    </style>
}

<div class="istat-row">
    <div class="istat-kart"><div class="istat-icon mavi">T</div><div><div class="istat-sayi">@Model.Count</div><div class="istat-label">Toplam işlem</div></div></div>
    <div class="istat-kart"><div class="istat-icon yesil">OK</div><div><div class="istat-sayi">@Model.Count(x => x.Durum == 1)</div><div class="istat-label">Tamamlanan</div></div></div>
    <div class="istat-kart"><div class="istat-icon sari">B</div><div><div class="istat-sayi">@Model.Count(x => x.Durum == 0)</div><div class="istat-label">Bekleyen</div></div></div>
    <div class="istat-kart"><div class="istat-icon mor">YS</div><div><div class="istat-sayi">@Model.Select(x => x.FirmaId).Distinct().Count()</div><div class="istat-label">Farklı servis</div></div></div>
</div>

<div class="filtre-kart">
    <div class="filtre-baslik">Filtrele</div>
    <form method="get" action="/personel-panel/devreyealmalar">
        <div class="filtre-grid">
            <div class="filtre-alan">
                <label>Tesisat No</label>
                <input type="text" name="tesisat" placeholder="Tesisat no..." value="@secilenTesisat" />
            </div>
            <div class="filtre-alan">
                <label>Yetkili Servis</label>
                <input type="text" name="servis" placeholder="Servis adı..." value="@secilenServis" />
            </div>
            <div class="filtre-alan">
                <label>İl</label>
                <input type="text" name="il" placeholder="İl..." value="@secilenIl" />
            </div>
            <div class="filtre-alan">
                <label>İlçe</label>
                <input type="text" name="ilce" placeholder="İlçe..." value="@secilenIlce" />
            </div>
            <div class="filtre-alan">
                <label>Marka</label>
                <select name="marka">
                    <option value="">Tüm</option>
                    @foreach (var m in markalar)
                    {
                        <option value="@m.MarkaAdi" selected="@(secilenMarka == m.MarkaAdi ? "selected" : null)">@m.MarkaAdi</option>
                    }
                </select>
            </div>
            <div class="filtre-alan">
                <label>Durum</label>
                <select name="durum">
                    <option value="">Tüm</option>
                    <option value="1" selected="@(secilenDurum == "1" ? "selected" : null)">Tamamlandı</option>
                    <option value="0" selected="@(secilenDurum == "0" ? "selected" : null)">Bekliyor</option>
                    <option value="2" selected="@(secilenDurum == "2" ? "selected" : null)">İptal</option>
                </select>
            </div>
            <div class="filtre-alan">
                <label>Başlangıç</label>
                <input type="date" name="bas" value="@secilenBas" />
            </div>
            <div class="filtre-alan">
                <label>Bitiş</label>
                <input type="date" name="bit" value="@secilenBit" />
            </div>
        </div>
        <div class="filtre-butonlar">
            <button type="submit" class="btn-filtre">Filtrele</button>
            <a class="btn-temizle" href="/personel-panel/devreyealmalar">Temizle</a>
        </div>
    </form>
</div>

<div class="section">
    <div class="section-head">
        <div class="section-title">İç Tesisat İşlem Listesi</div>
        <div class="section-sayi">@Model.Count kayıt</div>
    </div>
    <div class="bulk-actions">
        <button type="button" class="pdf-btn" onclick="indirSeciliPdf()">Seçili PDF</button>
        <button type="button" class="pdf-btn" onclick="indirTumPdf()">Tüm PDF</button>
        <button type="button" class="pdf-btn" onclick="indirSeciliExcel()">Seçili Excel</button>
        <button type="button" class="pdf-btn" onclick="indirTumExcel()">Tüm Excel</button>
    </div>
    <div class="tablo-head">
        <div></div>
        <div>Tesisat</div>
        <div>Yetkili Servis</div>
        <div>İl</div>
        <div>İlçe</div>
        <div>Marka</div>
        <div>Tarih</div>
        <div>Durum</div>
        <div></div>
    </div>
    @if (!Model.Any())
    {
        <div class="empty">Kayıt bulunamadı.</div>
    }
    else
    {
        foreach (var d in Model)
        {
            var ilce = firmaIlceleri.TryGetValue(d.FirmaId, out var firmaIlce) ? firmaIlce : "";
            <div class="tablo-row">
                <div><input class="row-check" type="checkbox" value="@d.Id" /></div>
                <div class="tesisat-no">@d.TesistatNo</div>
                <div class="cell-overflow" title="@d.Firma?.FirmaAdi">@d.Firma?.FirmaAdi</div>
                <div>@(d.Firma?.FaaliyetIli ?? "-")</div>
                <div>@(string.IsNullOrWhiteSpace(ilce) ? "-" : ilce)</div>
                <div>@(d.CihazMarka ?? d.Marka?.MarkaAdi ?? "-")</div>
                <div>@d.DevreyeAlmaTarihi.ToString("dd.MM.yyyy")</div>
                <div>
                    <span class="badge @(d.Durum == 1 ? "b-green" : d.Durum == 2 ? "b-red" : "b-yellow")">
                        @(d.Durum == 1 ? "Tamam" : d.Durum == 2 ? "İptal" : "Bekliyor")
                    </span>
                </div>
                <div><a class="detay-btn" href="/personel-panel/devreyealmalar/detay/@d.Id">Detay</a></div>
            </div>
        }
    }
</div>

@section Scripts {
    <script>
        function seciliIdler() {
            return Array.from(document.querySelectorAll(".row-check:checked")).map(x => x.value);
        }
        function indirSeciliPdf() {
            const ids = seciliIdler();
            if (ids.length === 0) { alert("Lütfen en az bir işlem seçin."); return; }
            ids.forEach(id => window.open("/personel-panel/devreyealma-pdf/" + id, "_blank"));
        }
        function indirTumPdf() {
            const ids = Array.from(document.querySelectorAll(".row-check")).map(x => x.value);
            if (ids.length === 0) { alert("Kayıt bulunamadı."); return; }
            ids.forEach(id => window.open("/personel-panel/devreyealma-pdf/" + id, "_blank"));
        }
        function indirSeciliExcel() {
            const ids = seciliIdler();
            if (ids.length === 0) { alert("Lütfen en az bir işlem seçin."); return; }
            ids.forEach(id => window.open("/personel-panel/devreyealma-excel/" + id, "_blank"));
        }
        function indirTumExcel() {
            const ids = Array.from(document.querySelectorAll(".row-check")).map(x => x.value);
            if (ids.length === 0) { alert("Kayıt bulunamadı."); return; }
            ids.forEach(id => window.open("/personel-panel/devreyealma-excel/" + id, "_blank"));
        }
    </script>
}
