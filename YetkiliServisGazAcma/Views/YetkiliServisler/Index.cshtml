@model List<YetkiliServisGazAcma.Entities.Ys_Firma>
@{
    ViewData["Title"] = "Yetkili Servisler";
    Layout = "_PublicLayout";
    var markalar = ViewBag.Markalar as List<YetkiliServisGazAcma.Entities.Ys_Marka> ?? new();
    var iller = ViewBag.Iller as List<string> ?? new();
    var seciliIl = ViewBag.SeciliIl as string ?? "";
    var ilceler = ViewBag.Ilceler as List<string> ?? new();
    var seciliIlce = ViewBag.SeciliIlce as string ?? "";
    int? seciliMarkaId = ViewBag.SeciliMarkaId as int?;
    int? seciliKategoriId = ViewBag.SeciliKategoriId as int?;
    var q = ViewBag.Q as string ?? "";
    var kategoriler = ViewBag.Kategoriler as List<YetkiliServisGazAcma.Entities.UrunKategori> ?? new();
    var tr = new System.Globalization.CultureInfo("tr-TR");

    string NormalizeKey(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return "";
        var lower = value.Trim().ToLower(tr).Normalize(System.Text.NormalizationForm.FormD);
        var chars = lower
            .Where(ch => System.Globalization.CharUnicodeInfo.GetUnicodeCategory(ch) != System.Globalization.UnicodeCategory.NonSpacingMark && char.IsLetterOrDigit(ch))
            .ToArray();
        return new string(chars)
            .Replace("ı", "i")
            .Replace("ş", "s")
            .Replace("ğ", "g")
            .Replace("ü", "u")
            .Replace("ö", "o")
            .Replace("ç", "c");
    }

    bool KullanilanKategoriMi(string? value)
    {
        var key = NormalizeKey(value);

        return key == "kombi"
            || key.Contains("merkezikazan")
            || key.Contains("sofben")
            || key.Contains("sohben");
    }

    string TelLink(string? tel)
    {
        if (string.IsNullOrWhiteSpace(tel)) return "";
        return new string(tel.Where(ch => char.IsDigit(ch) || ch == '+').ToArray());
    }
}
@section Styles {
    <style>
        :root {
            --c-primary: #3bb7e8;
            --c-primary-dark: #2a8fb2;
            --c-accent: #4caf7d;
            --c-ink: #0e1a24;
            --c-muted: #5a6b78;
            --c-bg: #f4f7fa;
            --c-card: #ffffff;
            --c-border: #e4edf4;
            --c-shadow: 0 16px 44px rgba(10, 27, 43, 0.11);
        }
        * { box-sizing: border-box; }
        body { margin: 0; font-family: "Manrope", Arial, sans-serif; color: var(--c-ink); background: #fff; }
        a { color: inherit; text-decoration: none; }
        .container { max-width: 1320px; margin: 0 auto; padding: 0 22px; }

        .site-header {
            position: relative; top: 0; z-index: 30;
            background: #fff; box-shadow: 0 12px 28px rgba(0,0,0,0.12);
