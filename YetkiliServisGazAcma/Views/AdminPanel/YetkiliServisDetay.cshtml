@{
    ViewData["Title"] = "Yetkili Servis Detay";
    ViewData["PanelTitle"] = ViewData["Title"];
    ViewData["PanelSubtitle"] = "Admin Paneli";
    ViewData["ActiveMenu"] = "YetkiliServisler";
    Layout = "~/Views/Shared/_PanelLayout.cshtml";
    var Kullanici = ViewBag.Kullanici as YetkiliServisGazAcma.Entities.AppKullanici;
    var servis = ViewBag.Servis as YetkiliServisGazAcma.Entities.Ys_Firma;
    var sertifikalar = ViewBag.Sertifikalar as List<YetkiliServisGazAcma.Entities.Ys_Sertifika> ?? new();
    var subeler = ViewBag.Subeler as List<YetkiliServisGazAcma.Entities.Ys_Sube> ?? new();
    var devreye = ViewBag.Devreye as List<YetkiliServisGazAcma.Entities.Ys_DevreyeAlma> ?? new();
    var kategoriler = servis?.FirmaKategoriler?.Where(x => !x.SilindiMi
            && x.Kategori != null
            && !x.Kategori.SilindiMi
            && x.Kategori.AktifMi
            && KullanilanKategoriMi(x.Kategori.Ad))
        .Select(x => x.Kategori!)
        .GroupBy(x => NormalizeKategori(x.Ad))
        .Select(g => g.First())
        .ToList() ?? new List<YetkiliServisGazAcma.Entities.UrunKategori>();
    string adSoyad = Kullanici?.AdSoyad ?? "S&#252;per Admin";
    string basHarf = !string.IsNullOrEmpty(adSoyad) ? adSoyad.Substring(0, 1).ToUpper() : "A";
    int onayBekleyen = ViewBag.OnayBekleyen is int v ? v : 0;
}

@functions {
    private static bool KullanilanKategoriMi(string? ad)
    {
        var key = NormalizeKategori(ad);

        return key == "kombi"
            || key.Contains("merkezikazan")
            || key.Contains("sofben")
            || key.Contains("sohben");
    }

    private static string NormalizeKategori(string? ad)
    {
        if (string.IsNullOrWhiteSpace(ad))
            return string.Empty;

        var normalized = ad.Trim().ToLower(new System.Globalization.CultureInfo("tr-TR")).Normalize(System.Text.NormalizationForm.FormD);
        var chars = normalized
            .Where(ch => System.Globalization.CharUnicodeInfo.GetUnicodeCategory(ch) != System.Globalization.UnicodeCategory.NonSpacingMark && char.IsLetterOrDigit(ch))
            .ToArray();

        return new string(chars)
            .Replace("ı", "i")
            .Replace("ş", "s")
            .Replace("ğ", "g")
            .Replace("ü", "u")
            .Replace("ö", "o")
            .Replace("ç", "c");
    }
}

@section Styles {
    <style>
.content { padding: 28px 32px; display: grid; gap: 16px; }
.back-link { display: inline-flex; align-items: center; gap: 8px; color: #1B9FD4; font-weight: 700; text-decoration: none; margin-bottom: 6px; }
.page-title { font-size: 22px; font-weight: 800; margin: 2px 0 8px; }
.section { background: #fff; border-radius: 12px; border: 1px solid #e6eef4; box-shadow: 0 10px 24px rgba(20,40,60,0.08); padding: 16px; }
.section-title { font-size: 14px; font-weight: 800; color: #1B9FD4; margin-bottom: 10px; display:flex; align-items:center; gap:8px; }
.info-grid { display:grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.info-item { background: #f7fafc; border: 1px solid #edf3f8; border-radius: 10px; padding: 10px 12px; }
.info-label { font-size: 11px; color: #6f7b86; margin-bottom: 4px; font-weight: 700; }
.info-value { font-size: 13px; color: #333; font-weight: 600; }
.table-head { padding: 10px 12px; background: #f8f8f6; font-size: 11px; color: #888; font-weight: bold; display: grid; grid-template-columns: 1.4fr 1fr 1fr 0.8fr; }
.table-row { padding: 10px 12px; border-top: 1px solid #f0f0ee; font-size: 13px; color: #333; display: grid; grid-template-columns: 1.4fr 1fr 1fr 0.8fr; align-items: center; }
.table-row.small { grid-template-columns: 1fr 1fr 1fr; }
.table-head.small { grid-template-columns: 1fr 1fr 1fr; }
.badge { display: inline-block; padding: 3px 10px; border-radius: 10px; font-size: 11px; font-weight: bold; }
.b-green { background: #E1F5EE; color: #085041; }
.b-red { background: #FCEBEB; color: #501313; }
.empty { padding: 18px; color: #999; font-size: 12px; }
.category-list { display:flex; flex-wrap:wrap; gap:10px; }
.category-chip { display:inline-flex; align-items:center; gap:10px; background:#f7fbff; border:1px solid #dbe8f2; border-radius:999px; padding:9px 13px; color:#17354c; font-size:13px; font-weight:800; }
.category-icon { width:28px; height:28px; border-radius:10px; background:#eaf6fb; display:grid; place-items:center; flex:0 0 auto; overflow:hidden; }
.category-icon img { width:20px; height:20px; object-fit:contain; }
.category-fallback { color:#1B9FD4; font-size:12px; font-weight:900; }

@@media (max-width: 980px) {
    .info-grid { grid-template-columns: 1fr; }
    .table-head, .table-row { grid-template-columns: 1fr; gap: 6px; }
    .table-head.small, .table-row.small { grid-template-columns: 1fr; gap: 6px; }
}
    </style>
}

<a class="back-link" href="/AdminPanel/yetkiliservisler">&#8592; Yetkili Servislere D&#246;n</a>
<div class="page-title">@servis?.FirmaAdi</div>

<div class="section">
    <div class="section-title">&#128295; Firma Bilgileri</div>
    <div class="info-grid">
        <div class="info-item"><div class="info-label">Firma</div><div class="info-value">@servis?.FirmaAdi</div></div>
        <div class="info-item"><div class="info-label">Firma Kodu</div><div class="info-value">@servis?.Sirket?.SirketAdi</div></div>
        <div class="info-item"><div class="info-label">Vergi No</div><div class="info-value">@servis?.VergiNo</div></div>
        <div class="info-item"><div class="info-label">Telefon</div><div class="info-value">@servis?.Telefon</div></div>
        <div class="info-item"><div class="info-label">Yetkili Ki&#351;i</div><div class="info-value">@servis?.YetkiliKisi</div></div>
        <div class="info-item"><div class="info-label">Faaliyet &#304;li</div><div class="info-value">@servis?.FaaliyetIli</div></div>
        <div class="info-item" style="grid-column: span 2;"><div class="info-label">Adres</div><div class="info-value">@servis?.Adres</div></div>
    </div>
</div>

<div class="section">
    <div class="section-title">&#128230; Hizmet Türleri</div>
    @if (kategoriler.Count == 0)
    {
        <div class="empty">Hizmet türü kaydı yok.</div>
    }
    else
    {
        <div class="category-list">
            @foreach (var kategori in kategoriler)
            {
                <div class="category-chip">
                    <span class="category-icon">
                        @if (!string.IsNullOrWhiteSpace(kategori.IconUrl))
                        {
                            <img src="@kategori.IconUrl" alt="@kategori.Ad" />
                        }
                        else
                        {
                            <span class="category-fallback">@((kategori.Ad ?? "?").Substring(0, 1).ToUpper())</span>
                        }
                    </span>
                    <span>@kategori.Ad</span>
                </div>
            }
        </div>
    }
</div>

<div class="section">
    <div class="section-title">&#128196; Yetki Belgeleri</div>
    <div class="table-head">
        <div>Tarih</div><div>Ba&#351;lang&#305;&#231;</div><div>Biti&#351;</div><div>Durum</div>
    </div>
    @if (sertifikalar.Count == 0)
    {
        <div class="empty">Yetki belgesi kayd&#305; yok.</div>
    }
    else
    {
        foreach (var s in sertifikalar)
        {
            <div class="table-row">
                <div>@s.OlusturmaTarihi.ToString("dd.MM.yyyy")</div>
                <div>@(s.SertifikaBaslangicTarihi?.ToString("dd.MM.yyyy") ?? "-")</div>
                <div>@s.SertifikaBitisTarihi.ToString("dd.MM.yyyy")</div>
                <div>
                    @if (s.Durum == 1) { <span class="badge b-green">Onayl&#305;</span> }
                    else if (s.Durum == 2) { <span class="badge b-red">Reddedildi</span> }
                    else { <span class="badge" style="background:#FAEEDA;color:#633806;">Bekliyor</span> }
                </div>
            </div>
        }
    }
</div>

<div class="section">
    <div class="section-title">&#127970; &#350;ubeler</div>
    <div class="table-head small">
        <div>&#350;ube</div><div>&#304;l / &#304;l&#231;e</div><div>Telefon</div>
    </div>
    @if (subeler.Count == 0)
    {
        <div class="empty">&#350;ube kayd&#305; yok.</div>
    }
    else
    {
        foreach (var s in subeler)
        {
            <div class="table-row small">
                <div>@s.SubeAdi</div>
                <div>@s.Il @s.Ilce</div>
                <div>@s.Telefon</div>
            </div>
        }
    }
</div>

<div class="section">
    <div class="section-title">&#128202; Son Devreye Almalar</div>
    <div class="table-head">
        <div>Tesisat No</div><div>Marka</div><div>Tarih</div><div>Durum</div>
    </div>
    @if (devreye.Count == 0)
    {
        <div class="empty">Devreye alma kayd&#305; yok.</div>
    }
    else
    {
        foreach (var d in devreye)
        {
            <div class="table-row">
                <div>@(d.TesistatNo ?? "-")</div>
                <div>@(d.Marka?.MarkaAdi ?? "-")</div>
                <div>@d.OlusturmaTarihi.ToString("dd.MM.yyyy")</div>
                <div>
                    @if (d.Durum == 1) { <span class="badge b-green">Tamamland&#305;</span> }
                    else { <span class="badge" style="background:#FAEEDA;color:#633806;">Bekliyor</span> }
                </div>
            </div>
        }
    }
</div>
