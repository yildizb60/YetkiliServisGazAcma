@{
    ViewData["Title"] = "Yetki Belgesi Bitiş Uyarıları";
    ViewData["PanelTitle"] = "Yetki Belgesi Bitiş Uyarıları";
    ViewData["PanelSubtitle"] = "Admin Paneli";
    ViewData["ActiveMenu"] = "YetkiBelgesiUyarilari";
    Layout = "~/Views/Shared/_PanelLayout.cshtml";

    var yaklasan = ViewBag.Yaklasan as List<YetkiliServisGazAcma.Entities.Ys_YetkiBelgesi> ?? new();
    var gecmis = ViewBag.Gecmis as List<YetkiliServisGazAcma.Entities.Ys_YetkiBelgesi> ?? new();
}

@section Styles {
    <style>
        .warning-stack {
            display: grid;
            gap: 16px;
        }

        .warning-summary {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
        }

        .warning-kpi {
            background: var(--df-surface);
            border: 1px solid var(--df-border);
            border-radius: var(--df-radius);
            box-shadow: var(--df-shadow-soft);
            padding: 16px;
        }

        .warning-kpi-label {
            color: var(--df-muted);
            font-size: 12px;
            font-weight: 700;
        }

        .warning-kpi-value {
            color: var(--df-text-soft);
            font-size: 28px;
            font-weight: 800;
            margin-top: 5px;
        }

        .warning-panel-accent {
            border-left: 4px solid var(--df-warning);
        }

        .danger-panel-accent {
            border-left: 4px solid var(--df-danger);
        }

        .warning-row-soon td {
            background: var(--df-warning-soft);
        }

        .warning-row-expired td {
            background: var(--df-danger-soft);
        }

        @@media (max-width: 860px) {
            .warning-summary {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<div class="warning-stack">
    <div class="warning-summary">
        <div class="warning-kpi">
            <div class="warning-kpi-label">30 g&#252;n i&#231;inde bitecek</div>
            <div class="warning-kpi-value">@yaklasan.Count</div>
        </div>
        <div class="warning-kpi">
            <div class="warning-kpi-label">S&#252;resi dolan</div>
            <div class="warning-kpi-value">@gecmis.Count</div>
        </div>
    </div>

    <section class="df-page-panel warning-panel-accent">
        <div class="df-panel-head">
            <div>
                <h2 class="df-panel-title">30 G&#252;n &#304;&#231;inde Bitenler</h2>
                <div class="df-panel-subtitle">Yak&#305;n tarihte bitecek yetki belgeleri</div>
            </div>
            <span class="badge b-yellow">Dikkat</span>
        </div>

        @if (yaklasan.Count == 0)
        {
            <div class="df-empty">
                <div class="df-empty-title">Yak&#305;n tarihte biten belge yok</div>
                <div class="df-empty-text">S&#252;resi yakla&#351;an yetki belgeleri burada listelenecek.</div>
            </div>
        }
        else
        {
            <div class="df-table-wrap">
                <table class="df-table">
                    <thead>
                        <tr>
                            <th>Firma</th>
                            <th>&#350;irket</th>
                            <th>Biti&#351;</th>
                            <th>Kalan</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in yaklasan)
                        {
                            var kalanGun = (s.YetkiBelgesiBitisTarihi.Date - DateTime.Now.Date).Days;
                            <tr class="@(kalanGun <= 7 ? "warning-row-soon" : "")">
                                <td>
                                    <div class="df-cell-main">@(s.Firma?.FirmaAdi ?? "-")</div>
                                </td>
                                <td>
                                    <div class="df-cell-sub">@(s.Firma?.Sirket?.SirketAdi ?? "-")</div>
                                </td>
                                <td>@s.YetkiBelgesiBitisTarihi.ToString("dd.MM.yyyy")</td>
                                <td><span class="badge b-yellow">@kalanGun g&#252;n</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="df-page-panel danger-panel-accent">
        <div class="df-panel-head">
            <div>
                <h2 class="df-panel-title">S&#252;resi Dolanlar</h2>
                <div class="df-panel-subtitle">Yetki belgesi ge&#231;erlili&#287;i bitmi&#351; kay&#305;tlar</div>
            </div>
            <span class="badge b-red">Kritik</span>
        </div>

        @if (gecmis.Count == 0)
        {
            <div class="df-empty">
                <div class="df-empty-title">S&#252;resi dolan belge yok</div>
                <div class="df-empty-text">Ge&#231;erlili&#287;i biten belgeler burada listelenecek.</div>
            </div>
        }
        else
        {
            <div class="df-table-wrap">
                <table class="df-table">
                    <thead>
                        <tr>
                            <th>Firma</th>
                            <th>&#350;irket</th>
                            <th>Biti&#351;</th>
                            <th>Durum</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in gecmis)
                        {
                            <tr class="warning-row-expired">
                                <td>
                                    <div class="df-cell-main">@(s.Firma?.FirmaAdi ?? "-")</div>
                                </td>
                                <td>
                                    <div class="df-cell-sub">@(s.Firma?.Sirket?.SirketAdi ?? "-")</div>
                                </td>
                                <td>@s.YetkiBelgesiBitisTarihi.ToString("dd.MM.yyyy")</td>
                                <td><span class="badge b-red">S&#252;resi Doldu</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>
