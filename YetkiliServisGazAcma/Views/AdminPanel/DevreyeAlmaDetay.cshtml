@model YetkiliServisGazAcma.Entities.Ys_DevreyeAlma
@{
    ViewData["Title"] = "Devreye Alma Detay";
    ViewData["PanelTitle"] = "Devreye Alma Detay";
    ViewData["PanelSubtitle"] = "Admin Paneli";
    ViewData["ActiveMenu"] = "DevreyeAlmalar";
    Layout = "~/Views/Shared/_PanelLayout.cshtml";

    var marka = Model.Marka?.MarkaAdi ?? Model.CihazMarka ?? "-";
    var durumClass = Model.Durum == 1 ? "df-pill-success" : Model.Durum == 2 ? "df-pill-danger" : "df-pill-warning";
    var durumYazi = Model.Durum == 1 ? "Tamamlandı" : Model.Durum == 2 ? "İptal" : "Bekliyor";
}

@functions {
    private static string Deger(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private static string Tarih(DateTime? value)
    {
        return value.HasValue ? value.Value.ToString("dd.MM.yyyy") : "-";
    }
}

<div class="cert-stack">
    <section class="df-page-panel">
        <div class="df-panel-head">
            <div>
                <h2 class="df-panel-title">Tesisat No: @Deger(Model.TesistatNo)</h2>
                <div class="df-panel-subtitle">@(Deger(Model.Firma?.Sirket?.SirketAdi)) / @(Deger(Model.Firma?.FirmaAdi)) / @(Deger(marka))</div>
            </div>
            <div class="df-actions">
                <a class="df-btn df-btn-secondary df-btn-sm" href="/AdminPanel/devreyealmalar">Listeye D&#246;n</a>
                <a class="df-btn df-btn-primary df-btn-sm" href="/AdminPanel/devreyealmalar/pdf/@Model.Id" target="_blank">PDF</a>
                <a class="df-btn df-btn-success df-btn-sm" href="/AdminPanel/devreyealmalar/excel/@Model.Id" target="_blank">Excel</a>
                <span class="df-pill @durumClass">@durumYazi</span>
            </div>
        </div>

        <div class="df-toolbar">
            <div class="df-form-row">
                <div class="df-field">
                    <label>Devreye Alma Tarihi</label>
                    <div class="df-control">@Model.DevreyeAlmaTarihi.ToString("dd.MM.yyyy")</div>
                </div>
                <div class="df-field">
                    <label>Marka</label>
                    <div class="df-control">@Deger(marka)</div>
                </div>
                <div class="df-field">
                    <label>Teknisyen</label>
                    <div class="df-control">@Deger(Model.TeknisyenAdi)</div>
                </div>
                <div class="df-field">
                    <label>Servis</label>
                    <div class="df-control">@Deger(Model.Firma?.FirmaAdi)</div>
                </div>
            </div>
        </div>
    </section>

    <div class="df-detail-grid">
        <section class="df-detail-card">
            <div class="df-detail-card-title">Müşteri Bilgileri</div>
            <div class="df-detail-info">
                <div class="info-item">
                    <div class="info-label">Müşteri</div>
                    <div class="info-value">@Deger(Model.MusteriAdi)</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Telefon</div>
                    <div class="info-value">@Deger(Model.MusteriTelefon)</div>
                </div>
                <div class="info-item">
                    <div class="info-label">TC Kimlik No</div>
                    <div class="info-value">@Deger(Model.MusteriTcNo ?? Model.AboneNo)</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Adres</div>
                    <div class="info-value">@Deger(Model.Adres)</div>
                </div>
            </div>
        </section>

        <section class="df-detail-card">
            <div class="df-detail-card-title">Tesisat Bilgileri</div>
            <div class="df-detail-info">
                <div class="info-item">
                    <div class="info-label">Tesisat No</div>
                    <div class="info-value">@Deger(Model.TesistatNo)</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Servis Cari Kod</div>
                    <div class="info-value">@Deger(Model.AboneNo)</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Uygunluk Belge No</div>
                    <div class="info-value">@Deger(Model.UygunlukBelgeNo)</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Uygunluk Tarihi</div>
                    <div class="info-value">@Tarih(Model.UygunlukTarihi)</div>
                </div>
            </div>
        </section>

        <section class="df-detail-card">
            <div class="df-detail-card-title">Cihaz Bilgileri</div>
            <div class="df-detail-info">
                <div class="info-item">
                    <div class="info-label">Cihaz Tipi</div>
                    <div class="info-value">@Deger(Model.CihazTipi)</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Cihaz Markası</div>
                    <div class="info-value">@Deger(Model.CihazMarka)</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Model</div>
                    <div class="info-value">@Deger(Model.CihazModeli)</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Seri No</div>
                    <div class="info-value">@Deger(Model.SeriNo)</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Kapasite</div>
                    <div class="info-value">@Deger(Model.CihazKapasite)</div>
                </div>
            </div>
        </section>

        <section class="df-detail-card">
            <div class="df-detail-card-title">Teknisyen Bilgileri</div>
            <div class="df-detail-info">
                <div class="info-item">
                    <div class="info-label">Teknisyen</div>
                    <div class="info-value">@Deger(Model.TeknisyenAdi)</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Yetki Belgesi No</div>
                    <div class="info-value">@Deger(Model.TeknisyenSertifikaNo)</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Kayıt Tarihi</div>
                    <div class="info-value">@Model.OlusturmaTarihi.ToString("dd.MM.yyyy HH:mm")</div>
                </div>
            </div>
        </section>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Notlar))
    {
        <section class="df-detail-card">
            <div class="df-detail-card-title">Notlar</div>
            <div class="df-detail-note">@Model.Notlar</div>
        </section>
    }
</div>
