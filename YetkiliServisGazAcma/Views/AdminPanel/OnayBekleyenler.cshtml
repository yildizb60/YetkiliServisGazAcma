@using YetkiliServisGazAcma.Entities
@{
    ViewData["Title"] = "Yetki Belgesi Onayları";
    ViewData["PanelTitle"] = "Yetki Belgesi Onayları";
    ViewData["PanelSubtitle"] = "Admin Paneli";
    ViewData["ActiveMenu"] = "OnayBekleyenler";
    Layout = "~/Views/Shared/_PanelLayout.cshtml";

    var bekleyenler = ViewBag.Bekleyenler as List<Ys_Sertifika> ?? new List<Ys_Sertifika>();
    var onaylananlar = ViewBag.Onaylananlar as List<Ys_Sertifika> ?? new List<Ys_Sertifika>();
    var reddedilenler = ViewBag.Reddedilenler as List<Ys_Sertifika> ?? new List<Ys_Sertifika>();
}

@section Styles {
    <style>
        .approval-board { display: grid; gap: 16px; }
        .approval-metrics { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; align-items: stretch; padding: 0 24px 20px; }
        .approval-metric { min-width: 0; background: #f8fafc; border: 1px solid #edf2f7; border-radius: 8px; padding: 14px 16px; display: grid; gap: 8px; }
        .approval-metric .info-label { font-size: 11px; color: #526071; font-weight: 800; text-transform: uppercase; letter-spacing: .04em; }
        .approval-metric .info-value { font-size: 22px; color: #172033; font-weight: 900; line-height: 1; }
        .filtre-kart { background: #fff; border-radius: 12px; border: 1px solid #eee; padding: 20px 24px; }
        .filtre-baslik { font-size: 14px; font-weight: 800; color: #333; margin-bottom: 16px; border-bottom: 1px solid #f0f0ee; padding-bottom: 12px; }
        .filtre-grid { display: grid; grid-template-columns: repeat(6, minmax(130px, 1fr)); gap: 14px; align-items: end; }
        .filtre-alan { display: flex; flex-direction: column; gap: 6px; min-width: 0; }
        .filtre-alan label { font-size: 11px; color: #555; font-weight: 800; text-transform: uppercase; letter-spacing: .04em; }
        .filtre-alan input,
        .filtre-alan select { padding: 10px 12px; border: 1.5px solid #ddd; border-radius: 8px; font-size: 13px; outline: none; color: #333; background: #fafafa; min-width: 0; }
        .filtre-alan input:focus,
        .filtre-alan select:focus { border-color: #4CAF7D; background: #fff; }
        .filtre-butonlar { display: flex; gap: 10px; margin-top: 16px; }
        .btn-filtre { padding: 10px 22px; background: linear-gradient(135deg, #1B9FD4, #0d7faa); color: #fff; border: none; border-radius: 8px; font-size: 13px; cursor: pointer; font-weight: 800; }
        .btn-filtre:hover { opacity: .9; }
        .btn-temizle { padding: 10px 16px; background: #fff; color: #888; border: 1.5px solid #ddd; border-radius: 8px; font-size: 13px; cursor: pointer; text-decoration: none; }
        .btn-temizle:hover { border-color: #e24b4a; color: #e24b4a; }
        .approval-tabs { display: flex; flex-wrap: wrap; gap: 8px; }
        .approval-tab {
            border: 1px solid var(--df-border);
            background: var(--df-surface);
            color: var(--df-text-soft);
            border-radius: var(--df-radius);
            min-height: 36px;
            padding: 0 14px;
            font-size: 12px;
            font-weight: 800;
            cursor: pointer;
        }
        .approval-tab.active { background: var(--df-primary-soft); border-color: #d5dbf5; color: var(--df-primary); }
        .approval-table-title { font-size: 14px; font-weight: 800; color: #333; }
        .approval-panels [data-panel] { display: none; }
        .approval-panels [data-panel].active { display: block; }
        @@media (max-width: 1180px) {
            .filtre-grid { grid-template-columns: repeat(3, minmax(160px, 1fr)); }
        }
        @@media (max-width: 900px) {
            .approval-metrics,
            .filtre-grid { grid-template-columns: 1fr; }
        }
    </style>
}

<div class="approval-board">
    @if (TempData["Basarili"] != null)
    {
        <div class="df-alert df-alert-success">@TempData["Basarili"]</div>
    }
    @if (TempData["Hata"] != null)
    {
        <div class="df-alert df-alert-danger">@TempData["Hata"]</div>
    }

    <section class="df-page-panel">
        <div class="df-panel-head">
            <div>
                <h2 class="df-panel-title">Yetki Belgesi Onayları</h2>
                <div class="df-panel-subtitle">Bekleyen, onaylanan ve reddedilen belgeleri aynı ekrandan yönetin.</div>
            </div>
        </div>
        <div class="approval-metrics">
            <div class="approval-metric">
                <div class="info-label">Onaya G&#246;nderildi</div>
                <div class="info-value">@bekleyenler.Count</div>
            </div>
            <div class="approval-metric">
                <div class="info-label">Onaylananlar</div>
                <div class="info-value">@onaylananlar.Count</div>
            </div>
            <div class="approval-metric">
                <div class="info-label">Reddedilenler</div>
                <div class="info-value">@reddedilenler.Count</div>
            </div>
        </div>
        <div class="filtre-butonlar">
            <button type="button" class="btn-filtre" id="approvalFilterApply">Filtrele</button>
            <button type="button" class="btn-temizle" id="approvalFilterClear">Temizle</button>
        </div>
    </section>

    <section class="filtre-kart">
        <div class="filtre-baslik">Filtrele</div>
        <div class="filtre-grid">
            <div class="filtre-alan">
                <label>Firma</label>
                <input type="text" id="filterFirma" placeholder="Firma adı" autocomplete="off" />
            </div>
            <div class="filtre-alan">
                <label>Şirket</label>
                <input type="text" id="filterSirket" placeholder="Şirket adı" autocomplete="off" />
            </div>
            <div class="filtre-alan">
                <label>Yükleme</label>
                <input type="date" id="filterYukleme" />
            </div>
            <div class="filtre-alan">
                <label>Başlangıç</label>
                <input type="date" id="filterBaslangic" />
            </div>
            <div class="filtre-alan">
                <label>Bitiş</label>
                <input type="date" id="filterBitis" />
            </div>
            <div class="filtre-alan">
                <label>Durum</label>
                <select id="filterDurum">
                    <option value="bekleyen">Onaya Gönderildi</option>
                    <option value="onaylanan">Onaylananlar</option>
                    <option value="reddedilen">Reddedilenler</option>
                </select>
            </div>
        </div>
    </section>

    <section class="df-page-panel approval-panels">
        <div class="df-panel-head">
            <div class="approval-table-title">Yetki Belgesi Listesi</div>
            <div class="approval-tabs" data-approval-tabs>
                <button type="button" class="approval-tab active" data-target="bekleyen">Onaya G&#246;nderildi (@bekleyenler.Count)</button>
                <button type="button" class="approval-tab" data-target="onaylanan">Onaylananlar (@onaylananlar.Count)</button>
                <button type="button" class="approval-tab" data-target="reddedilen">Reddedilenler (@reddedilenler.Count)</button>
            </div>
        </div>

        <div data-panel="bekleyen" class="active">
            @await Html.PartialAsync("~/Views/Shared/_SertifikaOnayTable.cshtml", new Tuple<List<Ys_Sertifika>, string, string>(bekleyenler, "bekleyen", "admin"))
        </div>
        <div data-panel="onaylanan">
            @await Html.PartialAsync("~/Views/Shared/_SertifikaOnayTable.cshtml", new Tuple<List<Ys_Sertifika>, string, string>(onaylananlar, "onaylanan", "admin"))
        </div>
        <div data-panel="reddedilen">
            @await Html.PartialAsync("~/Views/Shared/_SertifikaOnayTable.cshtml", new Tuple<List<Ys_Sertifika>, string, string>(reddedilenler, "reddedilen", "admin"))
        </div>
    </section>
</div>

@section Scripts {
<script>
(function () {
    var tabs = document.querySelector('[data-approval-tabs]');
    var durumSelect = document.getElementById('filterDurum');
    var filterButton = document.getElementById('approvalFilterApply');
    var clearButton = document.getElementById('approvalFilterClear');
    var inputs = {
        firma: document.getElementById('filterFirma'),
        sirket: document.getElementById('filterSirket'),
        yukleme: document.getElementById('filterYukleme'),
        baslangic: document.getElementById('filterBaslangic'),
        bitis: document.getElementById('filterBitis')
    };

    function norm(value) {
        return (value || '').toLocaleLowerCase('tr-TR').trim();
    }

    function activatePanel(target) {
        if (!target) target = 'bekleyen';
        document.querySelectorAll('.approval-panels [data-panel]').forEach(function (panel) {
            panel.classList.toggle('active', panel.getAttribute('data-panel') === target);
        });
        if (tabs) {
            tabs.querySelectorAll('[data-target]').forEach(function (item) {
                item.classList.toggle('active', item.getAttribute('data-target') === target);
            });
        }
        if (durumSelect && durumSelect.value !== target) durumSelect.value = target;
        applyFilters();
    }

    function applyFilters() {
        var activePanel = document.querySelector('.approval-panels [data-panel].active');
        if (!activePanel) return;

        var filters = {
            firma: norm(inputs.firma && inputs.firma.value),
            sirket: norm(inputs.sirket && inputs.sirket.value),
            yukleme: inputs.yukleme ? inputs.yukleme.value : '',
            baslangic: inputs.baslangic ? inputs.baslangic.value : '',
            bitis: inputs.bitis ? inputs.bitis.value : ''
        };

        activePanel.querySelectorAll('tr[data-approval-row="true"]').forEach(function (row) {
            var visible = true;
            if (filters.firma) visible = visible && (norm(row.dataset.firma).indexOf(filters.firma) > -1 || norm(row.dataset.vergi).indexOf(filters.firma) > -1);
            if (filters.sirket) visible = visible && norm(row.dataset.sirket).indexOf(filters.sirket) > -1;
            if (filters.yukleme) visible = visible && row.dataset.yukleme === filters.yukleme;
            if (filters.baslangic) visible = visible && row.dataset.baslangic >= filters.baslangic;
            if (filters.bitis) visible = visible && row.dataset.bitis <= filters.bitis;
            row.style.display = visible ? '' : 'none';
        });
    }

    if (tabs) {
        tabs.addEventListener('click', function (event) {
            var btn = event.target.closest('[data-target]');
            if (btn) activatePanel(btn.getAttribute('data-target'));
        });
    }
    if (durumSelect) durumSelect.addEventListener('change', function () { activatePanel(durumSelect.value); });
    if (filterButton) filterButton.addEventListener('click', applyFilters);
    if (clearButton) {
        clearButton.addEventListener('click', function () {
            Object.keys(inputs).forEach(function (key) {
                if (inputs[key]) inputs[key].value = '';
            });
            activatePanel('bekleyen');
        });
    }
})();
</script>
}
