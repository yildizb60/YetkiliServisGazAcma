@{
    ViewData["Title"] = "Admin Panel";
    ViewData["PanelTitle"] = "Genel Bakış";
    ViewData["PanelSubtitle"] = "Admin Paneli";
    ViewData["ActiveMenu"] = "Dashboard";
    Layout = "~/Views/Shared/_PanelLayout.cshtml";

    var sonSertifikalar = ViewBag.SonSertifikalar as List<YetkiliServisGazAcma.Entities.Ys_Sertifika>;
    var sonDevreyeAlmalar = ViewBag.SonDevreyeAlmalar as List<YetkiliServisGazAcma.Entities.Ys_DevreyeAlma>;
}

@section Styles {
    <style>
        body {
            background:
                radial-gradient(circle at 8% 10%, rgba(27, 159, 212, .10), transparent 34%),
                radial-gradient(circle at 90% 6%, rgba(76, 175, 125, .08), transparent 30%),
                #f0f4f8;
        }

        .cards {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 16px;
            margin-bottom: 24px;
        }

        .card {
            background: linear-gradient(180deg, #ffffff 0%, #f7fbff 100%);
            border-radius: 14px;
            padding: 16px;
            border: 1px solid #dde8f2;
            cursor: pointer;
            transition: transform .16s ease, box-shadow .16s ease, border-color .16s ease;
            box-shadow: 0 10px 22px rgba(15, 23, 42, .08);
            display: flex;
            align-items: center;
            gap: 12px;
            position: relative;
            overflow: hidden;
            color: inherit;
        }

        .card::before {
            content: "";
            position: absolute;
            left: 0;
            top: 0;
            width: 4px;
            height: 100%;
            background: linear-gradient(180deg, #3bb7e8, #4caf7d);
        }

        .card:hover {
            border-color: #a9d9ef;
            transform: translateY(-4px);
            box-shadow: 0 18px 30px rgba(15, 23, 42, .13);
        }

        .card-icon {
            width: 46px;
            height: 46px;
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-family: "Segoe UI Emoji", "Segoe UI Symbol", "Apple Color Emoji", "Noto Color Emoji", sans-serif;
        }

        .icon-blue { background: #e8f6fd; color: #1B9FD4; }
        .icon-green { background: #eaf8f0; color: #2f9d68; }
        .icon-orange { background: #fff2e5; color: #c57715; }
        .icon-red { background: #fdecec; color: #d64545; }
        .icon-indigo { background: #eceefe; color: #5c6bc0; }

        .card-meta { min-width: 0; }
        .card-label { font-size: 12px; color: #6b7a89; margin-bottom: 3px; font-weight: 700; text-transform: uppercase; letter-spacing: .02em; }
        .card-value { font-size: 28px; font-weight: 800; color: #0f2538; line-height: 1; }
        .card-sub { font-size: 11px; color: #90a0ad; margin-top: 5px; }

        .iki-kolon {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        .col4 { grid-template-columns: 2fr 1.2fr 1fr 1fr; }
        .col5 { grid-template-columns: 1.5fr 1.2fr 1fr 1fr .8fr; }

        @@media (max-width: 1100px) {
            .cards { grid-template-columns: repeat(2, minmax(0, 1fr)); }
            .iki-kolon { grid-template-columns: 1fr; }
        }

        @@media (max-width: 720px) {
            .cards { grid-template-columns: 1fr; }
        }
    </style>
}

<div class="cards">
    <div class="card" onclick="window.location='/AdminPanel/onay-bekleyenler'">
        <div class="card-icon icon-orange">✅</div>
        <div class="card-meta">
            <div class="card-label">Onay Bekleyen</div>
            <div class="card-value">@ViewBag.OnayBekleyen</div>
            <div class="card-sub">Yetki Belgesi</div>
        </div>
    </div>
    <div class="card">
        <div class="card-icon icon-green">🔧</div>
        <div class="card-meta">
            <div class="card-label">Bu Ay Devreye Alınan</div>
            <div class="card-value">@ViewBag.BuAyDevreyeAlma</div>
            <div class="card-sub">Cihaz</div>
        </div>
    </div>
    <div class="card" onclick="window.location='/AdminPanel/yetkiliservisler'">
        <div class="card-icon icon-indigo">🛠</div>
        <div class="card-meta">
            <div class="card-label">Yetkili Servis</div>
            <div class="card-value">@ViewBag.ToplamFirma</div>
            <div class="card-sub">Kayıtlı firma</div>
        </div>
    </div>
    <a class="card" href="/AdminPanel/raporlar" style="text-decoration:none;">
        <div class="card-icon icon-blue">📊</div>
        <div class="card-meta">
            <div class="card-label">Toplam Devreye Alma</div>
            <div class="card-value">@ViewBag.ToplamDevreyeAlma</div>
            <div class="card-sub">Tüm zamanlar</div>
        </div>
    </a>
    <div class="card" onclick="window.location='/AdminPanel/yetki-belgesi-uyarilari'">
        <div class="card-icon icon-red">⚠</div>
        <div class="card-meta">
            <div class="card-label">Süresi Dolacak</div>
            <div class="card-value">@ViewBag.SuresiBitecek</div>
            <div class="card-sub">30 gün içinde yetki belgesi</div>
        </div>
    </div>
</div>

<div class="iki-kolon">
    <div class="section">
        <div class="section-head">
            <div class="section-title">Son Yetki Belgesi Başvuruları</div>
            <a class="btn-sm" href="/AdminPanel/onay-bekleyenler">Tümünü Gör</a>
        </div>
        <div class="tablo-head col4">
            <div>Firma</div><div>Şirket</div><div>Tarih</div><div>Durum</div>
        </div>
        @if (sonSertifikalar == null || !sonSertifikalar.Any())
        {
            <div class="empty">Henüz yetki belgesi başvurusu yok</div>
        }
        else
        {
            foreach (var s in sonSertifikalar)
            {
                <div class="tablo-row col4">
                    <div>@s.Firma?.FirmaAdi</div>
                    <div style="font-size:12px;color:#888">@s.Firma?.Sirket?.SirketAdi</div>
                    <div>@s.OlusturmaTarihi.ToString("dd.MM.yyyy")</div>
                    <div>
                        @if (s.Durum == 0)
                        {
                            <span class="badge b-yellow">Bekliyor</span>
                        }
                        else if (s.Durum == 1)
                        {
                            <span class="badge b-green">Onaylandı</span>
                        }
                        else
                        {
                            <span class="badge b-red">Reddedildi</span>
                        }
                    </div>
                </div>
            }
        }
    </div>

    <div class="section">
        <div class="section-head">
            <div class="section-title">Son Devreye Almalar</div>
        </div>
        <div class="tablo-head col5">
            <div>Tesisat No</div><div>Servis</div><div>Marka</div><div>Tarih</div><div>Durum</div>
        </div>
        @if (sonDevreyeAlmalar == null || !sonDevreyeAlmalar.Any())
        {
            <div class="empty">Henüz devreye alma kaydı yok</div>
        }
        else
        {
            foreach (var d in sonDevreyeAlmalar)
            {
                <div class="tablo-row col5">
                    <div><strong>@d.TesistatNo</strong></div>
                    <div style="font-size:12px;color:#888">@d.Firma?.FirmaAdi</div>
                    <div>@d.Marka?.MarkaAdi</div>
                    <div>@d.OlusturmaTarihi.ToString("dd.MM.yyyy")</div>
                    <div>
                        @if (d.Durum == 1)
                        {
                            <span class="badge b-green">Tamam</span>
                        }
                        else if (d.Durum == 2)
                        {
                            <span class="badge b-red">İptal</span>
                        }
                        else
                        {
                            <span class="badge b-yellow">Bekliyor</span>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>
