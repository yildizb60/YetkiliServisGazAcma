@using YetkiliServisGazAcma.Entities
@{
    ViewData["Title"] = "Personeller";
    ViewData["PanelTitle"] = ViewData["Title"];
    ViewData["PanelSubtitle"] = "Admin Paneli";
    ViewData["ActiveMenu"] = "Personeller";
    Layout = "~/Views/Shared/_PanelLayout.cshtml";

    var personeller = ViewBag.Personeller as List<AppKullanici> ?? new List<AppKullanici>();
    var seciliQ = ViewBag.SeciliQ as string ?? "";
    var seciliSirket = ViewBag.SeciliSirket as string ?? "";
    var seciliDurum = ViewBag.SeciliDurum as string ?? "";
    var aktifSayisi = personeller.Count(x => x.AktifMi);
    var pasifSayisi = personeller.Count - aktifSayisi;
}

@if (TempData["Basarili"] != null)
{
    <div class="df-alert df-alert-success">@TempData["Basarili"]</div>
}
@if (TempData["Hata"] != null)
{
    <div class="df-alert df-alert-danger">@TempData["Hata"]</div>
}

<div class="section-label">
    Personel y&ouml;netimi
</div>

<div class="df-page-panel">
    <div class="df-panel-head">
        <div>
            <div class="df-panel-title">Personel Listesi</div>
            <div class="df-panel-subtitle">@personeller.Count kay&#305;t listeleniyor</div>
        </div>
        <div class="df-status-tabs">
            <span class="df-tab active">T&uuml;m&uuml; (@personeller.Count)</span>
            <span class="df-tab">Aktif (@aktifSayisi)</span>
            <span class="df-tab">Pasif (@pasifSayisi)</span>
        </div>
    </div>

    <div class="df-toolbar">
        <form class="df-form-row" method="get" action="/AdminPanel/personeller">
            <div class="df-field">
                <label>Arama</label>
                <input class="df-control" type="search" name="q" value="@seciliQ" placeholder="Ad soyad, e-posta, telefon" />
            </div>
            <div class="df-field">
                <label>&#350;irket</label>
                <input class="df-control" type="text" name="sirket" value="@seciliSirket" placeholder="&#350;irket ad&#305;" />
            </div>
            <div class="df-field">
                <label>Durum</label>
                <select class="df-control" name="durum">
                    <option value="" selected="@(string.IsNullOrEmpty(seciliDurum))">T&uuml;m&uuml;</option>
                    <option value="Aktif" selected="@(seciliDurum == "Aktif")">Aktif</option>
                    <option value="Pasif" selected="@(seciliDurum == "Pasif")">Pasif</option>
                </select>
            </div>
            <button class="df-btn df-btn-primary df-btn-sm" type="submit">Filtrele</button>
            <a class="df-btn df-btn-secondary df-btn-sm" href="/AdminPanel/personeller">Temizle</a>
            <a class="df-btn df-btn-success df-btn-sm" href="/AdminPanel/personeller/ekle">Yeni Personel</a>
        </form>
    </div>

    <div class="df-table-wrap">
        <table class="df-table">
            <thead>
                <tr>
                    <th>Ad Soyad</th>
                    <th>E-Posta</th>
                    <th>&#350;irket</th>
                    <th>Durum</th>
                    <th>&#304;&#351;lem</th>
                </tr>
            </thead>
            <tbody>
                @if (!personeller.Any())
                {
                    <tr>
                        <td colspan="5">
                            <div class="df-empty">
                                <div class="df-empty-title">Personel kayd&#305; yok.</div>
                                <p class="df-empty-text">Filtreleri de&#287;i&#351;tirerek tekrar deneyebilir veya yeni personel ekleyebilirsiniz.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var p in personeller)
                    {
                        <tr>
                            <td>
                                <div class="df-cell-main">@(p.AdSoyad ?? "-")</div>
                                <div class="df-cell-sub">@(p.PhoneNumber ?? "-")</div>
                            </td>
                            <td>@(p.Email ?? "-")</td>
                            <td>
                                <div class="df-cell-main">@(p.Sirket?.SirketAdi ?? "-")</div>
                                <div class="df-cell-sub">@(p.Sirket?.Il ?? "")</div>
                            </td>
                            <td>
                                <span class="df-pill @(p.AktifMi ? "df-pill-success" : "df-pill-muted")">
                                    @(p.AktifMi ? "Aktif" : "Pasif")
                                </span>
                            </td>
                            <td>
                                <div class="df-actions">
                                    <a class="df-btn df-btn-secondary df-btn-sm" href="/AdminPanel/kullanicilar/duzenle/@p.Id?returnUrl=/AdminPanel/personeller">D&uuml;zenle</a>
                                    <form method="post" action="/AdminPanel/personeller/durum/@p.Id">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="aktif" value="@(p.AktifMi ? "false" : "true")" />
                                        <button type="submit" class="df-btn df-btn-ghost df-btn-sm">
                                            @Html.Raw(p.AktifMi ? "Pasifle&#351;tir" : "Aktifle&#351;tir")
                                        </button>
                                    </form>
                                    <form method="post" action="/AdminPanel/personeller/sil/@p.Id" onsubmit="return confirm('Personel silinsin mi?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="df-btn df-btn-danger df-btn-sm">Sil</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
