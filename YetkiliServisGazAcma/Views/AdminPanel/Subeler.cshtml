@using YetkiliServisGazAcma.Entities
@{
    ViewData["Title"] = "Şube / Servis Noktaları";
    ViewData["PanelTitle"] = "Şube / Servis Noktaları";
    ViewData["PanelSubtitle"] = "Admin Paneli";
    ViewData["ActiveMenu"] = "Subeler";
    Layout = "~/Views/Shared/_PanelLayout.cshtml";

    var subeler = ViewBag.Subeler as List<Ys_Sube> ?? new List<Ys_Sube>();
    var firmalar = ViewBag.Firmalar as List<Ys_Firma> ?? new List<Ys_Firma>();
    var seciliFirmaId = ViewBag.SeciliFirmaId is int fid ? fid : 0;
    var seciliQ = ViewBag.SeciliQ as string ?? "";
    var aktifSayisi = subeler.Count(x => x.AktifMi);
    var pasifSayisi = subeler.Count - aktifSayisi;
}

@if (TempData["Basarili"] != null)
{
    <div class="df-alert df-alert-success">@TempData["Basarili"]</div>
}
@if (TempData["Hata"] != null)
{
    <div class="df-alert df-alert-danger">@TempData["Hata"]</div>
}

<div class="section-label">
    Servis ağı
</div>

<div class="df-page-panel">
    <div class="df-panel-head">
        <div>
            <div class="df-panel-title">Şube / Servis Noktaları</div>
            <div class="df-panel-subtitle">@subeler.Count kayıt listeleniyor</div>
        </div>
        <div class="df-status-tabs" id="subeStatusTabs">
            <button type="button" class="df-tab active" data-status="all">Tümü (@subeler.Count)</button>
            <button type="button" class="df-tab" data-status="aktif">Aktif (@aktifSayisi)</button>
            <button type="button" class="df-tab" data-status="pasif">Pasif (@pasifSayisi)</button>
        </div>
    </div>

    <div class="df-toolbar">
        <form method="get" action="/AdminPanel/subeler" class="df-form-row">
            <div class="df-field">
                <label>Firma</label>
                <select name="firmaId" class="df-control">
                    <option value="0">Tüm firmalar</option>
                    @foreach (var firma in firmalar)
                    {
                        <option value="@firma.Id" selected="@(seciliFirmaId == firma.Id)">@firma.FirmaAdi</option>
                    }
                </select>
            </div>
            <div class="df-field">
                <label>Arama</label>
                <input class="df-control" type="search" name="q" value="@seciliQ" placeholder="Şube, il, telefon veya firma" />
            </div>
            <button type="submit" class="df-btn df-btn-primary df-btn-sm">Filtrele</button>
            <a href="/AdminPanel/subeler" class="df-btn df-btn-secondary df-btn-sm">Temizle</a>
        </form>
    </div>

    <div class="stats-body">
        <form method="post" action="/AdminPanel/subeler/ekle" class="df-form-row">
            @Html.AntiForgeryToken()
            <div class="df-field">
                <label>Firma</label>
                <select name="firmaId" class="df-control" required>
                    <option value="">Firma seçin</option>
                    @foreach (var firma in firmalar)
                    {
                        <option value="@firma.Id">@firma.FirmaAdi</option>
                    }
                </select>
            </div>
            <div class="df-field">
                <label>Şube adı</label>
                <input class="df-control" name="subeAdi" required maxlength="150" placeholder="Merkez servis" />
            </div>
            <div class="df-field">
                <label>İl</label>
                <input class="df-control" name="il" maxlength="80" />
            </div>
            <div class="df-field">
                <label>İlçe</label>
                <input class="df-control" name="ilce" maxlength="80" />
            </div>
            <div class="df-field">
                <label>Telefon</label>
                <input class="df-control" name="telefon" maxlength="30" />
            </div>
            <div class="df-field">
                <label>Adres</label>
                <input class="df-control" name="adres" maxlength="300" />
            </div>
            <label class="df-check-row">
                <input type="checkbox" name="aktifMi" value="true" checked />
                Aktif
            </label>
            <button type="submit" class="df-btn df-btn-success df-btn-sm df-sube-add-button">Yeni Şube Ekle</button>
        </form>
    </div>

    <div class="df-table-wrap">
        <table class="df-table">
            <thead>
                <tr>
                    <th>Şube</th>
                    <th>Firma</th>
                    <th>Konum</th>
                    <th>Telefon</th>
                    <th>Durum</th>
                    <th>İşlem</th>
                </tr>
            </thead>
            <tbody>
                @if (!subeler.Any())
                {
                    <tr>
                        <td colspan="6">
                            <div class="df-empty">
                                <div class="df-empty-title">Şube bulunamadı.</div>
                                <p class="df-empty-text">Filtreleri değiştirerek tekrar deneyebilir veya yeni şube ekleyebilirsiniz.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var sube in subeler)
                    {
                        var durum = sube.AktifMi ? "aktif" : "pasif";
                        <tr data-status="@durum">
                            <td>
                                <div class="df-cell-main">@sube.SubeAdi</div>
                                <div class="df-cell-sub">@sube.Adres</div>
                            </td>
                            <td>
                                <div class="df-cell-main">@sube.Firma?.FirmaAdi</div>
                                <div class="df-cell-sub">@sube.Firma?.Email</div>
                            </td>
                            <td>@($"{sube.Il} {sube.Ilce}".Trim())</td>
                            <td>@sube.Telefon</td>
                            <td>
                                <span class="df-pill @(sube.AktifMi ? "df-pill-success" : "df-pill-muted")">
                                    @(sube.AktifMi ? "Aktif" : "Pasif")
                                </span>
                            </td>
                            <td>
                                <div class="df-actions">
                                    <a class="df-btn df-btn-secondary df-btn-sm" href="/AdminPanel/subeler/duzenle/@sube.Id">Düzenle</a>
                                    <form method="post" action="/AdminPanel/subeler/durum">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@sube.Id" />
                                        <button type="submit" class="df-btn df-btn-ghost df-btn-sm">
                                            @(sube.AktifMi ? "Pasifleştir" : "Aktifleştir")
                                        </button>
                                    </form>
                                    <form method="post" action="/AdminPanel/subeler/sil" onsubmit="return confirm('Şube kaydı silinsin mi?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@sube.Id" />
                                        <button type="submit" class="df-btn df-btn-danger df-btn-sm">Sil</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var tabs = document.getElementById('subeStatusTabs');
    if (!tabs) return;

    tabs.addEventListener('click', function (event) {
        var btn = event.target.closest('[data-status]');
        if (!btn) return;
        var status = btn.getAttribute('data-status');

        tabs.querySelectorAll('[data-status]').forEach(function (item) {
            item.classList.toggle('active', item === btn);
        });

        document.querySelectorAll('tr[data-status]').forEach(function (row) {
            row.style.display = status === 'all' || row.getAttribute('data-status') === status ? '' : 'none';
        });
    });
})();
</script>
}
