@model YetkiliServisGazAcma.Entities.Ys_Marka
@{
    ViewData["Title"] = "Marka Düzenle";
    ViewData["PanelTitle"] = ViewData["Title"];
    ViewData["PanelSubtitle"] = "Admin Paneli";
    ViewData["ActiveMenu"] = "Markalar";
    Layout = "~/Views/Shared/_PanelLayout.cshtml";
}

<div class="section-label">
    Marka y&ouml;netimi
</div>

<div class="df-page-panel">
    <div class="df-panel-head">
        <div>
            <div class="df-panel-title">Marka D&uuml;zenle</div>
            <div class="df-panel-subtitle">Marka bilgisini ayn&#305; panel tasar&#305;m&#305;yla g&uuml;ncelleyin</div>
        </div>
        <a class="df-btn df-btn-secondary df-btn-sm" href="/Marka">Markalara D&ouml;n</a>
    </div>

    <div class="stats-body">
        <form method="post" action="/Marka/Duzenle">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" value="@Model.Id" />
            <div class="df-form-row">
                <div class="df-field">
                    <label>Marka Ad&#305; *</label>
                    <input class="df-control" type="text" name="MarkaAdi" value="@Model.MarkaAdi" required />
                </div>
                <div class="df-field df-field-wide">
                    <label>A&ccedil;&#305;klama</label>
                    <textarea class="df-control" name="Aciklama">@Model.Aciklama</textarea>
                </div>
            </div>

            <div class="df-form-actions">
                <button type="submit" class="df-btn df-btn-primary df-btn-sm">Kaydet</button>
                <a class="df-btn df-btn-secondary df-btn-sm" href="/Marka">&#304;ptal</a>
            </div>
        </form>
    </div>
</div>
