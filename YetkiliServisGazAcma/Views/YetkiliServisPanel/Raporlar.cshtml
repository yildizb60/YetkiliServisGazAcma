@{
    var kullanici = ViewBag.Kullanici as YetkiliServisGazAcma.Entities.AppKullanici;
ViewData["Title"] = "Raporlarım";
    ViewData["PanelTitle"] = ViewData["Title"];
    ViewData["PanelSubtitle"] = "Yetkili Servis";
    ViewData["ActiveMenu"] = "Raporlar";
    Layout = "~/Views/Shared/_PanelLayout.cshtml";
    DateTime basTarih = ViewBag.BasTarih;
    DateTime bitTarih = ViewBag.BitTarih;
    var sonIslemler = ViewBag.SonIslemler as List<YetkiliServisGazAcma.Entities.Ys_DevreyeAlma> ?? new();
    var firma = ViewBag.Firma as YetkiliServisGazAcma.Entities.Ys_Firma;
    string adSoyad = kullanici?.AdSoyad ?? firma?.YetkiliKisi ?? "Yetkili Servis";
    string basHarf = !string.IsNullOrEmpty(adSoyad) ? adSoyad.Substring(0, 1).ToUpper() : "Y";
    var jsonOptions = new System.Text.Json.JsonSerializerOptions { Encoder = System.Text.Encodings.Web.JavaScriptEncoder.UnsafeRelaxedJsonEscaping };
}

@section Styles {
    <style>
.content { padding: 28px 32px; display: grid; gap: 16px; }
        .filter-bar { background: #fff; border: 1px solid #eee; border-radius: 12px; padding: 16px 20px; display: grid; grid-template-columns: 1fr 1fr auto; gap: 10px; align-items: end; }
        .filter-group { display: flex; flex-direction: column; gap: 6px; }
        .filter-group label { font-size: 11px; color: #777; font-weight: bold; text-transform: uppercase; letter-spacing: .04em; }
        .filter-group input { padding: 9px 10px; border: 1px solid #ddd; border-radius: 8px; font-size: 13px; }
        .btn-filter { padding: 9px 14px; border-radius: 8px; font-size: 12px; font-weight: bold; border: none; cursor: pointer; background: #1B9FD4; color: #fff; }
        .cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
        .card { background: #fff; border-radius: 12px; padding: 16px; border: 1px solid #eee; }
        .card-title { font-size: 11px; color: #777; text-transform: uppercase; letter-spacing: .04em; }
        .card-value { font-size: 22px; font-weight: bold; margin-top: 6px; }
        .charts { display: grid; grid-template-columns: 1.2fr 1fr 1fr; gap: 12px; }
        .chart-card { background: #fff; border-radius: 14px; border: 1px solid #e8eff6; padding: 14px; }
        .chart-title { font-size: 12px; font-weight: 700; color: #334155; margin-bottom: 8px; }
        .chart-wrap { position: relative; height: 220px; }
        .chart-wrap canvas { width: 100% !important; height: 100% !important; }
        .chart-empty { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; color: #9aa6b2; font-size: 12px; }
        .chart-wrap.has-data .chart-empty { display: none; }
        .chart-fallback { display: none; position: absolute; inset: 10px; overflow: auto; }
        .chart-wrap.has-data:not(.chart-rendered) canvas { display: none; }
        .chart-wrap.has-data:not(.chart-rendered) .chart-fallback { display: grid; align-content: center; gap: 8px; }
        .chart-fallback-row { display: grid; grid-template-columns: minmax(70px, 1fr) minmax(120px, 2fr) 34px; gap: 8px; align-items: center; font-size: 12px; color: #3d4f6e; }
        .chart-fallback-bar { height: 8px; border-radius: 999px; background: #eef1fb; overflow: hidden; }
        .chart-fallback-fill { display: block; height: 100%; border-radius: inherit; background: #2e4ec8; }
        .section { background: #fff; border-radius: 12px; border: 1px solid #eee; overflow: hidden; }
        .section-head { padding: 14px 20px; border-bottom: 2px solid #f0f0ee; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; }
        .section-title { font-size: 14px; font-weight: bold; color: #333; }
        .section-actions { display: flex; gap: 8px; flex-wrap: wrap; }
        .btn-rapor { padding: 8px 12px; border-radius: 8px; font-size: 12px; font-weight: bold; border: 1px solid #1B9FD4; color: #1B9FD4; background: #eef7ff; text-decoration: none; }
        .btn-rapor:hover { background: #e2f1ff; }
        .tablo-head { padding: 10px 20px; background: #f8f8f6; font-size: 11px; color: #888; font-weight: bold; display: grid; grid-template-columns: 0.4fr 1.2fr 1.2fr 1fr 1fr; }
        .tablo-row { padding: 12px 20px; border-top: 1px solid #f0f0ee; font-size: 13px; color: #333; display: grid; grid-template-columns: 0.4fr 1.2fr 1.2fr 1fr 1fr; align-items: center; }
        .empty { padding: 24px; text-align: center; color: #bbb; font-size: 13px; }
        @@media (max-width: 1280px) {
            .cards { grid-template-columns: repeat(2, 1fr); }
            .charts { grid-template-columns: 1fr; }
        }
        @@media (max-width: 860px) {
            .cards { grid-template-columns: 1fr; }
            .filter-bar { grid-template-columns: 1fr; }
        }
    </style>
}

<form class="filter-bar" method="get" action="/ys-panel/raporlar">
    <div class="filter-group">
        <label>Başlangıç</label>
        <input type="date" name="bas" value="@(basTarih.ToString("yyyy-MM-dd"))" />
    </div>
    <div class="filter-group">
        <label>Bitiş</label>
        <input type="date" name="bit" value="@(bitTarih.ToString("yyyy-MM-dd"))" />
    </div>
    <button class="btn-filter" type="submit">Raporla</button>
</form>
<div class="cards">
    <div class="card">
        <div class="card-title">Toplam İşlem</div>
        <div class="card-value">@ViewBag.DevreyeSayisi</div>
    </div>
    <div class="card">
        <div class="card-title">Tamamlanan</div>
        <div class="card-value">@ViewBag.Tamamlanan</div>
    </div>
    <div class="card">
        <div class="card-title">Bekleyen</div>
        <div class="card-value">@ViewBag.Bekleyen</div>
    </div>
    <div class="card">
        <div class="card-title">Yetki Belgesi Onaylı</div>
        <div class="card-value">@ViewBag.YetkiBelgesiOnayli</div>
    </div>
</div>
<div class="charts">
    <div class="chart-card">
        <div class="chart-title">Aylık İşlem Trendi</div>
        <div class="chart-wrap" id="wrapAylik">
            <div class="chart-empty">Veri bulunamadı</div>
            <canvas id="aylikChart"></canvas>
        </div>
    </div>
    <div class="chart-card">
        <div class="chart-title">Yetki Belgesi Durum Dağılımı</div>
        <div class="chart-wrap" id="wrapDurum">
            <div class="chart-empty">Veri bulunamadı</div>
            <canvas id="durumChart"></canvas>
        </div>
    </div>
    <div class="chart-card">
        <div class="chart-title">Markaya Göre İşlem Dağılımı</div>
        <div class="chart-wrap" id="wrapMarka">
            <div class="chart-empty">Veri bulunamadı</div>
            <canvas id="markaChart"></canvas>
        </div>
    </div>
</div>
<div class="section">
    <div class="section-head">
        <div class="section-title">Son İşlemler</div>
        <div class="section-actions">
            <form id="pdfSeçlectedForm" method="get" action="/ys-panel/raporlar/pdf">
                <input type="hidden" name="bas" value="@basTarih.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="bit" value="@bitTarih.ToString("yyyy-MM-dd")" />
                <button class="btn-rapor" type="submit">Seçili İşlemler PDF</button>
            </form>
            <button class="btn-rapor" type="button" onclick="indirSeciliYsExcel()">Seçili İşlemler Excel</button>
            <a class="btn-rapor" href="/ys-panel/raporlar/pdf?bas=@basTarih.ToString("yyyy-MM-dd")&bit=@bitTarih.ToString("yyyy-MM-dd")">Seçili Tarih PDF</a>
            <a class="btn-rapor" href="/ys-panel/raporlar/pdf-toplu">Toplu PDF</a>
            <a class="btn-rapor" href="/ys-panel/raporlar/excel?bas=@basTarih.ToString("yyyy-MM-dd")&bit=@bitTarih.ToString("yyyy-MM-dd")">Excel İndir</a>
            <a class="btn-rapor" href="/ys-panel/raporlar/excel-toplu">Toplu Excel</a>
        </div>
    </div>
    <div class="tablo-head">
        <div>Seç</div><div>Tesisat No</div><div>Müşteri</div><div>Marka</div><div>Tarih</div>
    </div>
    @if (sonIslemler == null || sonIslemler.Count == 0)
    {
        <div class="empty">Bu aralıkta işlem yok</div>
    }
    else
    {
        @foreach (var d in sonIslemler)
        {
            <div class="tablo-row">
                <div><input type="checkbox" name="ids" value="@d.Id" form="pdfSeçlectedForm" /></div>
                <div><strong>@d.TesistatNo</strong></div>
                <div>@d.MusteriAdi</div>
                <div>@d.Marka?.MarkaAdi</div>
                <div>@d.DevreyeAlmaTarihi.ToString("dd.MM.yyyy")</div>
            </div>
        }
    }
</div>

<div id="raporChartData"
     data-aylik-labels='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ChartAylikLabels ?? new List<string>(), jsonOptions))'
     data-aylik-data='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ChartAylikData ?? new List<int>(), jsonOptions))'
     data-durum-data='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ChartDurumData ?? new List<int>(), jsonOptions))'
     data-marka-labels='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ChartMarkaLabels ?? new List<string>(), jsonOptions))'
     data-marka-data='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ChartMarkaData ?? new List<int>(), jsonOptions))'
     hidden></div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
    (function () {
        const root = document.getElementById("raporChartData");
        if (!root) return;

        const parseArray = (raw) => {
            if (!raw) return [];
            try {
                const data = JSON.parse(raw);
                return Array.isArray(data) ? data : [];
            } catch {
                return [];
            }
        };

        const aylikLabels = parseArray(root.dataset.aylikLabels);
        const aylikData = parseArray(root.dataset.aylikData).map(Number);
        const durumData = parseArray(root.dataset.durumData).map(Number);
        const markaLabels = parseArray(root.dataset.markaLabels);
        const markaData = parseArray(root.dataset.markaData).map(Number);

        const hasAnyPositive = (arr) => arr.some(x => Number(x) > 0);
        const markHasData = (wrapId) => {
            const wrap = document.getElementById(wrapId);
            if (wrap) wrap.classList.add("has-data");
        };
        const markRendered = (wrapId) => {
            const wrap = document.getElementById(wrapId);
            if (wrap) wrap.classList.add("chart-rendered");
        };
        const renderFallback = (wrapId, labels, data) => {
            const wrap = document.getElementById(wrapId);
            if (!wrap) return;
            const max = Math.max(...data, 1);
            const holder = document.createElement("div");
            holder.className = "chart-fallback";
            labels.forEach((label, index) => {
                const value = Number(data[index]) || 0;
                const percent = Math.max(4, Math.round((value / max) * 100));
                const row = document.createElement("div");
                row.className = "chart-fallback-row";
                const labelEl = document.createElement("span");
                labelEl.textContent = label;
                const bar = document.createElement("span");
                bar.className = "chart-fallback-bar";
                const fill = document.createElement("span");
                fill.className = "chart-fallback-fill";
                fill.style.width = `${percent}%`;
                bar.appendChild(fill);
                const valueEl = document.createElement("strong");
                valueEl.textContent = value;
                row.append(labelEl, bar, valueEl);
                holder.appendChild(row);
            });
            wrap.appendChild(holder);
        };

        const aylikHasData = aylikLabels.length > 0 && hasAnyPositive(aylikData);
        const durumHasData = durumData.length === 3 && hasAnyPositive(durumData);
        const markaHasData = markaLabels.length > 0 && hasAnyPositive(markaData);

        if (aylikHasData) {
            markHasData("wrapAylik");
            renderFallback("wrapAylik", aylikLabels, aylikData);
        }

        if (durumHasData) {
            markHasData("wrapDurum");
            renderFallback("wrapDurum", ["Onaylı", "Bekleyen", "Reddedilen"], durumData);
        }

        if (markaHasData) {
            markHasData("wrapMarka");
            renderFallback("wrapMarka", markaLabels, markaData);
        }

        if (typeof Chart === "undefined") return;

        if (aylikHasData) {
            markRendered("wrapAylik");
            new Chart(document.getElementById("aylikChart"), {
                type: "line",
                data: {
                    labels: aylikLabels,
                    datasets: [{
                        label: "İşlem",
                        data: aylikData,
                        borderColor: "#1B9FD4",
                        backgroundColor: "rgba(27, 159, 212, 0.18)",
                        fill: true,
                        borderWidth: 2,
                        tension: 0.35,
                        pointRadius: 3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
                }
            });
        }

        if (durumHasData) {
            markRendered("wrapDurum");
            new Chart(document.getElementById("durumChart"), {
                type: "doughnut",
                data: {
                    labels: ["Onaylı", "Bekleyen", "Reddedilen"],
                    datasets: [{
                        data: durumData,
                        backgroundColor: ["#4CAF7D", "#1B9FD4", "#E24B4A"],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { position: "bottom" } }
                }
            });
        }

        if (markaHasData) {
            markRendered("wrapMarka");
            new Chart(document.getElementById("markaChart"), {
                type: "bar",
                data: {
                    labels: markaLabels,
                    datasets: [{
                        label: "İşlem",
                        data: markaData,
                        backgroundColor: "rgba(76, 175, 125, 0.75)",
                        borderRadius: 6,
                        borderSkipped: false
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
                }
            });
        }
    })();
</script>
<script>
function indirSeciliYsExcel() {
    const ids = Array.from(document.querySelectorAll('input[name="ids"][form]:checked')).map(x => x.value);
    if (ids.length === 0) {
        alert('Lütfen en az bir işlem seçin.');
        return;
    }
    const query = ids.map(id => 'ids=' + encodeURIComponent(id)).join('&');
    window.open('/ys-panel/raporlar/excel?' + query, '_blank');
}
</script>
}
