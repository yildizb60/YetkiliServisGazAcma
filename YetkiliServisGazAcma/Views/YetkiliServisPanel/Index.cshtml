@{
    var kullanici = ViewBag.Kullanici as YetkiliServisGazAcma.Entities.AppKullanici;
    ViewData["Title"] = "Yetkili Servis Paneli";
    ViewData["PanelTitle"] = "Genel Bakış";
    ViewData["PanelSubtitle"] = "Yetkili Servis";
    ViewData["ActiveMenu"] = "Dashboard";
    Layout = "~/Views/Shared/_PanelLayout.cshtml";

    var firma = ViewBag.Firma as YetkiliServisGazAcma.Entities.Ys_Firma;
    var sonIslemler = ViewBag.SonIslemler as List<YetkiliServisGazAcma.Entities.Ys_DevreyeAlma>
        ?? new List<YetkiliServisGazAcma.Entities.Ys_DevreyeAlma>();
    var buAy = ViewBag.BuAy as int? ?? 0;
    var toplam = ViewBag.Toplam as int? ?? 0;
    var bugun = DateTime.Now.Date;
    var tumBelgeler = firma?.YetkiBelgeleri?
        .Where(x => !x.SilindiMi)
        .OrderByDescending(x => x.OlusturmaTarihi)
        .ToList() ?? new List<YetkiliServisGazAcma.Entities.Ys_YetkiBelgesi>();
    var onayliBelgeler = tumBelgeler
        .Where(x => x.Durum == 1)
        .OrderBy(x => x.YetkiBelgesiBitisTarihi)
        .ToList();
    var gecerliBelgeler = onayliBelgeler
        .Where(x => (!x.YetkiBelgesiBaslangicTarihi.HasValue || x.YetkiBelgesiBaslangicTarihi.Value.Date <= bugun)
            && x.YetkiBelgesiBitisTarihi.Date >= bugun)
        .OrderBy(x => x.YetkiBelgesiBitisTarihi)
        .ToList();
    var bekleyenBelge = tumBelgeler.Count(x => x.Durum == 0);
    var reddedilenBelge = tumBelgeler.Count(x => x.Durum == 2);
    var markaSayisi = firma?.FirmaMarkalar?.Count(x => !x.SilindiMi) ?? 0;
    var kategoriSayisi = firma?.FirmaKategoriler?.Count(x => !x.SilindiMi) ?? 0;
    var subeSayisi = firma?.Subeler?.Count(x => !x.SilindiMi) ?? 0;
    var tamamlananSon = sonIslemler.Count(x => x.Durum == 1);
    var bekleyenSon = sonIslemler.Count(x => x.Durum != 1);
    var ilkKurulumZorunlu = ViewBag.IlkKurulumZorunlu as bool? ?? false;
    var ilkKurulumTamamlandi = ViewBag.IlkKurulumTamamlandi as bool? ?? true;
    var ilkKurulumEksikler = ViewBag.IlkKurulumEksikler as List<string> ?? new List<string>();
    var kurulumKilitli = ilkKurulumZorunlu && !ilkKurulumTamamlandi;
    var bildirimler = ViewBag.Bildirimler as List<string> ?? new List<string>();
    var adSoyad = kullanici?.AdSoyad ?? firma?.YetkiliKisi ?? "Yetkili Servis";
    var basHarf = !string.IsNullOrWhiteSpace(adSoyad)
        ? adSoyad.Trim().Substring(0, 1).ToUpper(new System.Globalization.CultureInfo("tr-TR"))
        : "Y";

    var ay = DateTime.Now;
    var ayIlkGun = new DateTime(ay.Year, ay.Month, 1);
    var ayGunSayisi = DateTime.DaysInMonth(ay.Year, ay.Month);
    var ilkGunOffset = ((int)ayIlkGun.DayOfWeek + 6) % 7;
    var oncekiAy = ayIlkGun.AddMonths(-1);
    var oncekiAyGunSayisi = DateTime.DaysInMonth(oncekiAy.Year, oncekiAy.Month);
    var takvimHucre = 42;

    var kartlar = new List<DashboardTile>();

    if (ilkKurulumZorunlu)
    {
        kartlar.Add(new DashboardTile
        {
            Title = "İlk Kurulum",
            Url = "/ys-panel/ilk-kurulum",
            Icon = "bi bi-clipboard-check",
            Done = ilkKurulumTamamlandi ? 1 : 0,
            Total = 1,
            Subtitle = "Tamamlanma",
            Stat1Label = "Toplam",
            Stat1Value = "1",
            Stat2Label = "Eksik",
            Stat2Value = ilkKurulumEksikler.Count.ToString(),
            Stat2Class = ilkKurulumEksikler.Count > 0 ? "df-badge-pulse" : "df-tile-stat-val",
            Stat3Label = "Durum",
            Stat3Value = ilkKurulumTamamlandi ? "Tamam" : "Eksik",
            Stat3Class = ilkKurulumTamamlandi ? "df-tile-stat-val" : "df-badge-pulse",
            Featured = kurulumKilitli
        });
    }

    kartlar.Add(new DashboardTile
    {
        Title = "Yetki Belgem",
        Url = "/ys-yetki-belgesi",
        Icon = "bi bi-file-earmark-text",
        Done = gecerliBelgeler.Count,
        Total = Math.Max(tumBelgeler.Count, 1),
        Subtitle = "Geçerli / Toplam",
        Stat1Label = "Toplam",
        Stat1Value = tumBelgeler.Count.ToString(),
        Stat2Label = "Bekleyen",
        Stat2Value = bekleyenBelge.ToString(),
        Stat2Class = bekleyenBelge > 0 ? "df-badge-pulse" : "df-tile-stat-val",
        Stat3Label = "Geçerli",
        Stat3Value = gecerliBelgeler.Count.ToString(),
        Featured = !ilkKurulumZorunlu
    });

    kartlar.Add(new DashboardTile
    {
        Title = kurulumKilitli ? "Kurulumu Tamamla" : "Cihaz Devreye Al",
        Url = kurulumKilitli ? "/ys-panel/ilk-kurulum" : "/ys-devreyeal",
        Icon = "bi bi-bag-check",
        Done = buAy,
        Total = Math.Max(toplam, buAy),
        Subtitle = "Bu Ay / Toplam",
        Stat1Label = "Toplam",
        Stat1Value = toplam.ToString(),
        Stat2Label = "Bu Ay",
        Stat2Value = buAy.ToString(),
        Stat3Label = "Durum",
        Stat3Value = kurulumKilitli ? "Kilitli" : "Aktif",
        Stat3Class = kurulumKilitli ? "df-badge-pulse" : "df-tile-stat-val"
    });

    kartlar.Add(new DashboardTile
    {
        Title = "İşlem Geçmişim",
        Url = "/ys-devreyeal/gecmis",
        Icon = "bi bi-clock",
        Done = tamamlananSon,
        Total = Math.Max(sonIslemler.Count, tamamlananSon),
        Subtitle = "Tamamlanan / Son Kayıt",
        Stat1Label = "Son Kayıt",
        Stat1Value = sonIslemler.Count.ToString(),
        Stat2Label = "Bekleyen",
        Stat2Value = bekleyenSon.ToString(),
        Stat2Class = bekleyenSon > 0 ? "df-badge-pulse" : "df-tile-stat-val",
        Stat3Label = "Tamamlanan",
        Stat3Value = tamamlananSon.ToString()
    });

    kartlar.Add(new DashboardTile
    {
        Title = "Marka Yetkilerim",
        Url = "/ys-panel/markalar",
        Icon = "bi bi-building-check",
        Done = markaSayisi,
        Total = markaSayisi,
        Subtitle = "Tanımlı / Toplam",
        Stat1Label = "Toplam",
        Stat1Value = markaSayisi.ToString(),
        Stat2Label = "Kategori",
        Stat2Value = kategoriSayisi.ToString(),
        Stat3Label = "Durum",
        Stat3Value = markaSayisi > 0 ? "Aktif" : "Eksik",
        Stat3Class = markaSayisi > 0 ? "df-tile-stat-val" : "df-badge-pulse"
    });

    kartlar.Add(new DashboardTile
    {
        Title = "Şubelerim",
        Url = "/ys-panel/subeler",
        Icon = "bi bi-building-gear",
        Done = subeSayisi,
        Total = subeSayisi,
        Subtitle = "Tanımlı / Toplam",
        Stat1Label = "Toplam",
        Stat1Value = subeSayisi.ToString(),
        Stat2Label = "Eksik",
        Stat2Value = subeSayisi > 0 ? "0" : "1",
        Stat2Class = subeSayisi > 0 ? "df-tile-stat-val" : "df-badge-pulse",
        Stat3Label = "Durum",
        Stat3Value = subeSayisi > 0 ? "Aktif" : "Eksik",
        Stat3Class = subeSayisi > 0 ? "df-tile-stat-val" : "df-badge-pulse"
    });

    if (toplam > 0 || buAy > 0 || gecerliBelgeler.Count > 0)
    {
        kartlar.Add(new DashboardTile
        {
            Title = "Raporlarım",
            Url = "/ys-panel/raporlar",
            Icon = "bi bi-bar-chart-line",
            Done = toplam,
            Total = toplam,
            Subtitle = "Kayıt / Toplam",
            Stat1Label = "Toplam",
            Stat1Value = toplam.ToString(),
            Stat2Label = "Bu Ay",
            Stat2Value = buAy.ToString(),
            Stat3Label = "Belge",
            Stat3Value = gecerliBelgeler.Count.ToString()
        });
    }
}

@functions {
    private sealed class DashboardTile
    {
        public string Title { get; set; } = "";
        public string Url { get; set; } = "";
        public string Icon { get; set; } = "";
        public int Done { get; set; }
        public int Total { get; set; }
        public string Subtitle { get; set; } = "";
        public string Stat1Label { get; set; } = "";
        public string Stat1Value { get; set; } = "";
        public string Stat1Class { get; set; } = "df-tile-stat-val";
        public string Stat2Label { get; set; } = "";
        public string Stat2Value { get; set; } = "";
        public string Stat2Class { get; set; } = "df-tile-stat-val";
        public string Stat3Label { get; set; } = "";
        public string Stat3Value { get; set; } = "";
        public string Stat3Class { get; set; } = "df-tile-stat-val";
        public bool Featured { get; set; }
    }

    private static int RingPct(int done, int total)
    {
        if (total <= 0) return 0;
        return Math.Clamp((int)Math.Round(done * 100.0 / total), 0, 100);
    }

    private static string RingOffset(int done, int total)
    {
        const double length = 175.9;
        var pct = RingPct(done, total);
        return (length - (length * pct / 100.0)).ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);
    }
}

<div class="df-dashboard">
    @if (kurulumKilitli)
    {
        <div class="df-alert df-alert-danger">
            İlk kurulum tamamlanmadan işlem yapılamaz. Eksik adımlar: @(ilkKurulumEksikler.Count > 0 ? string.Join(", ", ilkKurulumEksikler) : "Kurulum bilgileri").
            <a class="df-btn df-btn-danger df-btn-sm" href="/ys-panel/ilk-kurulum" style="margin-left:10px">Tamamla</a>
        </div>
    }

    <div class="section-label">
        <i class="bi bi-lightning-charge-fill"></i>
        Bekleyen İşlemlerim
    </div>

    <div class="df-approval-grid" id="approval-grid">
        @foreach (var kart in kartlar)
        {
            <a class="df-atile @(kart.Featured ? "is-featured" : "")" href="@kart.Url">
                <div class="df-atile-top">
                    <div class="df-atile-icon"><i class="@kart.Icon"></i></div>
                    <div>
                        <div class="df-atile-name">@kart.Title</div>
                        <span class="df-atile-link">Sayfaya git <i class="bi bi-arrow-right"></i></span>
                    </div>
                </div>
                <div class="df-ring-wrap">
                    <div class="df-ring-container">
                        <svg class="df-ring-svg" width="72" height="72" viewBox="0 0 72 72">
                            <circle class="df-ring-bg" cx="36" cy="36" r="28"></circle>
                            <circle class="df-ring-fill" cx="36" cy="36" r="28" stroke-dasharray="175.9" stroke-dashoffset="@RingOffset(kart.Done, kart.Total)"></circle>
                        </svg>
                        <div class="df-ring-center"><span class="df-ring-pct">@RingPct(kart.Done, kart.Total)%</span></div>
                    </div>
                    <div class="df-ring-meta"><span class="df-ring-sub">@kart.Subtitle</span></div>
                </div>
                <div class="df-tile-stats">
                    <div class="df-tile-stat"><span class="df-tile-stat-lbl">@kart.Stat1Label</span><span class="@kart.Stat1Class">@kart.Stat1Value</span></div>
                    <div class="df-tile-stat"><span class="df-tile-stat-lbl">@kart.Stat2Label</span><span class="@kart.Stat2Class">@kart.Stat2Value</span></div>
                    <div class="df-tile-stat"><span class="df-tile-stat-lbl">@kart.Stat3Label</span><span class="@kart.Stat3Class">@kart.Stat3Value</span></div>
                </div>
            </a>
        }
    </div>

    <div class="section-label">
        <i class="bi bi-bar-chart-line-fill"></i>
        İstatistikler & Takvim
    </div>

    <div class="stats-grid">
        <div class="stats-card">
            <div class="stats-card-header">
                <h2><i class="bi bi-bar-chart-line"></i> Firma İstatistikleri</h2>
                <div class="df-tab-pills mb-0">
                    <button class="df-tab-pill-item active" type="button" data-panel-target="panel-islem">İşlemler</button>
                    <button class="df-tab-pill-item" type="button" data-panel-target="panel-belge">Belgeler</button>
                </div>
            </div>

            <div class="panel active" id="panel-islem">
                <div class="stats-body split">
                    <div class="user-pane">
                        <div class="user-row">
                            <div class="user-ava">@basHarf</div>
                            <div>
                                <div class="user-lbl">Kullanıcı</div>
                                <div class="user-name">@adSoyad</div>
                            </div>
                        </div>
                        <div class="kpi-grid">
                            <div class="kpi-tile"><div class="kpi-icon"><i class="bi bi-plus-lg"></i></div><div class="kpi-n">@toplam</div><div class="kpi-lbl">Toplam İşlem</div></div>
                            <div class="kpi-tile"><div class="kpi-icon ic-green"><i class="bi bi-send-check"></i></div><div class="kpi-n">@buAy</div><div class="kpi-lbl">Bu Ay</div></div>
                            <div class="kpi-tile"><div class="kpi-icon ic-warn"><i class="bi bi-hourglass-split"></i></div><div class="kpi-n">@bekleyenSon</div><div class="kpi-lbl">Bekleyen</div></div>
                            <div class="kpi-tile"><div class="kpi-icon ic-teal"><i class="bi bi-check-circle"></i></div><div class="kpi-n">@tamamlananSon</div><div class="kpi-lbl">Tamamlanan</div></div>
                        </div>
                    </div>
                    <div class="chart-pane">
                        @if (!sonIslemler.Any())
                        {
                            <div class="df-empty">
                                <div class="df-empty-icon"><i class="bi bi-bag-check"></i></div>
                                <div class="df-empty-title">Veri Bulunamadı.</div>
                                <p class="df-empty-text">Devreye alma işlemi oluştuğunda burada görüntülenecektir.</p>
                            </div>
                        }
                        else
                        {
                            <div class="dash-list">
                                @foreach (var islem in sonIslemler.Take(4))
                                {
                                    var durumYazi = islem.Durum == 1 ? "Tamamlandı" : islem.Durum == 2 ? "İptal" : "Bekliyor";
                                    <div class="dash-list-item">
                                        <div class="dash-list-title">@(islem.MusteriAdi ?? islem.TesistatNo ?? "-")</div>
                                        <div class="dash-list-sub">@durumYazi - @(islem.Marka?.MarkaAdi ?? islem.CihazMarka ?? "-")</div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="panel" id="panel-belge">
                <div class="stats-body split">
                    <div class="user-pane">
                        <div class="user-row">
                            <div class="user-ava">@basHarf</div>
                            <div>
                                <div class="user-lbl">Firma</div>
                                <div class="user-name">@(firma?.FirmaAdi ?? "Yetkili Servis")</div>
                            </div>
                        </div>
                        <div class="kpi-grid">
                            <div class="kpi-tile"><div class="kpi-icon"><i class="bi bi-file-earmark-text"></i></div><div class="kpi-n">@tumBelgeler.Count</div><div class="kpi-lbl">Toplam Belge</div></div>
                            <div class="kpi-tile"><div class="kpi-icon ic-green"><i class="bi bi-check-circle"></i></div><div class="kpi-n">@gecerliBelgeler.Count</div><div class="kpi-lbl">Geçerli</div></div>
                            <div class="kpi-tile"><div class="kpi-icon ic-warn"><i class="bi bi-hourglass-split"></i></div><div class="kpi-n">@bekleyenBelge</div><div class="kpi-lbl">Bekleyen</div></div>
                            <div class="kpi-tile"><div class="kpi-icon ic-purple"><i class="bi bi-x-circle"></i></div><div class="kpi-n">@reddedilenBelge</div><div class="kpi-lbl">Reddedilen</div></div>
                        </div>
                    </div>
                    <div class="chart-pane">
                        @if (!tumBelgeler.Any())
                        {
                            <div class="df-empty">
                                <div class="df-empty-icon"><i class="bi bi-file-earmark-text"></i></div>
                                <div class="df-empty-title">Veri Bulunamadı.</div>
                                <p class="df-empty-text">Yetki belgesi yüklendiğinde burada görüntülenecektir.</p>
                            </div>
                        }
                        else
                        {
                            <div class="dash-list">
                                @foreach (var belge in tumBelgeler.Take(4))
                                {
                                    var durumYazi = belge.Durum == 1 ? "Onaylandı" : belge.Durum == 2 ? "Reddedildi" : "Bekliyor";
                                    <div class="dash-list-item">
                                        <div class="dash-list-title">@durumYazi</div>
                                        <div class="dash-list-sub">@belge.OlusturmaTarihi.ToString("dd.MM.yyyy") - @belge.YetkiBelgesiBitisTarihi.ToString("dd.MM.yyyy")</div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="stats-card calendar-card">
            <div class="stats-card-header">
                <h2><i class="bi bi-calendar-check"></i> Takvim & Duyurular</h2>
            </div>
            <div class="stats-body split">
                <div class="user-pane">
                    <div class="mini-calendar">
                        <div class="mini-calendar-head">
                            <span>@ay.ToString("MMMM", new System.Globalization.CultureInfo("tr-TR"))</span>
                            <span>@ay.Year</span>
                        </div>
                        <div class="mini-calendar-grid">
                            @foreach (var gun in new[] { "Pzt", "Sal", "Çar", "Per", "Cum", "Cmt", "Paz" })
                            {
                                <div class="mini-calendar-cell weekday">@gun</div>
                            }
                            @for (var i = 0; i < takvimHucre; i++)
                            {
                                var gunNo = i - ilkGunOffset + 1;
                                if (gunNo < 1)
                                {
                                    <div class="mini-calendar-cell muted">@(oncekiAyGunSayisi + gunNo)</div>
                                }
                                else if (gunNo > ayGunSayisi)
                                {
                                    <div class="mini-calendar-cell muted">@(gunNo - ayGunSayisi)</div>
                                }
                                else
                                {
                                    var hucreTarih = new DateTime(ay.Year, ay.Month, gunNo);
                                    <div class="mini-calendar-cell @(hucreTarih.Date == bugun ? "today" : "")">@gunNo</div>
                                }
                            }
                        </div>
                    </div>
                </div>
                <div class="chart-pane">
                    @if (!bildirimler.Any())
                    {
                        <div class="df-empty">
                            <div class="df-empty-icon"><i class="bi bi-bell"></i></div>
                            <div class="df-empty-title">Duyuru bulunmamaktadır.</div>
                            <p class="df-empty-text">Güncel bir duyuru yayınlandığında burada görüntülenecektir.</p>
                        </div>
                    }
                    else
                    {
                        <div class="dash-list">
                            @foreach (var bildirim in bildirimler.Take(4))
                            {
                                <div class="dash-list-item">
                                    <div class="dash-list-title">@bildirim</div>
                                    <div class="dash-list-sub">Sistem bildirimi</div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    document.querySelectorAll('.df-dashboard [data-panel-target]').forEach(function (button) {
        button.addEventListener('click', function () {
            var card = button.closest('.stats-card');
            if (!card) return;
            card.querySelectorAll('[data-panel-target]').forEach(function (item) { item.classList.remove('active'); });
            card.querySelectorAll('.panel').forEach(function (panel) { panel.classList.remove('active'); });
            button.classList.add('active');
            var panel = card.querySelector('#' + button.getAttribute('data-panel-target'));
            if (panel) panel.classList.add('active');
        });
    });
})();
</script>
}
