@{
    var kullanici = ViewBag.Kullanici as YetkiliServisGazAcma.Entities.AppKullanici;
ViewData["Title"] = "Yetkili Servis Paneli";
    ViewData["PanelTitle"] = ViewData["Title"];
    ViewData["PanelSubtitle"] = "Yetkili Servis";
    ViewData["ActiveMenu"] = "Dashboard";
    Layout = "~/Views/Shared/_PanelLayout.cshtml";
    var firma = ViewBag.Firma as YetkiliServisGazAcma.Entities.Ys_Firma;
    var sonIslemler = ViewBag.SonIslemler as List<YetkiliServisGazAcma.Entities.Ys_DevreyeAlma>
        ?? new List<YetkiliServisGazAcma.Entities.Ys_DevreyeAlma>();
    var buAy = ViewBag.BuAy as int? ?? 0;
    var toplam = ViewBag.Toplam as int? ?? 0;
    var bugun = DateTime.Now.Date;
    var onayliSertifikalar = firma?.Sertifikalar?
        .Where(x => x.Durum == 1 && !x.SilindiMi)
        .OrderBy(x => x.SertifikaBitisTarihi)
        .ToList() ?? new List<YetkiliServisGazAcma.Entities.Ys_Sertifika>();
    var gecerliSertifikalar = onayliSertifikalar
        .Where(x => (!x.SertifikaBaslangicTarihi.HasValue || x.SertifikaBaslangicTarihi.Value.Date <= bugun)
            && x.SertifikaBitisTarihi.Date >= bugun)
        .OrderBy(x => x.SertifikaBitisTarihi)
        .ToList();
    var enYakin = gecerliSertifikalar.FirstOrDefault() ?? onayliSertifikalar.FirstOrDefault();
    var enYakinKalan = enYakin != null
        ? (enYakin.SertifikaBitisTarihi.Date - bugun).Days
        : (int?)null;
    string adSoyad = kullanici?.AdSoyad ?? firma?.YetkiliKisi ?? "Yetkili Servis";
    string basHarf = !string.IsNullOrEmpty(adSoyad) ? adSoyad.Substring(0, 1).ToUpper() : "Y";
    var markaSayisi = firma?.FirmaMarkalar?.Count(x => !x.SilindiMi) ?? 0;
    var ilkKurulumZorunlu = ViewBag.IlkKurulumZorunlu as bool? ?? false;
    var ilkKurulumTamamlandi = ViewBag.IlkKurulumTamamlandi as bool? ?? true;
    var ilkKurulumEksikler = ViewBag.IlkKurulumEksikler as List<string> ?? new List<string>();
    var kurulumKilitli = ilkKurulumZorunlu && !ilkKurulumTamamlandi;
}

@section Styles {
    <style>
:root {
            --primary: #3bb7e8;
            --primary-dark: #1e8db8;
            --success: #4caf7d;
            --bg: #eef2f5;
            --nav: #0f172a;
            --text: #1b2430;
            --muted: #607080;
            --card: #ffffff;
            --border: #d3dde6;
            --accent: #ecf2f6;
        }
.content { padding: 28px 32px 56px; }
        .hero { background: linear-gradient(125deg, #ffffff 0%, #f4fbff 48%, #eef7f2 100%); border: 1px solid var(--border); border-radius: 18px; padding: 24px; display: flex; align-items: center; justify-content: space-between; gap: 16px; box-shadow: 0 16px 34px rgba(15, 23, 42, 0.08); position: relative; overflow: hidden; }
        .hero::before { content:""; position:absolute; left:-28px; bottom:-44px; width:170px; height:170px; border-radius:50%; background: radial-gradient(circle, rgba(59,183,232,0.2), transparent 68%); }
        .hero::after { content:""; position:absolute; right:-36px; top:-30px; width:150px; height:150px; border-radius:50%; background: radial-gradient(circle, rgba(76,175,125,0.18), transparent 65%); }
        .hero-title { font-size: 21px; font-weight: 800; color: #0f2b3c; position: relative; z-index: 1; }
        .hero-sub { color: var(--muted); margin-top: 6px; font-size: 13px; position: relative; z-index: 1; }
        .hero-badge { display: inline-flex; align-items: center; gap: 8px; padding: 8px 13px; border-radius: 999px; background: #eaf8ff; border: 1px solid #b8e8fb; color: #0d79a0; font-size: 12px; font-weight: 700; position: relative; z-index: 1; }
        .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-top: 18px; }
        .stat { background: linear-gradient(180deg, #ffffff 0%, #f6f9fb 100%); border: 1.5px solid #d3dde6; border-radius: 14px; padding: 16px; display: flex; align-items: center; gap: 12px; box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08); transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease; position: relative; overflow: hidden; }
        .stat::before { content: ""; position: absolute; left: 0; top: 0; width: 4px; height: 100%; background: linear-gradient(180deg, var(--primary), var(--success)); }
        .stat:hover { transform: translateY(-4px); box-shadow: 0 16px 30px rgba(15, 23, 42, 0.14); border-color: #b7c9d8; }
        .stat-icon { width: 42px; height: 42px; border-radius: 12px; display: flex; align-items: center; justify-content: center; background: var(--accent); color: var(--primary); font-size: 18px; }
        .stat-val { font-size: 20px; font-weight: 800; color: #122536; }
        .stat-lbl { font-size: 12px; color: var(--muted); margin-top: 2px; }
        .grid-2 { display: grid; grid-template-columns: 1.2fr 1fr; gap: 16px; margin-top: 18px; }
        .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 18px; }
        .card { background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%); border: 1.5px solid #d3dde6; border-radius: 14px; overflow: hidden; box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08); transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease; }
        .card:hover { transform: translateY(-3px); box-shadow: 0 18px 32px rgba(15, 23, 42, 0.12); border-color: #b7c9d8; }
        .card-head { padding: 14px 18px; font-size: 14px; font-weight: 800; color: #172635; border-bottom: 1px solid #e0e8ef; display: flex; align-items: center; gap: 8px; background: linear-gradient(90deg, #f3f7fa, #ffffff); }
        .card-body { padding: 16px 18px; }
        .pill { display: inline-flex; align-items: center; gap: 8px; padding: 7px 12px; border-radius: 999px; font-size: 12px; font-weight: 700; background: var(--accent); color: var(--primary-dark); }
        .warn { background: #fff4e5; color: #9b6a00; }
        .success { background: #e6fff4; color: #1e7e57; }
        .danger { background: #ffecec; color: #b42318; }
        .muted { background: #f3f6f9; color: #566070; }
        .table { width: 100%; border-collapse: collapse; }
        .table th, .table td { padding: 10px 8px; border-bottom: 1px solid #f0f0f0; text-align: left; font-size: 13px; }
        .table thead { background: #f9fbfd; }
        .table th { font-size: 11px; color: #7a8796; text-transform: uppercase; letter-spacing: .04em; }
        .status { padding: 4px 8px; border-radius: 999px; font-size: 11px; font-weight: 700; background: var(--accent); color: var(--primary-dark); display: inline-block; }
        .status-ok { background: #e6fff4; color: #1e7e57; }
        .quick-card { background: linear-gradient(180deg, #ffffff 0%, #f6f9fb 100%); border: 1.5px solid #d3dde6; border-radius: 14px; padding: 16px; display: flex; align-items: center; gap: 12px; box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08); text-decoration: none; color: inherit; transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease; }
        .quick-card:hover { transform: translateY(-4px); box-shadow: 0 18px 30px rgba(15, 23, 42, 0.14); border-color: #b7c9d8; }
        .quick-icon { width: 44px; height: 44px; border-radius: 12px; display: inline-flex; align-items: center; justify-content: center; background: var(--accent); color: var(--primary); font-size: 18px; }
        .quick-title { font-weight: 800; font-size: 14px; color: #122536; }
        .quick-sub { font-size: 12px; color: var(--muted); margin-top: 2px; }
        .cert-list { display: flex; flex-direction: column; gap: 8px; }
        .cert-row { display: flex; align-items: center; justify-content: space-between; padding: 10px 12px; border: 1px solid var(--border); border-radius: 10px; background: #fafbfd; }
        .cert-title { font-size: 13px; font-weight: 700; color: #1b2430; }
        .cert-dates { font-size: 12px; color: var(--muted); }
        .setup-alert { background: linear-gradient(120deg, #fff5f5, #fff9ec); border: 1px solid #f6c7c7; border-left: 6px solid #d94444; border-radius: 14px; padding: 18px 20px; margin-bottom: 16px; box-shadow: 0 8px 24px rgba(217,68,68,0.08); }
        .setup-title { font-size: 16px; font-weight: 800; color: #7a1111; margin-bottom: 8px; }
        .setup-sub { font-size: 13px; color: #7b3a3a; margin-bottom: 10px; }
        .setup-list { margin: 0 0 12px 18px; color: #6f2f2f; font-size: 13px; }
        .setup-btn { display: inline-block; text-decoration: none; background: #d94444; color: #fff; padding: 9px 14px; border-radius: 8px; font-size: 13px; font-weight: 700; }
        @@media (max-width: 1100px) {
            .stats { grid-template-columns: repeat(2, 1fr); }
            .grid-2 { grid-template-columns: 1fr; }
            .grid-3 { grid-template-columns: 1fr; }
        }
        @@media (max-width: 800px) {
            .sidebar { position: static; width: 100%; height: auto; }
            .main { margin-left: 0; }
        }
    </style>
}

@if (kurulumKilitli)
{
    <div class="setup-alert">
        <div class="setup-title">İlk Kurulum Tamamlanmadan İşlem Yapılamaz</div>
        <div class="setup-sub">Bu hesap admin tarafından açıldığı için ilk girişte aşağıdaki adımların tamamı zorunludur:</div>
        <ul class="setup-list">
            <li>Şube kaydı</li>
            <li>Marka seçimi</li>
            <li>Kategori seçimi</li>
            <li>Yetki belgesi yükleme</li>
        </ul>
        @if (ilkKurulumEksikler.Count > 0)
        {
            <div class="setup-sub">Eksik adımlar: @string.Join(", ", ilkKurulumEksikler)</div>
        }
        <a class="setup-btn" href="/ys-panel/ilk-kurulum">İlk Kurulumu Tamamla</a>
    </div>
}
<div class="hero">
    <div>
        <div class="hero-title">Hoş Geldiniz, @adSoyad</div>
        <div class="hero-sub">@firma?.FirmaAdi — @firma?.Sirket?.SirketAdi</div>
    </div>
    <div class="hero-badge">📌 Güncel Firma Durumu</div>
</div>
<div class="stats">
    <div class="stat">
        <div class="stat-icon">&#128203;</div>
        <div>
            <div class="stat-val">@markaSayisi</div>
            <div class="stat-lbl">Yetkili Marka</div>
        </div>
    </div>
    <div class="stat">
        <div class="stat-icon">&#128295;</div>
        <div>
            <div class="stat-val">@buAy</div>
            <div class="stat-lbl">Bu Ay Devreye Alınan</div>
        </div>
    </div>
    <div class="stat">
        <div class="stat-icon">&#128202;</div>
        <div>
            <div class="stat-val">@toplam</div>
            <div class="stat-lbl">Toplam İşlem</div>
        </div>
    </div>
    <div class="stat">
        <div class="stat-icon">&#128196;</div>
        <div>
            <div class="stat-val">@(gecerliSertifikalar.Any() ? "Geçerli" : ((onayliSertifikalar.Any()) ? "Süresi Doldu" : "Yok"))</div>
            <div class="stat-lbl">Yetki Belgesi Durumu</div>
        </div>
    </div>
</div>
<div class="grid-2">
    <div class="card">
        <div class="card-head">⚡ Hızlı Özet</div>
        <div class="card-body">
            <div class="pill success">Yetkili Marka: @markaSayisi</div>
            <div style="height:10px;"></div>
            <div class="pill">Onaylı Yetki Belgesi Sayısı: @onayliSertifikalar.Count</div>
            @if (enYakin != null)
            {
                <div style="height:8px;"></div>
                if ((enYakinKalan ?? 0) < 0)
                {
                    <div class="pill danger">En yakın yetki belgesi süresi doldu</div>
                }
                else
                {
                    <div class="pill warn">En yakın bitiş: @string.Format("{0:dd.MM.yyyy}", enYakin.SertifikaBitisTarihi) (@(enYakinKalan ?? 0) gün)</div>
                }
            }
            <div style="height:16px;"></div>
            <div class="hero-sub">Bildirimleri sağ üst bildirim ikonundan takip edebilirsiniz.</div>
        </div>
    </div>
    <div class="card">
        <div class="card-head">📄 Onaylı Yetki Belgesilar</div>
        <div class="card-body">
            @if (onayliSertifikalar.Count == 0)
            {
                <div class="pill muted">Onaylı yetki belgesi bulunamadı.</div>
            }
            else
            {
                <div class="cert-list">
                    @foreach (var s in onayliSertifikalar)
                    {
                        <div class="cert-row">
                            <div>
                                <div class="cert-title">Yetki Belgesi</div>
                                <div class="cert-dates">@string.Format("{0:dd.MM.yyyy}", s.SertifikaBaslangicTarihi ?? s.OlusturmaTarihi) - @string.Format("{0:dd.MM.yyyy}", s.SertifikaBitisTarihi)</div>
                            </div>
                            <span class="pill success">Onaylı</span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
<div class="card" style="margin-top:16px;">
    <div class="card-head">🧾 Son İşlemler</div>
    <div class="card-body">
        <table class="table">
            <thead>
                <tr>
                    <th>Müşteri</th>
                    <th>Marka</th>
                    <th>Tarih</th>
                    <th>Durum</th>
                </tr>
            </thead>
            <tbody>
            @if (sonIslemler.Count == 0)
            {
                <tr><td colspan="4">Kayıt bulunamadı.</td></tr>
            }
            else
            {
                foreach (var i in sonIslemler)
                {
                    <tr>
                        <td>@(i.MusteriAdi ?? "-")</td>
                        <td>@(i.Marka?.MarkaAdi ?? i.CihazMarka ?? "-")</td>
                        <td>@string.Format("{0:dd.MM.yyyy}", i.OlusturmaTarihi)</td>
                        <td><span class="status @(i.Durum == 1 ? "status-ok" : "")">@(i.Durum == 1 ? "Tamamlandı" : "Bekliyor")</span></td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>
<div class="grid-3">
    <a class="quick-card" href="@(kurulumKilitli ? "/ys-panel/ilk-kurulum" : "/ys-devreyeal")">
        <div class="quick-icon">&#128295;</div>
        <div>
            <div class="quick-title">@(kurulumKilitli ? "İlk Kurulum" : "Cihaz Devreye Al")</div>
            <div class="quick-sub">@(kurulumKilitli ? "Önce zorunlu alanları tamamlayın" : "Yeni işlem başlat")</div>
        </div>
    </a>
    <a class="quick-card" href="/ys-yetki-belgesi">
        <div class="quick-icon">&#128196;</div>
        <div>
            <div class="quick-title">Yetki Belgem</div>
            <div class="quick-sub">Yükle ve takip et</div>
        </div>
    </a>
    <a class="quick-card" href="/ys-panel/raporlar">
        <div class="quick-icon">&#128202;</div>
        <div>
            <div class="quick-title">Raporlarım</div>
            <div class="quick-sub">Filtreli rapor al</div>
        </div>
    </a>
</div>
