@model List<YetkiliServisGazAcma.Entities.Ys_YetkiBelgesi>
@using YetkiliServisGazAcma.Entities
@{
    ViewData["Title"] = "Yetki Belgesi Onayları";
    ViewData["PanelTitle"] = "Yetki Belgesi Onayları";
    ViewData["PanelSubtitle"] = "Yetki Belgesi";
    ViewData["ActiveMenu"] = "OnayBekleyenler";
    Layout = "~/Views/Shared/_PanelLayout.cshtml";

    var bekleyenler = Model ?? new List<Ys_YetkiBelgesi>();
    var onaylananlar = ViewBag.Onaylananlar as List<Ys_YetkiBelgesi> ?? new List<Ys_YetkiBelgesi>();
    var reddedilenler = ViewBag.Reddedilenler as List<Ys_YetkiBelgesi> ?? new List<Ys_YetkiBelgesi>();
}

@if (TempData["Basarili"] != null)
{
    <div class="df-alert df-alert-success">@TempData["Basarili"]</div>
}
@if (TempData["Hata"] != null)
{
    <div class="df-alert df-alert-danger">@TempData["Hata"]</div>
}

<div class="section-label">
    <i class="bi bi-journal-text"></i>
    Yetki belgesi değerlendirme
</div>

<div class="df-page-panel approval-panels">
    <div class="df-panel-head">
        <div>
            <div class="df-panel-title">Yetki Belgesi Onay Listesi</div>
            <div class="df-panel-subtitle">Onayda bekleyenler, onaylananlar ve reddedilenler</div>
        </div>
        <div class="df-status-tabs" data-approval-tabs>
            <button type="button" class="df-tab active" data-target="bekleyen">Onayda Bekleyenler (@bekleyenler.Count)</button>
            <button type="button" class="df-tab" data-target="onaylanan">Onaylananlar (@onaylananlar.Count)</button>
            <button type="button" class="df-tab" data-target="reddedilen">Reddedilenler (@reddedilenler.Count)</button>
        </div>
    </div>

    <div data-panel="bekleyen" class="active">
        @await Html.PartialAsync("~/Views/Shared/_YetkiBelgesiOnayTable.cshtml", new Tuple<List<Ys_YetkiBelgesi>, string, string>(bekleyenler, "bekleyen", "admin"))
    </div>
    <div data-panel="onaylanan">
        @await Html.PartialAsync("~/Views/Shared/_YetkiBelgesiOnayTable.cshtml", new Tuple<List<Ys_YetkiBelgesi>, string, string>(onaylananlar, "onaylanan", "admin"))
    </div>
    <div data-panel="reddedilen">
        @await Html.PartialAsync("~/Views/Shared/_YetkiBelgesiOnayTable.cshtml", new Tuple<List<Ys_YetkiBelgesi>, string, string>(reddedilenler, "reddedilen", "admin"))
    </div>
</div>

@section Scripts {
<script>
(function () {
    var tabs = document.querySelector('[data-approval-tabs]');
    if (!tabs) return;

    tabs.addEventListener('click', function (event) {
        var btn = event.target.closest('[data-target]');
        if (!btn) return;
        var target = btn.getAttribute('data-target');

        tabs.querySelectorAll('[data-target]').forEach(function (item) {
            item.classList.toggle('active', item === btn);
        });

        document.querySelectorAll('.approval-panels [data-panel]').forEach(function (panel) {
            panel.classList.toggle('active', panel.getAttribute('data-panel') === target);
        });
    });
})();
</script>
}
