@{
    var path = Context?.Request?.Path.ToString().ToLowerInvariant() ?? "";
    var panelTipi =
        path.Contains("/adminpanel") || path.Contains("/dagitimsirket") || path.Contains("/marka")
            ? "admin"
            : path.Contains("/personel-panel")
                ? "personel"
                : "ys";

    var onayBekleyen = ViewBag.OnayBekleyen as int? ?? 0;
    var suresiBitecek = ViewBag.SuresiBitecek as int? ?? 0;
    var bildirimSayisi = ViewBag.BildirimSayisi as int?;
    var bildirimler = ViewBag.Bildirimler as IEnumerable<string>;
    var aktifSirketler = (ViewBag.AktifSirketler as IEnumerable<YetkiliServisGazAcma.Entities.Dag_Sirket>)?.ToList()
        ?? new List<YetkiliServisGazAcma.Entities.Dag_Sirket>();
    int? aktifSirketId = ViewBag.AktifSirketId as int?;
    var genelSistemAdminMi = ViewBag.GenelSistemAdminMi as bool? ?? false;
    var sirketSeciciGoster = Context?.User?.Identity?.IsAuthenticated == true
        && (aktifSirketler.Count > 1 || genelSistemAdminMi);
    var returnUrl = (Context?.Request?.Path.ToString() ?? "/")
        + (Context?.Request?.QueryString.ToString() ?? "");

    var onayPath = panelTipi == "personel" ? "/personel-panel/onay-bekleyenler" : "/AdminPanel/onay-bekleyenler";
    var surePath = panelTipi == "ys" ? "/ys-yetki-belgesi" : "/AdminPanel/yetki-belgesi-uyarilari";
    var satirlar = new List<(string Title, string Text, string Time, string Icon, string Tone, string Path, int Type)>();

    if (bildirimler != null)
    {
        foreach (var b in bildirimler.Where(x => !string.IsNullOrWhiteSpace(x)))
        {
            satirlar.Add(("Sistem Bildirimi", b!, "Şimdi", "bi-chat-right", "df-notif-icon-primary", panelTipi == "ys" ? "/ys-panel" : onayPath, 3));
        }
    }

    if (onayBekleyen > 0)
    {
        satirlar.Add(("Yetki Belgesi Onayı", $"{onayBekleyen} adet yetki belgesi onay bekliyor.", "Bekleyen işlem", "bi-journal-text", "df-notif-icon-warning", onayPath, 1));
    }

    if (suresiBitecek > 0)
    {
        satirlar.Add(("Süre Uyarısı", $"{suresiBitecek} adet yetki belgesi 30 gün içinde bitiyor.", "Yaklaşan bitiş", "bi-clock", "df-notif-icon-danger", surePath, 2));
    }

    var toplam = bildirimSayisi ?? satirlar.Count;
    var toplamYazi = toplam > 99 ? "99+" : toplam.ToString();
}
@if (sirketSeciciGoster)
{
    <div class="df-dropdown">
        <button class="df-nb-btn" id="companyBtn" type="button" data-dropdown-toggle="" title="Şirket değiştir">
            <i class="bi bi-building-gear"></i>
        </button>

        <div class="df-dropdown-menu df-nb-dropdown-wide" id="companyMenu">
            <div class="df-dropdown-header">Şirket Seç</div>
            <div class="df-nb-account-list">
                @if (genelSistemAdminMi)
                {
                    var tumAktif = !aktifSirketId.HasValue;
                    <form method="post" action="/panel/sirket-sec" class="df-company-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="sirketId" value="0" />
                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                        <button type="submit" class="df-nb-account-item @(tumAktif ? "active" : "")">
                            <div class="df-nb-account-avatar df-avatar-primary"><span>TŞ</span></div>
                            <div class="df-nb-account-info">
                                <div class="df-nb-account-name">Tüm Şirketler</div>
                                <div class="df-nb-account-sub">Genel yönetim görünümü</div>
                            </div>
                            @if (tumAktif)
                            {
                                <i class="bi bi-check-circle-fill df-nb-account-check"></i>
                            }
                        </button>
                    </form>
                }

                @foreach (var sirket in aktifSirketler)
                {
                    var aktif = aktifSirketId == sirket.Id;
                    var ad = sirket.SirketAdi ?? "Şirket";
                    var parcalar = ad.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                    var harfler = string.Concat(parcalar.Take(2).Select(x => x.Substring(0, 1))).ToUpper(new System.Globalization.CultureInfo("tr-TR"));
                    if (string.IsNullOrWhiteSpace(harfler)) harfler = "Ş";

                    <form method="post" action="/panel/sirket-sec" class="df-company-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="sirketId" value="@sirket.Id" />
                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                        <button type="submit" class="df-nb-account-item @(aktif ? "active" : "")">
                            <div class="df-nb-account-avatar df-avatar-primary"><span>@harfler</span></div>
                            <div class="df-nb-account-info">
                                <div class="df-nb-account-name">@ad</div>
                                <div class="df-nb-account-sub">@(aktif ? "Aktif şirket" : "")</div>
                            </div>
                            @if (aktif)
                            {
                                <i class="bi bi-check-circle-fill df-nb-account-check"></i>
                            }
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
}

<div class="df-dropdown">
    <button class="df-nb-btn" id="notifBtn" type="button" data-dropdown-toggle="" aria-label="Bildirimler">
        <i class="bi bi-bell"></i>
        @if (toplam > 0)
        {
            <span class="df-nb-badge red-bildirim-count" data-count="@toplam">@toplamYazi</span>
        }
    </button>

    <div class="df-dropdown-menu df-nb-dropdown-wide" id="notifMenu" style="min-width:360px">
        <div class="df-notif-header">
            <span class="df-notif-title">
                Bildirimler
                @if (toplam > 0)
                {
                    <span class="df-badge df-badge-primary df-badge-sm noti-quantity">
                        <span class="bildirim-count">@toplamYazi</span> okunmamış
                    </span>
                }
            </span>

            @if (toplam > 0)
            {
                <button type="button" class="df-notif-mark-all btn-bildirim-all">Tümünü okundu yap</button>
            }
        </div>

        <div class="df-notif-filter" id="filterContainer">
            <button type="button" class="df-btn df-btn-sm active df-btn-primary" data-filter="all">Tümü</button>
            <button type="button" class="df-btn df-btn-sm df-btn-secondary" data-filter="1">Onay</button>
            <button type="button" class="df-btn df-btn-sm df-btn-secondary" data-filter="2">Süre</button>
            <button type="button" class="df-btn df-btn-sm df-btn-secondary" data-filter="3">Sistem</button>
        </div>

        <div class="df-notif-list notification-body">
            @if (!satirlar.Any())
            {
                <div class="df-empty df-empty-compact">
                    <div class="df-empty-title">Yeni bildirim yok.</div>
                    <p class="df-empty-text">Bekleyen işlem oluştuğunda burada görünecek.</p>
                </div>
            }
            else
            {
                foreach (var item in satirlar)
                {
                    <div class="df-notif-item notification-item" data-type="@item.Type">
                        <div class="df-notif-icon @item.Tone">
                            <i class="bi @item.Icon"></i>
                        </div>
                        <a class="df-notif-body js-notif-redirect" href="@item.Path">
                            <div class="df-notif-text">@item.Title</div>
                            <div class="df-notif-time"><i class="bi bi-chat-right"></i> @item.Text</div>
                            <div class="df-notif-time fw-normal"><i class="bi bi-clock"></i> @item.Time</div>
                        </a>
                    </div>
                }
            }
        </div>

        <div class="df-notif-footer"></div>
    </div>
</div>
