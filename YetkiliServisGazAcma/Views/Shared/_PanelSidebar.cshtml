            <a class="@("nav-item" + Active("DevreyeAlmalar", "/AdminPanel/devreyealmalar"))" href="/AdminPanel/devreyealmalar">
                <span class="nav-ico">&#128295;</span> Devreye Almalar
            </a>
            <a class="@("nav-item" + Active("Raporlar", "/AdminPanel/raporlar"))" href="/AdminPanel/raporlar">
                <span class="nav-ico">&#128202;</span> Raporlar
            </a>
            <a class="@("nav-item" + Active("YetkiliServisler", "/AdminPanel/yetkiliservisler"))" href="/AdminPanel/yetkiliservisler">
                <span class="nav-ico">&#128295;</span> Yetkili Servisler
            </a>
            <a class="@("nav-item" + Active("Subeler", "/AdminPanel/subeler"))" href="/AdminPanel/subeler">
                <span class="nav-ico">&#127970;</span> Şube / Servis Noktaları
            </a>
            <a class="@("nav-item" + Active("Personeller", "/AdminPanel/personeller"))" href="/AdminPanel/personeller">
                <span class="nav-ico">&#128101;</span> Personeller
            </a>
            <a class="@("nav-item" + Active("Kullanicilar", "/AdminPanel/kullanicilar"))" href="/AdminPanel/kullanicilar">
