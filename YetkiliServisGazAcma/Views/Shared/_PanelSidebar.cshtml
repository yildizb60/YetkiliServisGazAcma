            <a class="@("nav-item" + Active("DevreyeAlmalar", "/personel-panel/devreyealmalar"))" href="/personel-panel/devreyealmalar">
                <span class="nav-ico">&#128295;</span> Devreye Almalar
            </a>
            <a class="@("nav-item" + Active("Markalar", "/personel-panel/markalar"))" href="/personel-panel/markalar">
                <span class="nav-ico">&#127991;</span> Markalar
            </a>
            <a class="@("nav-item" + Active("YetkiliServisler", "/personel-panel/yetkiliservisler"))" href="/personel-panel/yetkiliservisler">
