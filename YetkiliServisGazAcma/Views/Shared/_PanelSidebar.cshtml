            </a>
            <a class="@("nav-item" + Active("Yetkiler", "/AdminPanel/yetkiler"))" href="/AdminPanel/yetkiler">
                <span class="nav-ico">&#128274;</span> Yetkiler
            </a>

            <div class="nav-section">Sistem</div>
            <a class="@("nav-item" + Active("Profil", "/AdminPanel/profil"))" href="/AdminPanel/profil">
                <span class="nav-ico">&#128100;</span> Profilim
            </a>
        }
    </nav>

    <a class="cikis-btn" href="/cikis">&#128682; Çıkış Yap</a>
</aside>
