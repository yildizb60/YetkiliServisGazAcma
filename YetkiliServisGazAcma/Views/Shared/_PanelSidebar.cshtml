                <span class="nav-ico">&#127968;</span> Ana Sayfa
            </a>

            <div class="nav-section">İşlemler</div>
            <a class="@("nav-item" + ActiveExact("DevreyeAl", "/ys-devreyeal"))" href="/ys-devreyeal">
                <span class="nav-ico">&#128295;</span> Cihaz Devreye Al
            </a>
            <a class="@("nav-item" + Active("DevreyeGecmis", "/ys-devreyeal/gecmis", "/ys-devreyeal/detay"))" href="/ys-devreyeal/gecmis">
