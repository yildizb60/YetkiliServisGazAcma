@{
    ViewData["Title"] = "SMS Doğrulama";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}
@section Styles {
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { min-height: 100vh; font-family: "Segoe UI", Arial, sans-serif; background: #f3f9ff; display: flex; align-items: center; justify-content: center; padding: 24px; color: #102a43; }
        .card { width: min(420px, 100%); background: #fff; border: 1px solid #dce8f5; border-radius: 16px; padding: 28px; box-shadow: 0 18px 50px rgba(16,42,67,.09); }
        .badge { width: 44px; height: 44px; border-radius: 12px; background: #edf6fb; color: #1B9FD4; display: flex; align-items: center; justify-content: center; font-size: 22px; margin-bottom: 18px; }
        h1 { font-size: 24px; margin-bottom: 8px; }
        .sub { color: #64809b; font-size: 13px; line-height: 1.6; margin-bottom: 20px; }
        .info { background: #eff6ff; color: #1e4f73; border: 1px solid #cfe4f6; padding: 10px 12px; border-radius: 10px; font-size: 13px; margin-bottom: 12px; }
        .hata { background: #fff5f5; color: #7f1d1d; border: 1px solid #fecaca; padding: 10px 12px; border-radius: 10px; font-size: 13px; margin-bottom: 12px; }
        label { display: block; font-size: 12px; font-weight: 800; color: #244b6d; margin-bottom: 7px; }
        input { width: 100%; padding: 14px 16px; border: 1.5px solid #cee0f1; border-radius: 10px; font-size: 20px; letter-spacing: .16em; text-align: center; outline: none; }
        input:focus { border-color: #1B9FD4; box-shadow: 0 0 0 3px rgba(27,159,212,.16); }
        button { width: 100%; margin-top: 16px; padding: 13px; border: none; border-radius: 10px; background: #1B9FD4; color: #fff; font-weight: 800; cursor: pointer; }
        a { display: block; margin-top: 14px; text-align: center; color: #64809b; text-decoration: none; font-size: 13px; }
    </style>
}
<div class="card">
    <div class="badge">&#128172;</div>
    <h1>SMS Doğrulama</h1>
    <div class="sub">Telefonunuza gönderilen doğrulama kodunu girin.</div>
    @if (TempData["Bilgi"] != null)
    {
        <div class="info">@TempData["Bilgi"]</div>
    }
    @if (ViewBag.Hata != null)
    {
        <div class="hata">@ViewBag.Hata</div>
    }
    <form method="post" action="/giris/sms-dogrula">
        @Html.AntiForgeryToken()
        <label>Doğrulama Kodu</label>
        <input name="kod" inputmode="numeric" autocomplete="one-time-code" maxlength="8" required />
        <button type="submit">Girişi Tamamla</button>
    </form>
    <a href="/giris">Giriş ekranına dön</a>
</div>
