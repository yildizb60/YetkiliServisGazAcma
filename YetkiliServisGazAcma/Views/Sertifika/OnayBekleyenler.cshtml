@model List<YetkiliServisGazAcma.Entities.Ys_Sertifika>
@{
    ViewData["Title"] = "Yetki Belgesi Onay";
    Layout = null;
    int onayBekleyen = ViewBag.OnayBekleyen is int v ? v : 0;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Yetki Belgesi Onay</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: "Segoe UI", "Segoe UI Emoji", "Segoe UI Symbol", "Apple Color Emoji", "Noto Color Emoji", Arial, sans-serif; background: #f0f4f8; color: #333; }
        .layout { display: flex; min-height: 100vh; }
        .sidebar { width: 230px; background: #1a1a2e; position: fixed; top: 0; left: 0; height: 100vh; display: flex; flex-direction: column; }
        .logo { padding: 22px 20px; border-bottom: 1px solid rgba(255,255,255,0.08); display: flex; align-items: center; gap: 12px; }
        .logo-circle { width: 36px; height: 36px; background: #1B9FD4; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
        .logo-dot { width: 14px; height: 14px; background: #4CAF7D; border-radius: 50%; }
        .logo-text { color: #fff; font-size: 15px; font-weight: bold; }
        .logo-sub { color: rgba(255,255,255,0.4); font-size: 11px; margin-top: 2px; }
        .nav { padding: 16px 0; flex: 1; }
        .nav-section { color: rgba(255,255,255,0.3); font-size: 10px; padding: 14px 20px 5px; text-transform: uppercase; letter-spacing: .08em; }
        .nav-item { display: flex; align-items: center; gap: 10px; padding: 11px 20px; color: rgba(255,255,255,0.65); font-size: 14px; text-decoration: none; transition: background .15s; }
        .nav-ico { width: 18px; text-align: center; font-size: 15px; line-height: 1; font-family: "Segoe UI Emoji","Segoe UI Symbol","Apple Color Emoji","Noto Color Emoji",sans-serif; }
        .nav-item:hover { background: rgba(255,255,255,0.06); color: #fff; }
        .nav-item.active { background: #1B9FD4; color: #fff; }
        .nav-badge { background: #e24b4a; color: #fff; font-size: 9px; padding: 2px 6px; border-radius: 8px; margin-left: auto; }
        .cikis-btn { background: transparent; border: 1px solid rgba(255,255,255,0.2); color: rgba(255,255,255,0.6); padding: 9px 16px; border-radius: 6px; font-size: 13px; margin: 16px 20px; display: block; text-align: center; text-decoration: none; }
        .main { margin-left: 230px; flex: 1; }
        .topbar { background: #fff; padding: 16px 32px; display: flex; align-items: center; justify-content: space-between; border-bottom: 2px solid #1B9FD4; }
        .topbar-left { font-size: 17px; font-weight: bold; }
        .content { padding: 24px 28px; }
        .mesaj-basarili { background: #E1F5EE; color: #085041; padding: 12px 16px; border-radius: 8px; margin-bottom: 16px; font-size: 13px; }
        .mesaj-hata { background: #FCEBEB; color: #501313; padding: 12px 16px; border-radius: 8px; margin-bottom: 16px; font-size: 13px; }
        .sert-kart { background: #fff; border-radius: 10px; border: 1px solid #eee; padding: 20px; margin-bottom: 12px; }
        .sert-ust { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }
        .firma-adi { font-size: 15px; font-weight: bold; color: #333; }
        .firma-alt { font-size: 12px; color: #888; margin-top: 3px; }
        .badge { display: inline-block; padding: 4px 12px; border-radius: 10px; font-size: 12px; font-weight: bold; }
        .b-yellow { background: #FAEEDA; color: #633806; }
        .sert-detay { display: grid; grid-template-columns: repeat(5,1fr); gap: 12px; margin-bottom: 16px; padding: 12px; background: #f8f8f6; border-radius: 8px; }
        .detay-alan { font-size: 12px; }
        .detay-label { color: #888; margin-bottom: 3px; }
        .detay-deger { color: #333; font-weight: bold; }
        .aksiyonlar { display: flex; gap: 10px; align-items: center; }
        .btn-onayla { padding: 8px 20px; background: #4CAF7D; color: #fff; border: none; border-radius: 6px; font-size: 13px; font-weight: bold; cursor: pointer; }
        .btn-incele { padding: 8px 16px; background: #E6F1FB; color: #0C447C; border: none; border-radius: 6px; font-size: 12px; text-decoration: none; }
        .red-form { display: flex; gap: 8px; flex: 1; }
        .red-input { flex: 1; padding: 8px 10px; border: 1px solid #ddd; border-radius: 6px; font-size: 13px; outline: none; }
        .btn-reddet { padding: 8px 16px; background: #FCEBEB; color: #501313; border: 1px solid #F09595; border-radius: 6px; font-size: 12px; font-weight: bold; cursor: pointer; }
        .bos { text-align: center; padding: 60px; color: #bbb; font-size: 14px; }
    </style>
</head>
<body>
<div class="layout">
    <div class="sidebar">
        <div class="logo">
            @if (!string.IsNullOrWhiteSpace(ViewBag.PanelLogoUrl as string)) { <img class="panel-company-logo" src="@(ViewBag.PanelLogoUrl as string)" alt="@(ViewBag.PanelSirketAdi as string ?? "Şirket")" style="width:44px;height:44px;object-fit:contain;border-radius:14px;background:#fff;padding:5px;box-shadow:0 8px 20px rgba(0,0,0,.12);" /> } else { <div class="logo-circle"><div class="logo-dot"></div></div> }
            <div>
                <div class="logo-text">Gaz Açma</div>
                <div class="logo-sub">Süper Admin Paneli</div><div class="logo-company" style="color:rgba(255,255,255,.68);font-size:10px;margin-top:4px;font-weight:700;letter-spacing:.03em;line-height:1.2;">@(ViewBag.PanelSirketAdi as string ?? "Genel Yönetim")</div>
            </div>
        </div>
        <div class="nav">
            <div class="nav-section">Genel</div>
            <a class="nav-item" href="/AdminPanel"><span class="nav-ico">&#127968;</span> Dashboard</a>

            <div class="nav-section">Yönetim</div>
            <a class="nav-item" href="/Marka"><span class="nav-ico">&#127991;</span> Markalar</a>
            <a class="nav-item active" href="/AdminPanel/onay-bekleyenler">
                <span class="nav-ico">&#9989;</span> Yetki Belgesi Onay
                @if (onayBekleyen > 0) { <span class="nav-badge">@onayBekleyen</span> }
            </a><a class="nav-item" href="/AdminPanel/yetki-belgesi-uyarilari"><span class="nav-ico">&#9888;</span> Biti&#351; Uyar&#305;lar&#305;</a>
        <a class="nav-item" href="/AdminPanel/raporlar"><span class="nav-ico">&#128202;</span> Raporlar</a>
        <a class="nav-item" href="/AdminPanel/yetkiliservisler"><span class="nav-ico">&#128295;</span> Yetkili Servisler</a>
        <a class="nav-item" href="/AdminPanel/subeler"><span class="nav-ico">&#127970;</span> &#350;ube / Servis Noktalar&#305;</a>
            <a class="nav-item" href="/AdminPanel/personeller"><span class="nav-ico">&#128101;</span> Personeller</a>
            <a class="nav-item" href="/AdminPanel/kullanicilar"><span class="nav-ico">&#128100;</span> Kullanıcılar</a>
            <a class="nav-item" href="/AdminPanel/yetkiler"><span class="nav-ico">&#128274;</span> Yetkiler</a>

            <div class="nav-section">Sistem</div>
            <a class="nav-item" href="/AdminPanel/profil"><span class="nav-ico">&#128100;</span> Profilim</a>
        </div>
        <a class="cikis-btn" href="/cikis">&#128682; Çıkış Yap</a>
    </div>

    <div class="main">
        <div class="topbar">
            <div class="topbar-left">Onay Bekleyen Yetki Belgesilar</div>
        </div>
        <div class="content">

            @if (TempData["Basarili"] != null)
            {
                <div class="mesaj-basarili">✅ @TempData["Basarili"]</div>
            }
            @if (TempData["Hata"] != null)
            {
                <div class="mesaj-hata">❌ @TempData["Hata"]</div>
            }

            @if (!Model.Any())
            {
                <div class="bos"> Onay bekleyen yetki belgesi bulunmuyor</div>
            }
            else
            {
                @foreach (var s in Model)
                {
                    var baslangic = s.SertifikaBaslangicTarihi ?? s.OlusturmaTarihi;
                    var kalanGun = (s.SertifikaBitisTarihi.Date - DateTime.Now.Date).Days;
                    var kalanYazi = kalanGun < 0 ? $"{Math.Abs(kalanGun)} gün geçti" : $"{kalanGun} gün kaldı";
                    <div class="sert-kart">
                        <div class="sert-ust">
                            <div>
                                <div class="firma-adi">@s.Firma?.FirmaAdi</div>
                                <div class="firma-alt">
                                    @s.Firma?.Sirket?.SirketAdi  @s.Firma?.Telefon
                                </div>
                            </div>
                            <span class="badge b-yellow">? Onay Bekliyor</span>
                        </div>

                        <div class="sert-detay">
                            <div class="detay-alan">
                                <div class="detay-label">Yükleme Tarihi</div>
                                <div class="detay-deger">
                                    @s.OlusturmaTarihi.ToString("dd.MM.yyyy HH:mm")
                                </div>
                            </div>
                            <div class="detay-alan">
                                <div class="detay-label">Yetki Belgesi Başlangıç</div>
                                <div class="detay-deger">
                                    @baslangic.ToString("dd.MM.yyyy")
                                </div>
                            </div>
                            <div class="detay-alan">
                                <div class="detay-label">Yetki Belgesi Bitiş</div>
                                <div class="detay-deger">
                                    @s.SertifikaBitisTarihi.ToString("dd.MM.yyyy")
                                </div>
                            </div>
                            <div class="detay-alan">
                                <div class="detay-label">Kalan Gün</div>
                                <div class="detay-deger">@kalanYazi</div>
                            </div>
                            <div class="detay-alan">
                                <div class="detay-label">VKN</div>
                                <div class="detay-deger">@s.Firma?.VergiNo</div>
                            </div>
                        </div>

                        <div class="aksiyonlar">
                            <a class="btn-incele" href="@s.DosyaYolu"
                               target="_blank"> Yetki Belgesini İncele</a>

                            <form method="post" action="/ys-yetki-belgesi/onayla">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@s.Id" />
                                <button type="submit" class="btn-onayla">✅ Onayla</button>
                            </form>

                            <form method="post" action="/ys-yetki-belgesi/reddet"
                                  class="red-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@s.Id" />
                                <input type="text" name="gerekce"
                                       class="red-input"
                                       placeholder="Red gerekçesi..." />
                                <button type="submit" class="btn-reddet">❌ Reddet</button>
                            </form>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>
</body>
</html>


































