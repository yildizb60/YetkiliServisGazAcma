@model List<YetkiliServisGazAcma.Entities.Ys_Sertifika>
@{
    ViewData["Title"] = "Yetki Belgem";
    Layout = null;
    var firma = ViewBag.Firma as YetkiliServisGazAcma.Entities.Ys_Firma;
    string adSoyad = firma?.YetkiliKisi ?? "Yetkili Servis";
    string basHarf = !string.IsNullOrEmpty(adSoyad) ? adSoyad.Substring(0, 1).ToUpper() : "Y";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Yetki Belgem</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: "Segoe UI", "Segoe UI Emoji", "Segoe UI Symbol", "Apple Color Emoji", "Noto Color Emoji", Arial, sans-serif; background: #f0f4f8; }
        .layout { display: flex; min-height: 100vh; }
        .sidebar { width: 230px; background: #1a1a2e; position: fixed; top: 0; left: 0; height: 100vh; display: flex; flex-direction: column; }
        .logo { padding: 22px 20px; border-bottom: 1px solid rgba(255,255,255,0.08); display: flex; align-items: center; gap: 12px; }
        .logo-circle { width: 40px; height: 40px; background: #1B9FD4; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
        .logo-dot { width: 16px; height: 16px; background: #4CAF7D; border-radius: 50%; }
        .logo-text { color: #fff; font-size: 15px; font-weight: bold; }
        .logo-sub { color: rgba(255,255,255,0.4); font-size: 11px; margin-top: 2px; }
        .nav { padding: 16px 0; flex: 1; }
        .nav-section { color: rgba(255,255,255,0.3); font-size: 10px; padding: 14px 20px 5px; text-transform: uppercase; letter-spacing: .08em; }
        .nav-item { display: flex; align-items: center; gap: 10px; padding: 11px 20px; color: rgba(255,255,255,0.65); font-size: 14px; text-decoration: none; }
        .nav-item:hover { background: rgba(255,255,255,0.06); color: #fff; }
        .nav-item.active { background: #1B9FD4; color: #fff; }
        .cikis-btn { background: transparent; border: 1px solid rgba(255,255,255,0.2); color: rgba(255,255,255,0.6); padding: 9px 16px; border-radius: 6px; font-size: 13px; margin: 16px 20px; display: block; text-align: center; text-decoration: none; }
        .main { margin-left: 230px; flex: 1; }
        .topbar { background: #fff; padding: 16px 32px; display: flex; align-items: center; justify-content: space-between; border-bottom: 2px solid #1B9FD4; }
        .topbar-left { font-size: 17px; font-weight: bold; color: #1a1a1a; }
        .topbar-right { display: flex; align-items: center; gap: 12px; }
        .notif-wrap { position: relative; }
        .notif { position: relative; width: 32px; height: 32px; border-radius: 50%; background: #f0f4f8; display: flex; align-items: center; justify-content: center; font-size: 16px; color: #1B9FD4; border: none; cursor: pointer; }
        .notif-badge { position: absolute; top: -4px; right: -4px; background: #e24b4a; color: #fff; font-size: 9px; font-weight: bold; padding: 2px 5px; border-radius: 10px; }
        .notif-panel { position: absolute; right: 0; top: 38px; width: 320px; background: #fff; border: 1px solid #e7e7e7; border-radius: 10px; box-shadow: 0 10px 24px rgba(0,0,0,0.08); padding: 10px; display: none; z-index: 50; }
        .notif-panel.open { display: block; }
        .notif-title { font-size: 12px; font-weight: bold; color: #555; padding: 6px 8px 8px; border-bottom: 1px solid #f0f0f0; margin-bottom: 6px; }
        .notif-item { display: flex; gap: 10px; padding: 8px; border-radius: 8px; }
        .notif-item:hover { background: #f7fafc; }
        .notif-dot { width: 8px; height: 8px; border-radius: 50%; margin-top: 6px; background: #1B9FD4; flex-shrink: 0; }
        .notif-text { font-size: 13px; color: #333; line-height: 1.35; }
        .notif-empty { padding: 10px 8px; font-size: 12px; color: #999; }
        .avatar { width: 36px; height: 36px; border-radius: 50%; background: #1B9FD4; color: #fff; display: flex; align-items: center; justify-content: center; font-weight: bold; }
        .user-name { font-size: 14px; color: #333; font-weight: bold; }
        .user-role { font-size: 11px; color: #1B9FD4; }
        .content { padding: 28px 32px; }
        .mesaj-basarili { background: #E1F5EE; color: #085041; padding: 12px 16px; border-radius: 8px; margin-bottom: 16px; font-size: 13px; }
        .mesaj-hata { background: #FCEBEB; color: #501313; padding: 12px 16px; border-radius: 8px; margin-bottom: 16px; font-size: 13px; }
        .yukle-kart { background: #fff; border-radius: 10px; border: 1px solid #eee; padding: 24px; margin-bottom: 20px; }
        .kart-baslik { font-size: 14px; font-weight: bold; color: #333; margin-bottom: 16px; padding-bottom: 10px; border-bottom: 1px solid #f0f0ee; }
        .grid { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 16px; align-items: end; }
        .alan { display: flex; flex-direction: column; gap: 5px; }
        label { font-size: 12px; color: #444; font-weight: bold; }
        input[type=file], input[type=date] { padding: 8px 10px; border: 1px solid #ddd; border-radius: 6px; font-size: 13px; width: 100%; outline: none; }
        input:focus { border-color: #1B9FD4; }
        .btn-yukle { padding: 10px 24px; background: #1B9FD4; color: #fff; border: none; border-radius: 8px; font-size: 13px; font-weight: bold; cursor: pointer; width: 100%; }
        .btn-yukle:hover { background: #0d7faa; }
        .sert-kart { background: #fff; border-radius: 10px; border: 1px solid #eee; padding: 20px; display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
        .sert-sol { display: flex; align-items: center; gap: 16px; }
        .sert-icon { width: 48px; height: 48px; background: #E6F1FB; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 22px; }
        .sert-baslik { font-size: 14px; font-weight: bold; color: #333; }
        .sert-alt { font-size: 12px; color: #888; margin-top: 3px; }
        .badge { display: inline-block; padding: 4px 12px; border-radius: 10px; font-size: 12px; font-weight: bold; }
        .b-yellow { background: #FAEEDA; color: #633806; }
        .b-green { background: #E1F5EE; color: #085041; }
        .b-red { background: #FCEBEB; color: #501313; }
        .btn-indir { padding: 7px 16px; background: #E6F1FB; color: #0C447C; border: none; border-radius: 6px; font-size: 12px; font-weight: bold; text-decoration: none; }
        .btn-sil { padding: 7px 16px; background: #FCEBEB; color: #8A1F1F; border: none; border-radius: 6px; font-size: 12px; font-weight: bold; cursor: pointer; }
        .bos { text-align: center; padding: 40px; color: #bbb; font-size: 13px; }
        .filter-bar { background: #fff; border-radius: 10px; border: 1px solid #eee; padding: 12px 14px; display: flex; gap: 10px; align-items: center; margin-bottom: 14px; }
        .filter-bar input, .filter-bar select { padding: 8px 10px; border: 1px solid #ddd; border-radius: 6px; font-size: 13px; }
    </style>
</head>
<body>
<div class="layout">
    <div class="sidebar">
        <div class="logo">
            @if (!string.IsNullOrWhiteSpace(ViewBag.PanelLogoUrl as string)) { <img class="panel-company-logo" src="@(ViewBag.PanelLogoUrl as string)" alt="@(ViewBag.PanelSirketAdi as string ?? "Şirket")" style="width:44px;height:44px;object-fit:contain;border-radius:14px;background:#fff;padding:5px;box-shadow:0 8px 20px rgba(0,0,0,.12);" /> } else { <div class="logo-circle"><div class="logo-dot"></div></div> }
            <div>
                <div class="logo-text">Gaz Açma</div>
                <div class="logo-sub">Yetkili Servis</div><div class="logo-company" style="color:rgba(255,255,255,.68);font-size:10px;margin-top:4px;font-weight:700;letter-spacing:.03em;line-height:1.2;">@(ViewBag.PanelSirketAdi as string ?? "Genel Yönetim")</div>
            </div>
        </div>
        <div class="nav">
            <div class="nav-section">Firma</div>
            <a class="nav-item" href="/ys-panel">&#127968; Ana Sayfa</a>
            <div class="nav-section">Firma</div>
            <a class="nav-item" href="/ys-devreyeal">&#128295; Cihaz Devreye Al</a>
            <a class="nav-item" href="/ys-devreyeal/gecmis">&#128221; İşlem Geçmişim</a>
            <a class="nav-item" href="/ys-panel/raporlar">&#128202; Raporlarım</a>
            <div class="nav-section">Firma</div>
            <a class="nav-item active" href="/ys-yetki-belgesi">&#128196; Yetki Belgem</a>
            <a class="nav-item" href="/ys-panel/markalar">&#128203; Markalarım</a>
            <a class="nav-item" href="/ys-panel/subeler">&#127970; Şube / Servis Noktaları</a>
            <a class="nav-item" href="/ys-panel/profil">&#128100; Profilim</a>
        </div>
        <a class="cikis-btn" href="/cikis">Çıkış Yap</a>
    </div>

    <div class="main">
        <div class="topbar">
            <div class="topbar-left">&#128196; Yetki Belgem</div>
            <div class="topbar-right">
                @await Html.PartialAsync("_NotificationPanel")
                <div>
                    <div class="user-name">@adSoyad</div>
                    <div class="user-role">Yetkili Servis</div><div class="user-company" style="font-size:10px;color:#6b7c8e;margin-top:2px;font-weight:700;">@(ViewBag.PanelSirketAdi as string ?? "Genel Yönetim")</div>
                </div>
                <div class="avatar">@basHarf</div>
            </div>
        </div>
        <div class="content">

            @if (TempData["Basarili"] != null)
            {
                <div class="mesaj-basarili">&#9989; @TempData["Basarili"]</div>
            }
            @if (TempData["Hata"] != null)
            {
                <div class="mesaj-hata">&#10060; @TempData["Hata"]</div>
            }

            <div class="yukle-kart">
                <div class="kart-baslik">&#128196; Yeni Yetki Belgesi Yükle</div>
                <form method="post" action="/ys-yetki-belgesi/yukle"
                      enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="grid">
                        <div class="alan">
                            <label>Yetki Belgesi Dosyası (PDF/JPG/PNG)</label>
                            <input type="file" name="dosya"
                                   accept=".pdf,.jpg,.jpeg,.png" required />
                        </div>
                        <div class="alan">
                            <label>Yetki Belgesi Başlangıç Tarihi</label>
                            <input type="date" name="baslangicTarihi"
                                   value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="alan">
                            <label>Yetki Belgesi Bitiş Tarihi</label>
                            <input type="date" name="bitisTarihi" required />
                        </div>
                        <div class="alan">
                            <button type="submit" class="btn-yukle">
                                &#128228; Yükle
                            </button>
                        </div>
                    </div>
                </form>
            </div>

            <div class="kart-baslik" style="margin-bottom:12px;">
                &#128202; Yetki Belgesi Geçmişi
            </div>

            <div class="filter-bar">
                <input type="text" id="sertifikaSearch" placeholder="Tarih veya durum ara..." />
                <select id="sertifikaDurum">
                    <option value="">Tüm</option>
                    <option value="Onay Bekliyor">Onay Bekliyor</option>
                    <option value="Onaylandı">Onaylandı</option>
                    <option value="Reddedildi">Reddedildi</option>
                </select>
            </div>

            @if (!Model.Any())
            {
                <div class="bos">Henüz yetki belgesi yüklenmemiş.</div>
            }
            else
            {
                @foreach (var s in Model)
                {
                    var baslangic = s.SertifikaBaslangicTarihi ?? s.OlusturmaTarihi;
                    var durumText = s.Durum == 0 ? "Onay Bekliyor" : s.Durum == 1 ? "Onaylandı" : "Reddedildi";
                    var searchText = $"{s.OlusturmaTarihi:dd.MM.yyyy} {baslangic:dd.MM.yyyy} {s.SertifikaBitisTarihi:dd.MM.yyyy} {durumText}";
                    <div class="sert-kart" data-search="@searchText" data-durum="@durumText">
                        <div class="sert-sol">
                            <div class="sert-icon">&#128196;</div>
                            <div>
                                <div class="sert-baslik">
                                    Yetki Belgesi @s.OlusturmaTarihi.ToString("dd.MM.yyyy")
                                </div>
                                <div class="sert-alt">
                                    Başlangıç: @baslangic.ToString("dd.MM.yyyy")
                                </div>
                                <div class="sert-alt">
                                    Bitiş: @s.SertifikaBitisTarihi.ToString("dd.MM.yyyy")
                                </div>
                                @if (!string.IsNullOrEmpty(s.RedGerekce))
                                {
                                    <div class="sert-alt" style="color:#e24b4a;">
                                        Red gereke: @s.RedGerekce
                                    </div>
                                }
                            </div>
                        </div>
                        <div style="display:flex;align-items:center;gap:12px;">
                            <span class="badge @(s.Durum == 0 ? "b-yellow" : s.Durum == 1 ? "b-green" : "b-red")">
                                @durumText
                            </span>
                            <a class="btn-indir" href="@s.DosyaYolu" target="_blank">
                                &#128065; Görüntüle
                            </a>
                            <form method="post" action="/ys-yetki-belgesi/sil" onsubmit="return confirm('Yetki belgesini silmek istiyor musunuz?');" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@s.Id" />
                                <button type="submit" class="btn-sil">Sil</button>
                            </form>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
        </div>
    </div>
</div>

<script>
    (function () {
        var searchInput = document.getElementById('sertifikaSearch');
        var durumSelect = document.getElementById('sertifikaDurum');
        var cards = Array.prototype.slice.call(document.querySelectorAll('.sert-kart'));

        if (!searchInput || !durumSelect || cards.length === 0) {
            return;
        }

        function filtrele() {
            var q = (searchInput.value || '').toLowerCase().trim();
            var durum = (durumSelect.value || '').toLowerCase().trim();

            cards.forEach(function (card) {
                var metin = (card.getAttribute('data-search') || '').toLowerCase();
                var kartDurum = (card.getAttribute('data-durum') || '').toLowerCase();

                var aramaUygun = q === '' || metin.indexOf(q) !== -1;
                var durumUygun = durum === '' || kartDurum === durum;

                card.style.display = (aramaUygun && durumUygun) ? 'flex' : 'none';
            });
        }

        searchInput.addEventListener('input', filtrele);
        durumSelect.addEventListener('change', filtrele);
    })();
</script>

</body>
</html>

























