@model List<YetkiliServisGazAcma.Entities.Ys_Sertifika>
@{
    ViewData["Title"] = "Yetki Belgem";
    ViewData["PanelTitle"] = "Yetki Belgem";
    ViewData["PanelSubtitle"] = "Yetkili Servis";
    ViewData["ActiveMenu"] = "YetkiBelgesi";
    ViewData["PanelArea"] = "YetkiliServis";
    Layout = "~/Views/Shared/_PanelLayout.cshtml";
}

@section Styles {
    <style>
        .cert-stack {
            display: grid;
            gap: 16px;
        }

        .cert-message {
            padding: 12px 14px;
            border-radius: var(--df-radius);
            border: 1px solid var(--df-border);
            font-size: 13px;
            font-weight: 700;
        }

        .cert-upload {
            padding: 16px;
        }

        .cert-file-cell {
            display: flex;
            align-items: center;
            gap: 10px;
            min-width: 220px;
        }

        .cert-file-icon {
            width: 38px;
            height: 38px;
            border-radius: var(--df-radius);
            background: var(--df-primary-soft);
            color: var(--df-primary);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
        }

        .cert-reason {
            margin-top: 5px;
            color: var(--df-danger);
            font-size: 12px;
            font-weight: 600;
        }

        @@media (max-width: 860px) {
            .cert-upload .df-form-row,
            .cert-upload .df-field,
            .cert-upload .df-btn {
                width: 100%;
            }
        }
    </style>
}

<div class="cert-stack">
    @if (TempData["Basarili"] != null)
    {
        <div class="cert-message mesaj-basarili">@TempData["Basarili"]</div>
    }
    @if (TempData["Hata"] != null)
    {
        <div class="cert-message mesaj-hata">@TempData["Hata"]</div>
    }

    <section class="df-page-panel">
        <div class="df-panel-head">
            <div>
                <h2 class="df-panel-title">Yeni Yetki Belgesi Y&#252;kle</h2>
                <div class="df-panel-subtitle">PDF, JPG veya PNG dosyas&#305; ekleyin.</div>
            </div>
        </div>
        <form class="cert-upload" method="post" action="/ys-yetki-belgesi/yukle" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="df-form-row">
                <div class="df-field df-field-wide">
                    <label>Yetki Belgesi Dosyas&#305;</label>
                    <input class="df-control" type="file" name="dosya" accept=".pdf,.jpg,.jpeg,.png" required />
                </div>
                <div class="df-field">
                    <label>Ba&#351;lang&#305;&#231; Tarihi</label>
                    <input class="df-control" type="date" name="baslangicTarihi" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                </div>
                <div class="df-field">
                    <label>Biti&#351; Tarihi</label>
                    <input class="df-control" type="date" name="bitisTarihi" required />
                </div>
                <button type="submit" class="df-btn df-btn-primary">Y&#252;kle</button>
            </div>
        </form>
    </section>

    <section class="df-page-panel">
        <div class="df-panel-head">
            <div>
                <h2 class="df-panel-title">Yetki Belgesi Ge&#231;mi&#351;i</h2>
                <div class="df-panel-subtitle">@Model.Count kay&#305;t</div>
            </div>
        </div>
        <div class="df-toolbar">
            <div class="df-form-row">
                <div class="df-field">
                    <label>Arama</label>
                    <input class="df-control" type="text" id="sertifikaSearch" placeholder="Tarih veya durum ara" />
                </div>
                <div class="df-field">
                    <label>Durum</label>
                    <select class="df-control" id="sertifikaDurum">
                        <option value="">T&#252;m&#252;</option>
                        <option value="Onay Bekliyor">Onay Bekliyor</option>
                        <option value="Onaylandı">Onayland&#305;</option>
                        <option value="Reddedildi">Reddedildi</option>
                    </select>
                </div>
            </div>
        </div>

        @if (!Model.Any())
        {
            <div class="df-empty">
                <div class="df-empty-title">Hen&#252;z yetki belgesi yok</div>
                <div class="df-empty-text">Y&#252;klenen belgeler burada listelenecek.</div>
            </div>
        }
        else
        {
            <div class="df-table-wrap">
                <table class="df-table">
                    <thead>
                        <tr>
                            <th>Belge</th>
                            <th>Ba&#351;lang&#305;&#231;</th>
                            <th>Biti&#351;</th>
                            <th>Durum</th>
                            <th>&#304;&#351;lem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model)
                        {
                            var baslangic = s.SertifikaBaslangicTarihi ?? s.OlusturmaTarihi;
                            var durumText = s.Durum == 0 ? "Onay Bekliyor" : s.Durum == 1 ? "Onaylandı" : "Reddedildi";
                            var durumClass = s.Durum == 0 ? "b-yellow" : s.Durum == 1 ? "b-green" : "b-red";
                            var searchText = $"{s.OlusturmaTarihi:dd.MM.yyyy} {baslangic:dd.MM.yyyy} {s.SertifikaBitisTarihi:dd.MM.yyyy} {durumText}";
                            <tr class="sert-row" data-search="@searchText" data-durum="@durumText">
                                <td>
                                    <div class="cert-file-cell">
                                        <span class="cert-file-icon">PDF</span>
                                        <div>
                                            <div class="df-cell-main">Yetki Belgesi</div>
                                            <div class="df-cell-sub">@s.OlusturmaTarihi.ToString("dd.MM.yyyy") tarihinde y&#252;klendi</div>
                                            @if (!string.IsNullOrEmpty(s.RedGerekce))
                                            {
                                                <div class="cert-reason">Red gerek&#231;esi: @s.RedGerekce</div>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td>@baslangic.ToString("dd.MM.yyyy")</td>
                                <td>@s.SertifikaBitisTarihi.ToString("dd.MM.yyyy")</td>
                                <td><span class="badge @durumClass">@durumText</span></td>
                                <td>
                                    <div class="df-actions">
                                        <a class="df-btn df-btn-secondary df-btn-sm" href="@s.DosyaYolu" target="_blank">G&#246;r&#252;nt&#252;le</a>
                                        <form method="post" action="/ys-yetki-belgesi/sil" onsubmit="return confirm('Yetki belgesini silmek istiyor musunuz?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@s.Id" />
                                            <button type="submit" class="df-btn df-btn-danger df-btn-sm">Sil</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>

@section Scripts {
    <script>
        (function () {
            const searchInput = document.getElementById("sertifikaSearch");
            const durumSelect = document.getElementById("sertifikaDurum");
            const rows = Array.from(document.querySelectorAll(".sert-row"));

            if (!searchInput || !durumSelect || rows.length === 0) return;

            function filtrele() {
                const q = (searchInput.value || "").toLowerCase().trim();
                const durum = (durumSelect.value || "").toLowerCase().trim();

                rows.forEach(function (row) {
                    const metin = (row.getAttribute("data-search") || "").toLowerCase();
                    const satirDurum = (row.getAttribute("data-durum") || "").toLowerCase();
                    const aramaUygun = q === "" || metin.indexOf(q) !== -1;
                    const durumUygun = durum === "" || satirDurum === durum;
                    row.hidden = !(aramaUygun && durumUygun);
                });
            }

            searchInput.addEventListener("input", filtrele);
            durumSelect.addEventListener("change", filtrele);
        })();
    </script>
}
