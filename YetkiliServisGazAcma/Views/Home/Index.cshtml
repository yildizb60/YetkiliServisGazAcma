@using System.Globalization
@{
    ViewData["Title"] = "Ana Sayfa";
    Layout = "_PublicLayout";
    var tr = new CultureInfo("tr-TR");
    var servisCount = (long)(ViewBag.ServisCount ?? 0L);
    var devreyeCount = (long)(ViewBag.DevreyeCount ?? 0L);
    var sertifikaCount = (long)(ViewBag.SertifikaCount ?? 0L);
    var zamaninda = (double)(ViewBag.ZamanindaOran ?? 0d);
}
@section Styles {
    <style>
        :root {
            --c-primary: #3bb7e8;
            --c-primary-dark: #2a8fb2;
            --c-accent: #4caf7d;
            --c-ink: #0e1a24;
            --c-muted: #5a6b78;
            --c-bg: #e9edf2;
            --c-card: #ffffff;
            --c-border: #e7eef4;
            --c-shadow: 0 12px 40px rgba(10, 27, 43, 0.12);
        }
        * { box-sizing: border-box; }
        body { margin: 0; font-family: "Manrope", Arial, sans-serif; color: var(--c-ink); background: var(--c-card); }
        a { color: inherit; text-decoration: none; }
        .container { max-width: 1320px; margin: 0 auto; padding: 0 22px; }

       
        .site-header {
            position: relative; top: 0; z-index: 30;
            background: #fff; box-shadow: 0 12px 28px rgba(0,0,0,0.12);
            border-radius: 22px; margin: 18px auto -70px;
            max-width: 1480px; border: 1px solid #e6eef4;
        }
        .site-header-top { display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid var(--c-border); padding:12px 0; }
        .site-header-top-buttons { display:flex; gap:24px; font-size:14px; font-weight:800; text-transform:uppercase; margin-left:-8px; }
        .site-header-top-buttons a { padding:8px 6px; }
        .site-header-top-buttons a.active { color: #0e1a24; }
        .site-header-top-action { display:flex; align-items:center; gap:12px; }
        .header-search { display:flex; align-items:center; gap:8px; }
        .site-search-btn { width:34px; height:34px; border-radius:8px; border:1px solid #d6e3ee; background:#fff; cursor:pointer; display:grid; place-items:center; }
        .header-search-input { width:0; opacity:0; padding:0; border:0; height:32px; transition: all .2s ease; pointer-events:none; }
        .header-search.active .header-search-input { width:180px; opacity:1; padding:6px 10px; border:1px solid #d6e3ee; border-radius:8px; pointer-events:auto; }
        .site-header-social { display:flex; gap:10px; }
        .sm-btn { width:36px; height:36px; border-radius:10px; border:1px solid #d6efe3; background:#f7fbf9; display:grid; place-items:center; cursor:pointer; transition: all .2s ease; box-shadow: 0 6px 12px rgba(0,0,0,0.08); }
        .sm-btn:hover { background:#eef9f2; }
        .site-header-lang { font-weight:800; font-size:12px; margin-left:8px; }
        .icon { display:inline-block; width:18px; height:18px; background-repeat:no-repeat; background-position:center; background-size:contain; }
        .icon-search { background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%234CAF7D' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><circle cx='11' cy='11' r='7'/><line x1='21' y1='21' x2='16.65' y2='16.65'/></svg>"); }
        .icon-facebook { background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%234CAF7D'><path d='M13 3h4v4h-4c-1.1 0-2 .9-2 2v2h6v4h-6v6h-4v-6H5v-4h4V9c0-3.3 2.7-6 6-6z'/></svg>"); }
        .icon-instagram { background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%234CAF7D'><path d='M7 3h10a4 4 0 0 1 4 4v10a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V7a4 4 0 0 1 4-4zm5 5.5A3.5 3.5 0 1 0 15.5 12 3.5 3.5 0 0 0 12 8.5zm6-2.75a1 1 0 1 0 1 1 1 1 0 0 0-1-1z'/></svg>"); }
        .icon-youtube { background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%234CAF7D'><path d='M21.8 8.001a2.75 2.75 0 0 0-1.94-1.95C18.1 5.5 12 5.5 12 5.5s-6.1 0-7.86.55A2.75 2.75 0 0 0 2.2 8c-.55 1.76-.55 4-.55 4s0 2.24.55 4a2.75 2.75 0 0 0 1.94 1.95C5.9 18.5 12 18.5 12 18.5s6.1 0 7.86-.55A2.75 2.75 0 0 0 21.8 16c.55-1.76.55-4 .55-4s0-2.24-.55-4zM10 15.5v-7l6 3.5-6 3.5z'/></svg>"); }
        .icon-linkedin { background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%234CAF7D'><path d='M6 9H3v12h3zM4.5 3.5A1.5 1.5 0 1 0 6 5a1.5 1.5 0 0 0-1.5-1.5zM21 13.5c0-2.5-1.3-4-3.5-4a3 3 0 0 0-2.5 1.4V9h-3v12h3v-6.5c0-1.4.8-2.2 1.9-2.2 1.1 0 1.7.8 1.7 2.2V21h3z'/></svg>"); }
        .site-header-content { display:flex; align-items:center; justify-content:space-between; padding:26px 0; min-height:98px; }
        .site-header-brand { font-weight:800; color: #0e1a24; font-size:22px; margin-left:-8px; }
        .site-header-cta a { padding:12px 26px; border-radius:999px; border:2px solid var(--c-ink); font-weight:800; color: #0e1a24; font-size:14px; margin-right:22px; }

        
        /* Ana sayfa hero banner görseli: home-banner-modern-dogalgaz-yasam-alani.png */
        .banner { position: relative; margin-top: 12px; color: #fff; background: url("/images/hero/home-banner-modern-dogalgaz-yasam-alani.png") center 52%/cover no-repeat; min-height: 460px; display: flex; align-items: center; }
        .banner::before { content: ""; position: absolute; inset: 0; background: linear-gradient(120deg, rgb(0 2 3), rgb(82 174 210 / 16%)); }
        .banner-inner { position: relative; width: 100%; padding: 50px 0; }
        .site-breadcrumbs { display: flex; align-items: center; gap: 8px; font-size: 12px; letter-spacing: .4px; text-transform: uppercase; opacity: .9; }
        .site-breadcrumbs .sep { opacity: .7; }
        .banner-title { text-align: center; margin: 50px 0 8px; font-size: 34px; font-weight: 800; }
        .banner-sub { text-align: center; font-size: 16px; opacity: .95; }
        .banner-arrow { text-align: center; font-size: 28px; margin-top: 16px; }


        .floating-cards {
            position: relative;
            max-width: 1300px;
            margin: -52px auto 0;
            padding: 0 18px;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 18px;
            z-index: 5;
        }

        .float-card {
            background: #fff;
            border-radius: 18px;
            padding: 26px 24px;
            box-shadow: 0 20px 50px rgba(10,27,43,0.14);
            border: 3px solid #53a92c;
            display: flex;
            flex-direction: column;
            gap: 14px;
            transition: transform .22s ease, box-shadow .22s ease;
            position: relative;
            overflow: hidden;
        }

        .float-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 5px;
            background: none;
        }

        .float-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 28px 60px rgba(10,27,43,0.18);
        }

        .float-card-icon {
            width: 44px; height: 44px;
            background: #f0fdf4;
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 20px;
        }

        .float-card-body { flex: 1; }

        .float-title {
            font-weight: 800;
            color: #0e1a24;
            font-size: 15px;
            margin-bottom: 5px;
        }

        .float-desc {
            color: #5a6b78;
            font-size: 13px;
            line-height: 1.5;
        }

        .float-card-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            font-weight: 700;
            color: #3bb7e8;
            text-decoration: none;
            margin-top: 4px;
        }

        .float-card-link::after {
            content: '→';
            transition: transform .15s;
        }

        .float-card:hover .float-card-link::after { transform: translateX(4px); }

        
        .section { max-width: 1100px; margin: 64px auto 0; padding: 0 18px; }

        .section-header {
            display: flex;
            align-items: baseline;
            justify-content: space-between;
            margin-bottom: 20px;
        }

        .section-title {
            font-size: 18px;
            font-weight: 800;
            color: #0e1a24;
            position: relative;
            padding-left: 14px;
        }

        .section-title::before {
            content: '';
            position: absolute;
            left: 0; top: 4px; bottom: 4px;
            width: 3px;
            background: #53a92c;
            border-radius: 2px;
        }

        .section-link {
            font-size: 12px;
            font-weight: 700;
            color: #0c8ecf;
        }

        .quick-links {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 14px;
        }

        .quick-card {
            background: #fff;
            border-radius: 14px;
            padding: 22px 20px;
            border: 1px solid var(--c-border);
            display: flex;
            align-items: flex-start;
            gap: 14px;
            transition: border-color .18s, box-shadow .18s, transform .18s;
            cursor: pointer;
        }

        .quick-card:hover {
            border-color: #3bb7e8;
            box-shadow: 0 8px 24px rgba(76,175,125,0.12);
            transform: translateY(-2px);
        }

        .quick-card-icon {
            width: 40px; height: 40px;
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 18px; flex-shrink: 0;
        }

        .qc-blue   { background: #eff6ff; }
        .qc-green  { background: #f0fdf4; }
        .qc-teal   { background: #f0fdfa; }

        .quick-card h4 {
            margin: 0 0 4px;
            font-size: 14px;
            font-weight: 800;
            color: #0e1a24;
        }

        .quick-card p {
            margin: 0;
            color: #5a6b78;
            font-size: 12px;
            line-height: 1.5;
        }

        
        .process {
            max-width: 1200px;
            margin: 30px auto 0;
            padding: 34px 18px 24px;
            background: #fff !important;
            border: none;
            border-radius: 0;
            position: relative;
            overflow: hidden;
        }
        .process-head {
            text-align: center;
            margin-bottom: 28px;
        }
        .process-title {
            font-size: 30px;
            font-weight: 800;
            color: #112537;
            margin: 0;
        }
        .process-sub {
            margin-top: 8px;
            color: #607487;
            font-size: 15px;
        }
        .process .step {
            position: absolute;
            left: 9%;
            right: 9%;
            top: 92px;
            z-index: 1;
            height: 260px;
            pointer-events: none;
        }
        .process .step img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            display: block;
            opacity: .95;
        }
        .process-row {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 18px;
            position: relative;
            z-index: 3;
            background: transparent !important;
            box-shadow: none !important;
            filter: none !important;
        }
        .single-process {
            text-align: center;
            transition: transform .22s ease;
            background: transparent !important;
            box-shadow: none !important;
            position: relative;
            z-index: 5;
        }
        .single-process.down {
            margin-top: 64px;
        }
        .single-process:hover {
            transform: translateY(-4px);
        }
        .single-process.down:hover {
            transform: translateY(-4px);
        }
        .process .single-process .part-icon {
            width: 130px;
            height: 130px;
            display: -webkit-inline-box;
            display: -ms-inline-flexbox;
            display: inline-flex;
            -webkit-box-orient: vertical;
            -webkit-box-direction: normal;
            -ms-flex-direction: column;
            flex-direction: column;
            -webkit-box-pack: center;
            -ms-flex-pack: center;
            justify-content: center;
            -webkit-box-align: center;
            -ms-flex-align: center;
            align-items: center;
            background: url("https://www.baskentgazyetkilifirma.com/assets/img/single-process-hover.png") 100% 100% no-repeat;
            background-size: contain;
            -webkit-transition: all 0.3s ease-in;
            -moz-transition: all 0.3s ease-in;
            -o-transition: all 0.3s ease-in;
            transition: all 0.3s ease-in;
            margin-bottom: 26px;
            position: relative;
            color: #fff;
            font-size: 44px;
            box-shadow: none !important;
            z-index: 6;
        }
        .process .single-process .part-icon::after {
            content: "";
            position: absolute;
            inset: 0;
            background: none;
            z-index: 1;
            pointer-events: none;
            opacity: 0;
            transition: opacity .2s ease-in;
        }
        .process .single-process .part-icon > span:not(.step-num) {
            position: relative;
            z-index: 3;
        }
        .process .single-process:hover .part-icon {
            background:none;
            transform: translateY(-3px) scale(1.02);
            box-shadow: none !important;
        }
        .process .single-process:hover .part-icon::after {
            background: url("/img/process/process.png?v=20260410b") 100% 100% no-repeat;
            background-size: contain;
            opacity: 1;
        }
        .step-num {
            position: absolute;
            top: -2px;
            left: -4px;
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: #515251;
            color: #fff;
            font-size: 13px;
            line-height: 28px;
            font-weight: 800;
            transition: background .22s ease;
            z-index: 4;
        }
        .single-process:hover .step-num {
            background: #53a92c;
        }
        .single-process h4 {
            font-weight: 700;
            color: #1a2430;
            font-size: 32px;
            font-size: clamp(24px, 1.3vw, 30px);
            margin-bottom: 10px;
            line-height: 1.1;
        }
        .single-process p {
            font-size: 16px;
            line-height: 1.7;
            color: #334f67;
            margin: 0 auto;
            max-width: 250px;
        }

        
        .stats-strip {
            margin-top: 64px;
            background: linear-gradient(135deg, #2fa9d9 0%, #3bb7e8 58%, #4caf7d 100%);
            color: #fff;
            padding: 36px 0;
            position: relative;
            overflow: hidden;
            isolation: isolate;
        }

        .stats-strip::before {
            content: '';
            position: absolute;
            inset: 0;
            background: url("/images/genelimg.png") no-repeat 50% 50%;
            background-size: cover;
            opacity: .22;
            z-index: 0;
        }

        .stats-grid {
            width: min(1320px, calc(100% - 56px));
            margin: 0 auto;
            padding: 0;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 0;
            position: relative;
            z-index: 1;
        }

        .stat-card {
            padding: 12px 14px 12px 10px;
            text-align: left;
            display: flex;
            flex-direction: column;
            align-items: ;
            border-right: 1px solid rgba(255,255,255,0.10);
        }

        .stat-card:last-child { border-right: none; }

        .stat-icon {
            font-size: 22px;
            margin-bottom: 8px;
            opacity: .95;
        }

        .stat-value {
            font-size: 30px;
            font-weight: 900;
            letter-spacing: -.02em;
            line-height: 1;
        }

        .stat-label {
            font-size: 13px;
            opacity: 0.9;
            font-weight: 700;
            margin-top: 6px;
            letter-spacing: .02em;
        }

        
        .emergency-strip {
            background: #052d4a;
            color: rgba(255,255,255,0.85);
            padding: 14px 18px;
            text-align: center;
            font-weight: 600;
            font-size: 13px;
            letter-spacing: .02em;
        }

        .emergency-strip strong { color: #fff; }

        
        .quick-actions {
            position: fixed;
            right: 0;
            top: 40%;
            transform: translateY(-50%);
            z-index: 40;
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .quick-action {
            position: relative;
        }

        .quick-action a {
            display: flex;
            align-items: center;
            background: #53a92c;
            color: #fff;
            border-radius: 12px 0 0 12px;
            padding: 12px 14px;
            text-decoration: none;
            overflow: hidden;
            white-space: nowrap;
            max-width: 52px;
            transition: max-width .25s ease, background .2s;
            box-shadow: -4px 4px 16px rgba(0,0,0,0.18);
        }

        .quick-action a:hover {
            max-width: 240px;
            background: #53a92c;
        }

        .qa-icon {
            width: 24px; height: 24px;
            display: flex; align-items: center; justify-content: center;
            font-size: 15px;
            flex-shrink: 0;
        }

        .qa-label {
            font-size: 12px;
            font-weight: 700;
            margin-left: 10px;
            opacity: 0;
            transition: opacity .15s .05s;
            flex-shrink: 0;
        }

        .quick-action a:hover .qa-label { opacity: 1; }

        
        footer { background: #ffffff; padding: 48px 18px 0; border-top: 3px solid #3bb7e8; margin-top: 0; }
        #footer .innerContainer { max-width: 1100px; margin: 0 auto; }
        #footer .columns { display: grid; grid-template-columns: 1.2fr 1fr 1.2fr; gap: 40px; padding-bottom: 36px; }
        #footer .mainHeading { font-weight: 800; margin-bottom: 14px; font-size: 14px; color: #1a3d2b; position: relative; padding-bottom: 10px; }
        #footer .mainHeading::after { content: ""; position: absolute; left: 0; bottom: 0; width: 32px; height: 2px; background: #1a3d2b; border-radius: 2px; }
        #footer .columnContent { font-size: 13px; color: #3a5a48; line-height: 1.75; }
        #footer .columnContent p { margin: 0; }
        #footer .columnContent div { margin-bottom: 4px; }
        #footer .footer-logo { margin-top: 16px; }
        #footer .footer-logo img { width: 100%; max-width: 200px; opacity: .75; }
        #footer ul.menu { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
        #footer ul.menu a { color: #3a5a48; transition: color .15s; font-size: 13px; }
        #footer ul.menu a:hover { color: #2aa66f; }
        #footerBottom { background: #eaf6fb; padding: 14px 0; border-top: 1px solid #d5eaf5; }
        #footerBottom .innerContainer { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; font-size: 12px; color: #3a5a48; padding: 0 18px; font-weight: 600; }

        @@media (max-width: 980px) {
            .site-header-top { flex-direction: column; gap: 8px; }
            .site-header-content { flex-direction: column; gap: 12px; }
            .floating-cards { grid-template-columns: 1fr; }
            .quick-links { grid-template-columns: 1fr; }
            .process .step { display: none; }
            .process-row { grid-template-columns: 1fr 1fr; }
            .single-process.down { margin-top: 0; }
            .part-icon { width: 130px; height: 130px; font-size: 40px; }
            .single-process h4 { font-size: 26px; }
            .single-process p { max-width: 320px; }
            .stats-grid { grid-template-columns: 1fr 1fr; }
            .stat-card { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.10); }
            #footer .columns { grid-template-columns: 1fr; }
            #footerBottom .innerContainer { flex-direction: column; gap: 8px; }
            .quick-actions { display: none; }
        }
        @@media (max-width: 640px) {
            .process-row { grid-template-columns: 1fr; }
        }
        </style>
}

    
    <header class="site-header">
        <div class="container">
            <div class="site-header-top">
                <div class="site-header-top-buttons">
                    <a class="active" href="/">ANASAYFA</a>
                    <a href="/yetkili-servisler">YETKİLİ SERVİSLER</a>
                    <a href="/kayit/yetkili-servis">YETKİLİ SERVİS KAYDI</a>
                    <a href="/giris">GİRİŞ</a>
                </div>
                <div class="site-header-top-action">
                    <div class="header-search">
                        <button class="site-search-btn" type="button" aria-label="Arama"><i class="icon icon-search"></i></button>
                        <input class="header-search-input" type="text" placeholder="Arama..." />
                    </div>
                    <div class="site-header-social">
                        <button type="button" class="sm-btn" aria-label="Facebook"><i class="icon icon-facebook"></i></button>
                        <button type="button" class="sm-btn" aria-label="Instagram"><i class="icon icon-instagram"></i></button>
                        <button type="button" class="sm-btn" aria-label="YouTube"><i class="icon icon-youtube"></i></button>
                        <button type="button" class="sm-btn" aria-label="LinkedIn"><i class="icon icon-linkedin"></i></button>
                    </div>
                    <div class="site-header-lang"><span>TR</span></div>
                </div>
            </div>
            <div class="site-header-content">
                <div class="site-header-brand">Yetkili Servis Gaz Açma Sistemi</div>
                <div class="site-header-cta"><a href="/yetkili-servisler"><span>SERVİS TALEBİ</span></a></div>
            </div>
        </div>
    </header>

    
    <section class="banner">
        <div class="container banner-inner">
            <div class="site-breadcrumbs">
                <span>ANASAYFA</span><span class="sep">&#8250;</span>
                <span>YETKİLİ SERVİSLER</span><span class="sep">&#8250;</span>
                <span class="active">LİSTE</span>
            </div>
            <div class="banner-title">YETKİLİ SERVİSLER</div>
            <div class="banner-sub">Yetkili servisleri hızlıca bulun, kayıt ve yetki belgesi süreçlerini tek ekrandan yönetin.</div>
            <div class="banner-arrow">&#x2304;</div>
        </div>
    </section>

    
    <div class="floating-cards">
        <div class="float-card">
            <div class="float-card-icon">&#128295;</div>
            <div class="float-card-body">
                <div class="float-title">Yetkili Servisler</div>
