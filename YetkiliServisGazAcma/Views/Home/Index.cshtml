    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var hs = document.querySelector(".header-search");
            if (!hs) return;
            var btn = hs.querySelector(".site-search-btn");
            var input = hs.querySelector(".header-search-input");
            if (!btn || !input) return;
            btn.addEventListener("click", function (e) {
                e.preventDefault();
                hs.classList.toggle("active");
                if (hs.classList.contains("active")) input.focus();
            });
            document.addEventListener("click", function (e) {
                if (!hs.contains(e.target)) hs.classList.remove("active");
            });
            document.addEventListener("keydown", function (e) {
                if (e.key === "Escape") hs.classList.remove("active");
            });
        });
    </script>
